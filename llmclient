import os
import json
import re
from openai import AzureOpenAI
from loguru import logger


class LLMClient:
    def __init__(self, model: str = "gpt-4o"):
        # `model` is the Azure deployment name, e.g. "gpt-4o", "gpt-4", "gpt-35-turbo"
        self.client = AzureOpenAI(
            api_key=os.environ["AZURE_OPENAI_API_KEY"],
            azure_endpoint=os.environ["AZURE_OPENAI_ENDPOINT"],
            api_version=os.environ.get("AZURE_OPENAI_API_VERSION", "2024-02-01"),
        )
        self.model = model

    def complete(self, system_prompt: str, user_content: str, max_tokens: int = 8192) -> str:
        logger.debug(f"LLM call | deployment={self.model} | max_tokens={max_tokens}")
        response = self.client.chat.completions.create(
            model=self.model,          # Azure deployment name
            max_tokens=max_tokens,
            messages=[
                {"role": "system", "content": system_prompt},
                {"role": "user",   "content": user_content},
            ],
        )
        return response.choices[0].message.content

    def parse_json(self, text: str):
        # Strip markdown fences
        match = re.search(r"```(?:json)?\s*([\s\S]+?)\s*```", text)
        if match:
            text = match.group(1)
        try:
            return json.loads(text)
        except json.JSONDecodeError:
            match = re.search(r"(\{[\s\S]*\}|\[[\s\S]*\])", text)
            if match:
                return json.loads(match.group(1))
            raise ValueError(f"No valid JSON found in LLM response:\n{text[:500]}")
