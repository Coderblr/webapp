            .cif-input:focus, .cif-select:focus {
                border-color: var(--teal);
                background: #fff;
                box-shadow: 0 0 0 3px var(--teal-glow);
            }
            .cif-input.err, .cif-select.err {
                border-color: var(--red);
                box-shadow: 0 0 0 3px rgba(225,29,72,.08);
            }

            /* number input spinner hide */
            .cif-input[type=number]::-webkit-inner-spin-button,
            .cif-input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; }

            /* number stepper */
            .cif-num-wrap { position: relative; display: flex; align-items: center; }
            .cif-num-wrap .cif-input { padding-right: 80px; }
            .cif-steppers {
                position: absolute; right: 6px;
                display: flex; gap: 4px;
            }
            .cif-step-btn {
                width: 28px; height: 28px;
                border-radius: 7px;
                border: 1.5px solid var(--line);
                background: var(--white);
                color: var(--ink3);
                font-size: 16px; font-weight: 600;
                cursor: pointer;
                display: flex; align-items: center; justify-content: center;
                transition: background .12s, border-color .12s, color .12s;
                user-select: none;
                line-height: 1;
            }
            .cif-step-btn:hover {
                background: var(--teal-lt);
                border-color: var(--teal);
                color: var(--teal);
            }

            /* select wrapper */
            .cif-sel-wrap { position: relative; }
            .cif-sel-arrow {
                position: absolute; right: 12px; top: 50%;
                transform: translateY(-50%);
                pointer-events: none;
                color: var(--slate);
            }

            /* CIF type cards */
            .cif-type-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
            .cif-type-card {
                padding: 12px 14px;
                border-radius: 10px;
                border: 1.5px solid var(--line);
                cursor: pointer;
                transition: border-color .15s, background .15s, box-shadow .15s;
                display: flex; flex-direction: column; gap: 4px;
                background: #fafbff;
                user-select: none;
            }
            .cif-type-card:hover {
                border-color: var(--teal);
                background: #f0fdfa;
            }
            .cif-type-card.selected {
                border-color: var(--teal);
                background: #f0fdfa;
                box-shadow: 0 0 0 3px var(--teal-glow);
            }
            .cif-type-icon {
                font-size: 18px; margin-bottom: 2px;
            }
            .cif-type-name {
                font-size: 12.5px; font-weight: 700;
                color: var(--ink2);
            }
            .cif-type-desc {
                font-size: 11px; font-weight: 400;
                color: var(--slate); line-height: 1.3;
            }
            .cif-type-radio {
                width: 14px; height: 14px; border-radius: 50%;
                border: 2px solid var(--line);
                background: var(--white);
                margin-left: auto;
                margin-top: -2px;
                transition: border-color .15s, background .15s;
                flex-shrink: 0;
                align-self: flex-start;
            }
            .cif-type-card.selected .cif-type-radio {
                border-color: var(--teal);
                background: var(--teal);
                box-shadow: inset 0 0 0 3px #fff;
            }

            /* error text */
            .cif-err {
                font-size: 12px; font-weight: 500;
                color: var(--red);
                display: flex; align-items: center; gap: 5px;
            }

            /* global error */
            .cif-global-err {
                padding: 12px 16px;
                border-radius: 10px;
                background: var(--red-lt);
                border: 1px solid rgba(225,29,72,.20);
                color: var(--red);
                font-size: 13px; font-weight: 500;
            }

            /* ── SUBMIT BTN ── */
            .cif-submit {
                position: relative;
                width: 100%; height: 46px;
                border-radius: 11px;
                border: none;
                background: linear-gradient(135deg, #0d9488 0%, #0f766e 100%);
                color: #fff;
                font-family: var(--font);
                font-size: 14px; font-weight: 700;
                cursor: pointer;
                display: flex; align-items: center; justify-content: center; gap: 8px;
                box-shadow: 0 4px 14px rgba(13,148,136,.35);
