"use client";
import { useState } from "react";
import RegionDropdown from "../../utils/RegionDropdown";

export default function CifCreationView() {
    const [region, setRegion]         = useState("");
    const [no_cif, setNoCif]          = useState(1);
    const [acc_type, setAccType]      = useState('');
    const [response, setCifResponse]  = useState([]);
    const [cifLoading, setCifLoading] = useState(false);
    const [error, setError]           = useState("");
    const [no_acc, setNo_acc]         = useState(1);
    const [formErrors, setFormErrors] = useState({});
    const BASE_URL = process.env.NEXT_PUBLIC_API_URL;

    const handleCifSubmit = async (e) => {
        e.preventDefault();
        setFormErrors({});
        const errors = {};
        if (!region)   errors.region   = "Please select a region";
        if (!acc_type) errors.acc_type = "Please select CIF type";
        if (!no_cif || Number(no_cif) < 1 || Number(no_cif) > 10)
            errors.no_cif = "Number of CIF must be between 1 and 10";
        if (Object.keys(errors).length > 0) { setFormErrors(errors); return; }

        setCifLoading(true);
        setError("");
        setCifResponse([]);

        try {
            const res = await fetch(`${BASE_URL}/create_cif`, {
                credentials: "include",
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ region, no_cif: parseInt(no_cif, 10), acc_type }),
            });
            if (!res.ok) {
                if (res.status === 401 || res.status === 403) {
                    setError("Session expired or unauthorized. Please log in again.");
                    window.location.reload();
                    return;
                }
                throw new Error(`API returned an error: ${res.status} ${res.statusText}`);
            }
            const data = await res.json();
            setCifResponse(data);
        } catch (err) {
            if (!err.message.includes("unauthorized"))
                setCifResponse([{ res_data: JSON.stringify({ ERROR_DESCRIPTION: err.message }) }]);
        } finally {
            setCifLoading(false);
        }
    };

    const downloadCsv = () => {
        if (!response || response.length === 0) { alert("No data to download."); return; }
        let csv = "data:text/csv;charset=utf-8,Customer Number\t,Region\t,CIF Type\n";
        response.forEach((item) => {
            try {
                const p = JSON.parse(item.res_data);
                csv += `${p.CUSTOMER_NUMBER || ""}\t,${region}\t,${acc_type}\n`;
            } catch (e) { console.error("CSV parse error:", e); }
        });
        const link = document.createElement("a");
        link.setAttribute("href", encodeURI(csv));
        link.setAttribute("download", "cif_data.csv");
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    };

    const hasResults  = response && response.length > 0;
    const cifTypeLabel = acc_type === "PCIF" ? "Personal CIF" : acc_type === "NPCIF" ? "Non-Personal CIF" : "";

    return (
        <>
        <style>{`
            @import url('https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap');

            :root {
                --ink:       #0b1120;
                --ink2:      #1e2d4a;
                --ink3:      #3d5278;
                --slate:     #64748b;
                --line:      #e2e8f4;
                --line-lt:   #f0f4fb;
                --bg:        #f5f7fc;
                --white:     #ffffff;
                --teal:      #0d9488;
                --teal-lt:   #ccfbf1;
                --teal-glow: rgba(13,148,136,.12);
                --amber:     #f59e0b;
                --amber-lt:  #fef3c7;
                --red:       #e11d48;
                --red-lt:    #fff1f2;
                --shadow:    0 2px 12px rgba(11,17,32,.07);
                --shadow-md: 0 4px 24px rgba(11,17,32,.10);
                --shadow-lg: 0 8px 40px rgba(11,17,32,.13);
                --r:         14px;
                --font:      'Sora', sans-serif;
                --mono:      'JetBrains Mono', monospace;
            }

            .cif-root {
                font-family: var(--font);
                -webkit-font-smoothing: antialiased;
                min-height: 100%;
                background: var(--bg);
                padding: 28px 28px 40px;
                display: flex;
                flex-direction: column;
                gap: 24px;
            }

            /* ── PAGE HEADER ── */
            .cif-hero {
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 16px;
            }
            .cif-hero-left {
                display: flex;
                align-items: center;
                gap: 16px;
            }
            .cif-icon-wrap {
                width: 52px; height: 52px;
                border-radius: 14px;
                background: linear-gradient(135deg, #0d9488 0%, #0f766e 100%);
                display: flex; align-items: center; justify-content: center;
                box-shadow: 0 4px 16px rgba(13,148,136,.30);
                flex-shrink: 0;
            }
            .cif-icon-svg { width: 26px; height: 26px; color: #fff; }
            .cif-title {
                font-size: 22px; font-weight: 800;
                color: var(--ink); letter-spacing: -.03em; line-height: 1;
                margin-bottom: 4px;
            }
            .cif-sub {
                font-size: 13px; font-weight: 400;
                color: var(--slate); line-height: 1;
            }

            .cif-badge {
                padding: 5px 14px;
                border-radius: 20px;
                background: var(--teal-lt);
                color: var(--teal);
                font-size: 11.5px; font-weight: 700;
                letter-spacing: .05em; text-transform: uppercase;
                border: 1px solid rgba(13,148,136,.20);
            }

            /* ── TWO-COLUMN LAYOUT ── */
            .cif-layout {
                display: grid;
                grid-template-columns: 420px 1fr;
                gap: 20px;
                align-items: start;
            }
            @media (max-width: 900px) {
                .cif-layout { grid-template-columns: 1fr; }
            }

            /* ── FORM PANEL ── */
            .cif-panel {
                background: var(--white);
                border-radius: var(--r);
                border: 1px solid var(--line);
                box-shadow: var(--shadow);
                overflow: hidden;
            }

            .cif-panel-head {
                padding: 16px 22px;
                border-bottom: 1px solid var(--line-lt);
                background: linear-gradient(135deg, #f8faff 0%, #f0f5ff 100%);
                display: flex; align-items: center; gap: 10px;
            }
            .cif-panel-num {
                width: 26px; height: 26px; border-radius: 50%;
                background: var(--ink2);
                color: #fff; font-size: 12px; font-weight: 700;
                display: flex; align-items: center; justify-content: center;
                flex-shrink: 0;
            }
            .cif-panel-label {
                font-size: 13.5px; font-weight: 700; color: var(--ink2);
                letter-spacing: -.01em;
            }

            .cif-panel-body { padding: 22px; display: flex; flex-direction: column; gap: 18px; }

            /* ── FIELD ── */
            .cif-field { display: flex; flex-direction: column; gap: 6px; }
            .cif-label {
                font-size: 12.5px; font-weight: 600;
                color: var(--ink3); letter-spacing: .01em;
