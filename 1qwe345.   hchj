"use client";

import { useState } from "react";

export default function CifCreationView() {
  const [region, setRegion] = useState("");
  const [noCif, setNoCif] = useState("");
  const [accType, setAccType] = useState("");
  const [responses, setResponses] = useState([]);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState("");
  const [formErrors, setFormErrors] = useState({});

  const BASE_URL = process.env.NEXT_PUBLIC_API_URL;

  // ================= VALIDATION =================
  const validate = () => {
    const errors = {};

    if (!region) {
      errors.region = "Please select a region";
    }

    if (!accType) {
      errors.accType = "Please select CIF type";
    }

    if (!noCif) {
      errors.noCif = "Please enter number of CIF";
    } else if (Number(noCif) < 1 || Number(noCif) > 10) {
      errors.noCif = "Value must be between 1 and 10";
    }

    return errors;
  };

  // ================= SUBMIT =================
  const handleSubmit = async (e) => {
    e.preventDefault();

    const errors = validate();
    setFormErrors(errors);

    if (Object.keys(errors).length > 0) return;

    setLoading(true);
    setError("");
    setResponses([]);

    try {
      const res = await fetch(`${BASE_URL}/create_cif`, {
        method: "POST",
        credentials: "include",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          region: region,
          no_cif: parseInt(noCif),
          acc_type: accType,
        }),
      });

      if (!res.ok) {
        if (res.status === 401 || res.status === 403) {
          setError("Session expired. Please login again.");
          return;
        }
        throw new Error(`API Error: ${res.status}`);
      }

      const data = await res.json();

      // Ensure always array
      setResponses(Array.isArray(data) ? data : [data]);
    } catch (err) {
      setError(err.message || "Something went wrong");
    } finally {
      setLoading(false);
    }
  };

  // ================= CSV DOWNLOAD =================
  const downloadCSV = () => {
    if (!responses.length) {
      alert("No data to download");
      return;
    }

    let csv =
      "data:text/csv;charset=utf-8,Customer Number,Region,CIF Type\n";

    responses.forEach((item) => {
      try {
        const parsed = JSON.parse(item.res_data);
        csv += `${parsed.CUSTOMER_NUMBER || ""},${region},${accType}\n`;
      } catch {
        csv += `ERROR,${region},${accType}\n`;
      }
    });

    const link = document.createElement("a");
    link.href = encodeURI(csv);
    link.download = "cif_data.csv";
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
  };

  // ================= UI =================
  return (
    <div style={styles.container}>
      <h2>CIF Creation</h2>

      {/* FORM */}
      <form onSubmit={handleSubmit} style={styles.card}>
        {/* REGION */}
        <div style={styles.field}>
          <label>Region</label>
          <select
            value={region}
            onChange={(e) => setRegion(e.target.value)}
          >
            <option value="">Select Region</option>
            <option value="O">O - UAT</option>
            <option value="Y">Y - UAT</option>
            <option value="Z">Z - UAT</option>
            <option value="K">K - PreProd</option>
            <option value="R1">R1 - PreProd</option>
          </select>
          {formErrors.region && (
            <p style={styles.error}>{formErrors.region}</p>
          )}
        </div>

        {/* NUMBER OF CIF */}
        <div style={styles.field}>
          <label>No. of CIF</label>
          <input
            type="number"
            value={noCif}
            onChange={(e) => setNoCif(e.target.value)}
            min="1"
            max="10"
          />
          {formErrors.noCif && (
            <p style={styles.error}>{formErrors.noCif}</p>
          )}
        </div>

        {/* CIF TYPE */}
        <div style={styles.field}>
          <label>CIF Type</label>
          <select
            value={accType}
            onChange={(e) => setAccType(e.target.value)}
          >
            <option value="">Select Type</option>
            <option value="PCIF">Personal</option>
            <option value="NPCIF">Non-Personal</option>
          </select>
          {formErrors.accType && (
            <p style={styles.error}>{formErrors.accType}</p>
          )}
        </div>

        {/* BUTTON */}
        <button type="submit" disabled={loading}>
          {loading ? "Generating..." : "Generate CIF"}
        </button>
      </form>

      {/* ERROR */}
      {error && <p style={styles.error}>{error}</p>}

      {/* RESULTS */}
      {responses.length > 0 && (
        <div style={styles.card}>
          <h3>Generated Records ({responses.length})</h3>

          <button onClick={downloadCSV}>Download CSV</button>

          {responses.map((item, index) => {
            let parsed;

            try {
              parsed = JSON.parse(item.res_data);
            } catch {
              return (
                <div key={index} style={styles.errorBox}>
                  Error: {item.res_data}
                </div>
              );
            }

            return (
              <div key={index} style={styles.result}>
                <strong>#{index + 1}</strong>

                {parsed.CUSTOMER_NUMBER ? (
                  <p>Customer Number: {parsed.CUSTOMER_NUMBER}</p>
                ) : (
                  <>
                    <p>Status: Failed</p>
                    {parsed.ERROR_CODE && (
                      <p>Error Code: {parsed.ERROR_CODE}</p>
                    )}
                  </>
                )}
              </div>
            );
          })}
        </div>
      )}
    </div>
  );
}

// ================= STYLES =================
const styles = {
  container: {
    padding: 20,
    fontFamily: "Arial",
  },
  card: {
    border: "1px solid #ddd",
    padding: 20,
    marginTop: 20,
    borderRadius: 8,
  },
  field: {
    marginBottom: 15,
    display: "flex",
    flexDirection: "column",
  },
  error: {
    color: "red",
    fontSize: 12,
  },
  result: {
    padding: 10,
    borderBottom: "1px solid #eee",
  },
  errorBox: {
    padding: 10,
    background: "#ffe6e6",
    color: "red",
    marginBottom: 10,
  },
};