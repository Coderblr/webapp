    # Check for error WITHOUT prefix — e.g. "1000 7090 00 DATE OF EXPIRY..."
    error_match2 = re.search(r"\d+\s+(\d{4})\s+\d+\s+([A-Z][A-Z\s]+)", tail)
    if error_match2:
        return {
            "status":            "error",
            "error_type":        "UNKNOWN",
            "error_code":        error_match2.group(1),
            "error_description": error_match2.group(2).strip()
        }
