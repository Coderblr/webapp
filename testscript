import streamlit as st
import os
import base64
from dotenv import load_dotenv
from openai import AzureOpenAI

load_dotenv()

# Azure OpenAI Configuration
client = AzureOpenAI(
    api_key=os.getenv("AZURE_OPENAI_API_KEY"),
    api_version=os.getenv("AZURE_OPENAI_API_VERSION"),
    azure_endpoint=os.getenv("AZURE_OPENAI_ENDPOINT")
)

DEPLOYMENT_NAME = os.getenv("AZURE_OPENAI_DEPLOYMENT")


def encode_image(uploaded_file):
    return base64.b64encode(uploaded_file.read()).decode("utf-8")


st.set_page_config(
    page_title="AI Feature File Generator",
    layout="wide"
)

st.title("AI-Powered Feature File Generator")

st.write(
    "Upload an application screenshot and generate a Gherkin feature file automatically."
)

uploaded_file = st.file_uploader(
    "Upload Screenshot",
    type=["png", "jpg", "jpeg"]
)

if uploaded_file:

    st.image(uploaded_file, caption="Uploaded Screenshot")

    if st.button("Generate Feature File"):

        with st.spinner("Analyzing Screenshot..."):

            image_base64 = encode_image(uploaded_file)

            prompt = """
You are a Senior QA Automation Engineer.

Analyze the application screenshot.

Identify:
1. Page Name
2. UI Components
3. Input Fields
4. Buttons
5. Dropdowns
6. Validation Messages
7. User Actions

Generate:

1. Functional Test Scenarios
2. Positive Scenarios
3. Negative Scenarios
4. Boundary Scenarios

Finally generate a complete Gherkin Feature File.

Rules:
- Use proper Gherkin syntax
- Create meaningful Scenario names
- Use Given When Then
- Add Scenario Outline where applicable
- Generate automation-friendly scenarios
- Do not make assumptions beyond visible UI

Output only feature file.
"""

            response = client.chat.completions.create(
                model=DEPLOYMENT_NAME,
                messages=[
                    {
                        "role": "user",
                        "content": [
                            {
                                "type": "text",
                                "text": prompt
                            },
                            {
                                "type": "image_url",
                                "image_url": {
                                    "url": f"data:image/png;base64,{image_base64}"
                                }
                            }
                        ]
                    }
                ],
                temperature=0.2,
                max_tokens=4000
            )

            feature_content = response.choices[0].message.content

            st.subheader("Generated Feature File")

            st.code(feature_content, language="gherkin")

            st.download_button(
                label="Download Feature File",
                data=feature_content,
                file_name="generated.feature",
                mime="text/plain"
            )
