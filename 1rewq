"use client";

import { useState } from "react";
import { styles } from "../../styles/AppStyles";
import RegionDropdown from "../../utils/RegionDropdown";

export default function CustomerEnquiry() {
    const [cif, setCif] = useState("");
    const [server, setServer] = useState("O");
    const [response, setResponse] = useState(null);
    const [error, setError] = useState("");
    const [loading, setLoading] = useState(false);
    const [formErrors, setFormErrors] = useState({});

    const BASE_URL = process.env.NEXT_PUBLIC_API_URL;

    const handleSubmit = async (event) => {
        event.preventDefault();

        setError("");
        setResponse(null);

        // Validation
        if (!/^\d{11}$/.test(cif)) {
            setError("CIF must be exactly 11 digits");
            return;
        }

        setLoading(true);

        try {
            const res = await fetch(`${BASE_URL}/create_cust_enq`, {
                credentials: "include",
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                },
                body: JSON.stringify({
                    cif: cif.toString(),
                    region: server.toString(),
                }),
            });

            const data = await res.json();

            console.log("API Response:", data);

            if (!res.ok) {
                setError(
                    data?.detail
                        ? typeof data.detail === "string"
                            ? data.detail
                            : JSON.stringify(data.detail)
                        : "Something went wrong"
                );
                return;
            }

            // Backend returns array
            if (Array.isArray(data) && data.length > 0) {
                setResponse(data[0]);
            } else {
                setResponse(null);
                setError("No data received");
            }

        } catch (err) {
            console.error(err);
            setError("Failed to fetch customer details");
        } finally {
            setLoading(false);
        }
    };

    return (
        <div style={styles.pageContainer}>

            {/* Header */}
            <div style={styles.pageHeader}>
                <div>
                    <h1 style={styles.pageTitle}>
                        Customer Enquiry
                    </h1>

                    <p style={styles.pageSubtitle}>
                        Fetch customer details from selected environment
                    </p>
                </div>
            </div>

            {/* Form */}
            <div style={styles.formCard}>
                <div style={styles.formGrid}>

                    {/* Region */}
                    <RegionDropdown
                        value={server}
                        onChange={setServer}
                        error={formErrors.region}
                    />

                    {/* CIF */}
                    <div style={styles.formGroup}>
                        <label style={styles.label}>
                            CIF Number
                        </label>

                        <input
                            type="text"
                            value={cif}
                            onChange={(e) => {
                                const digits = e.target.value.replace(/\D/g, "");

                                if (digits.length <= 11) {
                                    setCif(digits);
                                }
                            }}
                            style={styles.input}
                            placeholder="Enter 11-digit CIF"
                        />

                        {cif.length > 0 && cif.length < 11 && (
                            <div style={styles.fieldError}>
                                CIF must be exactly 11 digits
                            </div>
                        )}
                    </div>

                </div>

                {error && (
                    <div style={styles.errorMsg}>
                        {error}
                    </div>
                )}

                <button
                    onClick={handleSubmit}
                    style={styles.primaryButton}
                >
                    {loading ? "Fetching..." : "Fetch Customer Details"}
                </button>
            </div>

            {/* Results */}
            {response?.res_data && (
                <div style={styles.resultsCard}>

                    <div style={styles.resultsHeader}>
                        <h3 style={styles.resultsTitle}>
                            Customer Enquiry Result
                        </h3>
                    </div>

                    <div style={styles.resultsList}>
                        <div style={styles.resultItem}>

                            <div style={styles.resultContent}>

                                {/* CUSTOMER NAME */}
                                <div>
                                    <span style={styles.resultLabel}>
                                        Customer Name:
                                    </span>

                                    <span style={styles.resultValue}>
                                        {response.res_data.name || "-"}
                                    </span>
                                </div>

                                {/* CUSTOMER TYPE */}
                                <div>
                                    <span style={styles.resultLabel}>
                                        Customer Type:
                                    </span>

                                    <span style={styles.resultValue}>
                                        {response.res_data.customer_type || "-"}
                                    </span>
                                </div>

                                {/* CIF */}
                                <div>
                                    <span style={styles.resultLabel}>
                                        CIF:
                                    </span>

                                    <span style={styles.resultValue}>
                                        {response.res_data.cif || cif}
                                    </span>
                                </div>

                                {/* ADDRESS */}
                                <div>
                                    <span style={styles.resultLabel}>
                                        Address:
                                    </span>

                                    <span style={styles.resultValue}>
                                        {[
                                            response.res_data.address,
                                            response.res_data.address2,
                                            response.res_data.address3,
                                        ]
                                            .filter(Boolean)
                                            .join(", ")}
                                    </span>
                                </div>

                                {/* RRN */}
                                <div>
                                    <span style={styles.resultLabel}>
                                        RRN:
                                    </span>

                                    <span style={styles.resultValue}>
                                        {response.RRN || "-"}
                                    </span>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            )}
        </div>
    );
}