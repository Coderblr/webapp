# ── SINGLE SESSION CHECK ──
    fresh_user = session.get(User.DBUser, raw_username)

    if fresh_user.active_session_jti:
        old_entry = session.get(User.BlacklistedToken, fresh_user.active_session_jti)

        if old_entry is None:
            # Check if session has naturally expired
            session_expired = False
            if fresh_user.session_expires_at:
                expires = fresh_user.session_expires_at
                if expires.tzinfo is None:
                    expires = expires.replace(tzinfo=timezone.utc)
                if datetime.now(timezone.utc) > expires:
                    session_expired = True

            if not session_expired:
                # Session still active — BLOCK
                raise HTTPException(
                    status_code=status.HTTP_403_FORBIDDEN,
                    detail="Another session is already active for this account. Please log out from the other device first.",
                )

            # Session expired — clear and allow login
            session.execute(
                sql_update(User.DBUser)
                .where(User.DBUser.username == user.username)
                .values(active_session_jti=None, session_expires_at=None)
            )
            session.commit()
