crawler:
  type: playwright       # playwright or selenium
  headless: true
  timeout: 30000
  max_pages: 6           # max child pages to follow from home
  viewport:
    width: 1920
    height: 1080

llm:
  model: gpt-4o             # your Azure deployment name (gpt-4o, gpt-4, gpt-35-turbo, etc.)
  max_tokens: 8192

output:
  base_dir: output
  save_intermediate: true

logging:
  level: INFO
