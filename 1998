@app.post("/execute/brd")
async def execute_brd(file: UploadFile = File(...)):
    """Upload a BRD (.pdf/.docx/.txt): AI drafts a feature file in the
    framework's own conventions, then the draft enters the SAME Framework
    Intelligence pipeline as a normal feature upload (match -> normalize ->
    merge -> dry-run -> generate -> human review -> approve -> execute)."""
    data = await file.read()
    try:
        brd_text = brd_processor.extract_text(file.filename, data)
        result = brd_processor.brd_to_feature(brd_text, file.filename)
    except ValueError as e:
        raise HTTPException(400, str(e))
    except RuntimeError as e:          # Azure config/network errors, already user-facing
        raise HTTPException(502, str(e))

    feature_text = result["feature_text"]
    stem = Path(file.filename).stem
    dest = config.UPLOADS_DIR / f"{stem}.feature"
    dest.write_text(feature_text, encoding="utf-8")

    hit = indexer.lookup(result["txn"]) if result["txn"] else None
    job = executor.start_job(str(dest), ai_ctx={
        "uploaded_text": feature_text, "filename": dest.name,
        "hit": hit, "module": result["module"] or (hit or {}).get("module"),
    })
    out = job.public()
    out["generated_feature"] = feature_text
    out["brd_conversion"] = {"txn": result["txn"], "module": result["module"]}
    return out


# ═══════════ CR Pipeline — multi-transaction BRD change requests (additive) ══
class CRApproval(BaseModel):
    """approved_txns=None approves everything staged; a list approves those and
    skips the rest. edits: {txn: {feature_text, files:{rel_path: java}}}."""
    approved_txns: list[str] | None = None
    edits: dict | None = None


@app.post("/execute/cr")
async def execute_cr(file: UploadFile = File(...)):
    """Upload a BRD as a CHANGE REQUEST that may span MANY transactions.
    The BRD is parsed ONCE; every transaction number is discovered; each becomes
    an independent work item (search -> compare -> delta-only merge -> dry-run ->
    generate -> quarantine-compile). One failed transaction never stops the
    queue. All staged changes pause at ONE consolidated review; approval then
    archives, commits, compiles, and executes each transaction sequentially,
    ending in a consolidated CR report."""
    data = await file.read()
    try:
        brd_text = brd_processor.extract_text(file.filename, data)
    except ValueError as e:
        raise HTTPException(400, str(e))
    if len(brd_text.strip()) < 40:
        raise HTTPException(400, "The BRD appears to be empty or unreadable after text extraction.")
    run = cr_pipeline.start_cr(file.filename, brd_text)
    return run.public()


