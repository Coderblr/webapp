package pages;

import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;

public class SBIBranchChannelPage extends BasePage {

    private static final String TXN    = "TXN-400";
    private static final String SCREEN = "SBI Branch Channel";

    public SBIBranchChannelPage(WebDriver driver) { super(driver); }

    @Override protected String transaction() { return TXN; }
    @Override protected String screen()      { return SCREEN; }

    public WebElement username()  { return find("login-username"); }
    public WebElement password()  { return find("password"); }
    public WebElement appSearch() { return find("appSearch"); }

    public void enterUsername(String v) { type("login-username", v); }
    public void enterPassword(String v) { type("password", v); }
    public void searchApp(String v)     { type("appSearch", v); }
}







