    // Opens the NBC URL from config.properties in a new tab automatically, then shows
    // an impossible-to-miss reminder that the bookmarklet still has to be clicked ON
    // that tab — browsers don't allow a page to inject scripts into another site's
    // tab, so this one manual click can't be skipped, only made harder to forget.
    function openTargetSiteAndPrompt() {
        const hint = document.getElementById('live-rec-hint');
        fetch(`${API_BASE}/api/recorder/target-url`)
            .then(res => res.json())
            .then(data => {
