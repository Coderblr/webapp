@app.post("/api/generate")
def generate_and_update(input_data: GenerateInput):
    gen_agent = JavaGeneratorAgent()
    
    # 1. Update locators/pages first
    for loc in input_data.locators:
        gen_agent.append_locator_to_page(loc.page_name, loc.element_name, loc.selector_type, loc.selector_value)

    # 2. Route each scenario based on whether the BRD tied it to an EXISTING
    # transaction number. If so, append its steps directly into that transaction's
    # real scenario (in its actual .feature file) so the full flow reflects the
    # change. Otherwise, fall back to the old generic Sample.feature path.
    transaction_updates = []
    for sc in input_data.scenarios:
        txn_number = sc.get("transaction_number")
        if txn_number:
            result = gen_agent.append_requirement_to_transaction(
                str(txn_number), sc["steps"], requirement_summary=sc.get("scenario", "")
            )
            result["transaction_number"] = txn_number
            result["scenario"] = sc.get("scenario", "")
            transaction_updates.append(result)
            if result["appended"]:
                continue  # steps placed directly in the transaction's scenario — done
            # No existing scenario found for this transaction number — fall through
            # to the generic path below so the requirement isn't silently dropped.

        for step in sc["steps"]:
            gen_agent.append_step_definition(step["text"], step["page"], step["action"])
            
    # Save framework version in history
    db = SessionLocal()
    try:
        current_version_num = db.query(FrameworkVersionModel).count() + 1
        
        # Save modification summary
        modified = {
            "scenarios": [s["scenario"] for s in input_data.scenarios],
            "locators": [{"page": l.page_name, "element": l.element_name} for l in input_data.locators],
            "transaction_updates": transaction_updates,
        }
        
        version_entry = FrameworkVersionModel(
            version_num=current_version_num,
            commit_msg=f"Auto-generated code for {len(input_data.scenarios)} scenarios",
            modified_files=json.dumps(modified),
            compiled=False
        )
        db.add(version_entry)
        db.commit()
    finally:
        db.close()

    applied_to_txns = [u for u in transaction_updates if u["appended"]]
    msg = f"Appended {len(input_data.scenarios)} scenarios and {len(input_data.locators)} locators to framework."
    if applied_to_txns:
        txn_list = ", ".join(u["transaction_number"] for u in applied_to_txns)
        msg += f" {len(applied_to_txns)} scenario(s) were appended directly into existing transaction(s): {txn_list}."

    return {
        "status": "SUCCESS",
        "message": msg,
        "transaction_updates": transaction_updates,
    }

