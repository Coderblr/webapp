@app.get("/api/locators")
def locator_repo(q: str = "", db=Depends(db_dep), user=Depends(current_user)):
    query = db.query(Element)
    if q:
        query = query.filter(Element.element_key.contains(q))
    out = []
    for e in query.limit(300):
        out.append({"element_id": e.id, "key": e.element_key,
                    "transaction": e.transaction_number, "screen": e.screen_name,
                    "tag": e.tag_name,
                    "locators": [{"id": l.id, "strategy": l.strategy,
                                  "value": l.value, "primary": l.is_primary,
                                  "confidence": l.confidence,
                                  "uniqueness": l.uniqueness,
                                  "reliability": l.reliability,
                                  "version": l.version,
                                  "previous": l.previous_value,
                                  "source": l.source,
                                  "updated": str(l.last_updated)}
                                 for l in e.locators]})
    return out


