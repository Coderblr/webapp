def import_existing_framework():
    """
    One-touch import: reads the existing java-framework (Page Objects, Step
    Definitions, Feature files) straight off disk and loads it into the AI's
    knowledge graph. After this, the AI treats everything found as existing
    framework knowledge — it reuses these locators/steps instead of
    regenerating or duplicating them.
    """
