"""
Locator Intelligence — Level 6: Self-Learning tied to REAL execution outcomes.

Everything built before this learns from RECORDING (a human clicked through a
screen) or from CAPTURE (the page was inspected). This is a higher trust
tier: a locator that was actually exercised in a scenario that PASSED on the
real application is proven correct in a way neither of those can claim.

No new Java instrumentation is needed for this — it reuses the knowledge
graph's already-built, already-tested step -> step-def -> page-method ->
locator tracing (static analysis of the real, freshly-compiled source) and
correlates it with the per-step pass/fail status Cucumber's own JSON report
already gives us (already parsed by executor._parse_report). A locator is
"proven" if the step that exercises it passed; "suspect" if a step touching
it failed with a locator-shaped exception.
"""
import json
import time

from . import config


def _repo_file():
    return config.DATA_DIR / "locator_learning.json"


def load() -> dict:
    f = _repo_file()
    return json.loads(f.read_text()) if f.exists() else {}


def _save(data: dict):
    _repo_file().write_text(json.dumps(data, indent=1))


def record_step_result(step_text: str, keyword: str | None, status: str) -> list[str]:
    """Trace one executed step to its real locators (via the knowledge graph)
    and update their success/failure counters based on this run's outcome.
    Returns the locator names updated (empty if the step couldn't be traced —
    e.g. it has no UI-touching implementation, nothing to learn)."""
    try:
        from . import knowledge_graph
        trace = knowledge_graph.trace_step(step_text, keyword)
    except Exception:  # noqa: BLE001 — learning is best-effort, never blocks a run
        return []
    if not trace:
        return []

    locators = set()
    for call in trace.get("calls_page_methods", []):
        locators.update(call.get("locators_used", []))
    if not locators:
        return []

    data = load()
    for loc in locators:
        entry = data.setdefault(loc, {"success_count": 0, "failure_count": 0,
                                      "page_classes": [], "last_status": None, "last_seen": None})
        if status == "passed":
            entry["success_count"] += 1
        elif status == "failed":
            entry["failure_count"] += 1
        pc = trace["calls_page_methods"][0]["page_class"] if trace["calls_page_methods"] else None
        if pc and pc not in entry["page_classes"]:
            entry["page_classes"].append(pc)
        entry["last_status"] = status
        entry["last_seen"] = time.strftime("%Y-%m-%d %H:%M:%S")
    _save(data)
    return sorted(locators)


def learn_from_report(step_results: list[dict], log=lambda m: None) -> dict:
    """step_results: [{"text": ..., "keyword": ..., "status": "passed"|"failed"|...}]
    Called once after a job finishes executing. Returns a small summary for
    the console/report."""
    learned, updated_locators = 0, set()
    for st in step_results:
        if st.get("status") not in ("passed", "failed"):
            continue
        touched = record_step_result(st.get("text", ""), st.get("keyword"), st["status"])
        if touched:
            learned += 1
            updated_locators.update(touched)
    if updated_locators:
        log(f">>> Self-learning: updated confidence for {len(updated_locators)} locator(s) "
           f"from {learned} executed step(s) this run.")
    return {"steps_learned_from": learned, "locators_updated": sorted(updated_locators)}


def proven_locators_for_prompt(cap: int = 30) -> str:
    """Locators PROVEN by real passing executions — the highest-trust source,
    ranked above the recorder repository and framework catalogs, formatted for
    injection into the AI generation prompt."""
    data = load()
    proven = [(name, e) for name, e in data.items()
             if e["success_count"] > 0 and e["success_count"] >= e["failure_count"]]
    proven.sort(key=lambda t: t[1]["success_count"], reverse=True)
    lines = [f'{name}   [{e["success_count"]} real pass(es), {e["failure_count"]} fail(s), '
            f'class: {e["page_classes"][0] if e["page_classes"] else "?"}]'
            for name, e in proven[:cap]]
    return "\n".join(lines)


def suspect_locators(min_failures: int = 2) -> list[dict]:
    """Locators that have failed more than they've succeeded in REAL runs —
    candidates for re-discovery (feeds Step 14 self-healing's diagnosis)."""
    data = load()
    out = [{"locator": name, **e} for name, e in data.items()
          if e["failure_count"] >= min_failures and e["failure_count"] >= e["success_count"]]
    return sorted(out, key=lambda e: e["failure_count"], reverse=True)
