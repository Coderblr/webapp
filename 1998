"""
Deterministic Java Merge Engine.

Every generator prompt already instructs the AI to "reproduce the complete
file, preserving everything, adding only what's new" — but that is a PROMPT
instruction, not a mechanical guarantee. If the AI's reproduction of an
existing method drifts even slightly while copying it (a common LLM failure
mode), that drift silently reaches the framework, because today the AI's
entire returned file is trusted and written verbatim.

This module closes that gap the same way merge_engine.py already closes it
for feature files: start from the REAL EXISTING FILE, byte-for-byte, and
apply ONLY the methods/fields that are genuinely new or meaningfully
different — never trust the AI's reproduction of anything it wasn't actually
asked to change.

  - A method in the AI's response with a name NOT in the old file -> APPENDED
    before the class's closing brace (Step 6/7/8: "insert at the correct
    logical position... append to existing page object").
  - A method with a name that EXISTS in the old file:
      - if the bodies are identical once whitespace-normalized -> untouched,
        the OLD text is kept byte-for-byte (protects against the AI silently
        reformatting/corrupting something it wasn't asked to touch).
      - if genuinely different -> replaced in place (this is the legitimate
        "modify an existing method" case) and reported for review visibility.
  - A field/locator declaration not present in the old file -> appended once,
    right after the class opens. An EXISTING field's value is never silently
    changed by this merge (a locator a human hand-tuned is never overwritten
    by an LLM's reproduction of it) — only genuinely new fields are added.

Side benefit: because untouched methods are guaranteed byte-identical to the
original, the review screen's line-diff highlighting becomes cleaner too —
no spurious "removed old line / added new line" noise from incidental AI
reformatting of code nobody asked it to change.
"""
import re

from . import knowledge_graph  # reuse the proven brace-matcher, don't duplicate it

FIELD_RE = re.compile(
    r'^([ \t]*(?:private|protected|public)?\s*(?:static\s+)?(?:final\s+)?'
    r'(?:By|WebElement|String|int|boolean|List<\w+>)\s+(\w+)\s*=.*?;)\s*$', re.M)


def _normalize(text: str) -> str:
    return re.sub(r"\s+", " ", text).strip()


def _method_spans(java_text: str) -> dict[str, dict]:
    """Every method's full source span (including any directly-preceding
    @Annotation line(s)) keyed by method name."""
    out = {}
    for m in knowledge_graph.METHOD_START_RE.finditer(java_text):
        name = m.group(1)
        sig_start = m.start()
        _, brace_close = knowledge_graph._extract_body(java_text, m.end() - 1)

        start = sig_start
        preceding = java_text[:sig_start]
        lines = preceding.splitlines(keepends=True)
        i, consumed = len(lines) - 1, 0
        while i >= 0 and lines[i].strip().startswith("@"):
            consumed += len(lines[i])
            i -= 1
        if consumed:
            start = sig_start - consumed

        out[name] = {"start": start, "end": brace_close, "text": java_text[start:brace_close]}
    return out


def extract_fields(java_text: str) -> dict[str, str]:
    return {m.group(2): m.group(1).strip() for m in FIELD_RE.finditer(java_text)}


def merge_java_file(old_text: str, new_text: str) -> dict:
    """
    Returns:
      {"merged_text": str, "added_methods": [names], "replaced_methods": [names],
       "unchanged_methods": [names], "added_fields": [names]}
    """
    if not old_text or not old_text.strip():
        # brand-new file — nothing to merge against, nothing to protect
        new_methods = list(_method_spans(new_text).keys())
        new_fields = list(extract_fields(new_text).keys())
        return {"merged_text": new_text, "added_methods": new_methods,
               "replaced_methods": [], "unchanged_methods": [], "added_fields": new_fields}

    old_methods = _method_spans(old_text)
    new_methods = _method_spans(new_text)
    old_fields = extract_fields(old_text)
    new_fields = extract_fields(new_text)

    merged = old_text
    added, replaced, unchanged = [], [], []
    replace_ops = []
    append_blocks = []

    for name, nm in new_methods.items():
        if name in old_methods:
            om = old_methods[name]
            if _normalize(om["text"]) == _normalize(nm["text"]):
                unchanged.append(name)
            else:
                replace_ops.append((om["start"], om["end"], nm["text"].strip()))
                replaced.append(name)
        else:
            append_blocks.append(nm["text"].strip())
            added.append(name)

    # apply replacements back-to-front so earlier byte offsets stay valid
    for start, end, block in sorted(replace_ops, key=lambda t: -t[0]):
        merged = merged[:start] + block + merged[end:]

    if append_blocks:
        insert_at = merged.rstrip().rfind("}")
        if insert_at == -1:
            insert_at = len(merged)
        block = "\n\n    " + "\n\n    ".join(append_blocks) + "\n"
        merged = merged[:insert_at] + block + merged[insert_at:]

    added_fields = []
    for name, decl in new_fields.items():
        if name not in old_fields:
            cls_open = merged.find("{")
            if cls_open != -1:
                merged = merged[:cls_open + 1] + "\n    " + decl + merged[cls_open + 1:]
                added_fields.append(name)

    return {"merged_text": merged, "added_methods": added, "replaced_methods": replaced,
           "unchanged_methods": unchanged, "added_fields": added_fields}
