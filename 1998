"""Module 17 — AI Automation Generator (+ Module 16 knowledge packaging).

Builds a Transaction Knowledge Package from everything the recorder captured
and asks Azure OpenAI to generate: Feature File (positive AND negative
scenarios derived from captured validation rules), Step Definitions, Page
Object (reading locators from the central repository), Runner, and test data.
Artifacts are stored as *proposals* for human review before being written into
the existing Java framework by the Framework Update Engine.
"""
import json
import re
from pathlib import Path

from ..ai import azure_client
from ..models import (Element, GeneratedArtifact, KnowledgePackage,
                      LearningEvent, NetworkCall, RecordedAction, Recording,
                      SessionLocal, TestDataField, ValidationMessage)
from . import framework_update


def build_knowledge_package(db, transaction: str) -> dict:
    """Module 16 — assemble the reusable knowledge package."""
    actions = (db.query(RecordedAction).join(Recording)
               .filter(Recording.transaction_number == transaction)
               .order_by(RecordedAction.sequence).all())
    fields = db.query(TestDataField).filter_by(transaction_number=transaction).all()
    msgs = db.query(ValidationMessage).filter_by(transaction_number=transaction).all()
    apis = db.query(NetworkCall).filter_by(transaction_number=transaction).all()
    elements = db.query(Element).filter_by(transaction_number=transaction).all()

    workflow = []
    last_screen = None
    for a in actions:
        if a.screen_name != last_screen:
            workflow.append(a.screen_name)
            last_screen = a.screen_name

    pkg = {
        "transaction_number": transaction,
        "workflow": workflow,                            # Module 11
        "actions": [{"seq": a.sequence, "type": a.action_type,
                     "screen": a.screen_name, "description": a.description,
                     "value": a.value_masked} for a in actions],
        "fields": [{"name": f.field_name, "type": f.input_type,
                    "mandatory": f.mandatory, "max_length": f.max_length,
                    "pattern": f.pattern, "sample": f.value_masked,
                    "sensitive": f.sensitive,
                    "options": f.dropdown_options} for f in fields],
        "messages": [{"kind": m.kind, "text": m.text, "code": m.error_code}
                     for m in msgs],
        "apis": [{"method": c.method, "url": c.url, "status": c.status_code,
                  "time_ms": c.response_time_ms} for c in apis][:30],
        "elements": [{"key": e.element_key, "screen": e.screen_name,
                      "tag": e.tag_name,
                      "primary_locator": next((l.value for l in e.locators
                                               if l.is_primary), None)}
                     for e in elements][:200],
    }
    kp = db.query(KnowledgePackage).filter_by(transaction_number=transaction).first()
    if kp:
        kp.business_workflow = workflow
        kp.version += 1
    else:
        db.add(KnowledgePackage(transaction_number=transaction,
                                business_workflow=workflow, ai_confidence=0.8))
    db.commit()
    return pkg


