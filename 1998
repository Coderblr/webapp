"""Reusable Azure OpenAI client.

Creates one `AzureOpenAI` client for the whole application (lazy
singleton) and exposes two helpers:

- `get_chat_completion`    — returns the full reply at once
- `stream_chat_completion` — yields the reply incrementally (for SSE)

All Azure-specific error translation happens here so the rest of the
codebase never has to import the OpenAI SDK.
"""

import logging
from collections.abc import Iterator
from contextlib import contextmanager

from openai import (
    APIConnectionError,
    APIStatusError,
    AuthenticationError,
    AzureOpenAI,
    BadRequestError,
    NotFoundError,
    RateLimitError,
)

from .config import settings
from .utils import truncate_history

logger = logging.getLogger(__name__)

# System prompt that specializes the assistant in software development.
SYSTEM_PROMPT = (
    "You are an expert AI coding assistant. You specialize in software "
    "development across languages and tools, including Python, Java, "
    "JavaScript, TypeScript, C#, C++, SQL, HTML, CSS, React, Angular, Vue, "
    "Next.js, Node.js, FastAPI, Flask, Django, Spring Boot, Selenium, "
    "Playwright, Cypress, Cucumber, REST APIs, GraphQL, Docker, Kubernetes, "
    "Azure, Git, GitHub, Jenkins, CI/CD, Linux, Windows, Bash, PowerShell, "
    "Regex, JSON, XML, algorithms, data structures, system design, "
    "debugging, code reviews, and error analysis.\n\n"
    "You help users by explaining code, generating code, debugging stack "
    "traces, suggesting improvements, explaining errors, optimizing code, "
    "and answering programming questions.\n\n"
    "Formatting rules:\n"
    "- Use Markdown in every answer.\n"
    "- Put code inside fenced code blocks with the correct language tag.\n"
    "- Use headings, lists, and tables when they make an answer clearer.\n"
    "- Be accurate and concise; prefer working, runnable examples."
)


class AzureClientError(Exception):
    """Raised when a chat completion cannot be produced.

    Carries an HTTP status code and a human-readable message so the API
    layer can return a meaningful error response.
    """

    def __init__(self, status_code: int, message: str) -> None:
        super().__init__(message)
        self.status_code = status_code
        self.message = message


_client: AzureOpenAI | None = None


def get_client() -> AzureOpenAI:
    """Return the shared AzureOpenAI client, creating it on first use."""
    global _client

    if _client is None:
        missing = settings.validate()
        if missing:
            raise AzureClientError(
                status_code=503,
                message=(
                    "Azure OpenAI is not configured. Missing environment "
                    f"variables: {', '.join(missing)}. Copy .env.example to "
                    ".env and fill in your credentials."
                ),
            )
        _client = AzureOpenAI(
            azure_endpoint=settings.azure_openai_endpoint,
            api_key=settings.azure_openai_api_key,
            api_version=settings.azure_openai_api_version,
        )
        logger.info("Azure OpenAI client initialized.")
    return _client


@contextmanager
def _translate_errors():
    """Map OpenAI SDK exceptions to `AzureClientError` with clear messages."""
    try:
        yield
    except AuthenticationError as exc:
        logger.error("Azure OpenAI authentication failed: %s", exc)
        raise AzureClientError(
            401, "Authentication with Azure OpenAI failed. Check AZURE_OPENAI_API_KEY."
        ) from exc
    except NotFoundError as exc:
        logger.error("Azure OpenAI deployment not found: %s", exc)
        raise AzureClientError(
            404,
            "Deployment not found. Check AZURE_OPENAI_DEPLOYMENT and "
            "AZURE_OPENAI_ENDPOINT.",
        ) from exc
    except RateLimitError as exc:
        logger.warning("Azure OpenAI rate limit hit: %s", exc)
        raise AzureClientError(
            429, "Azure OpenAI rate limit exceeded. Please wait a moment and retry."
        ) from exc
    except BadRequestError as exc:
        logger.error("Azure OpenAI rejected the request: %s", exc)
        raise AzureClientError(
            400, "Azure OpenAI rejected the request. The message may be too long."
        ) from exc
    except APIConnectionError as exc:
        logger.error("Cannot reach Azure OpenAI: %s", exc)
        raise AzureClientError(
            502,
            "Could not connect to Azure OpenAI. Check AZURE_OPENAI_ENDPOINT and "
            "your network connection.",
        ) from exc
    except APIStatusError as exc:
        logger.error("Azure OpenAI returned an error: %s", exc)
        raise AzureClientError(
            502, f"Azure OpenAI returned an unexpected error (HTTP {exc.status_code})."
        ) from exc


def _build_messages(message: str, history: list[dict[str, str]] | None) -> list[dict[str, str]]:
    """Assemble the full message list sent to the model."""
    messages: list[dict[str, str]] = [{"role": "system", "content": SYSTEM_PROMPT}]
    messages.extend(truncate_history(history or []))
    messages.append({"role": "user", "content": message})
    return messages


def get_chat_completion(message: str, history: list[dict[str, str]] | None = None) -> str:
    """Send a user message (plus optional history) and return the full reply.

    Raises:
        AzureClientError: with an appropriate HTTP status code and a
            meaningful message when the request fails.
    """
    client = get_client()

    with _translate_errors():
        response = client.chat.completions.create(
            model=settings.azure_openai_deployment,
            messages=_build_messages(message, history),
            temperature=0.3,
            max_tokens=2000,
        )

    choice = response.choices[0] if response.choices else None
    content = choice.message.content if choice and choice.message else None
    if not content:
        raise AzureClientError(502, "Azure OpenAI returned an empty response.")
    return content


def stream_chat_completion(
    message: str, history: list[dict[str, str]] | None = None
) -> Iterator[str]:
    """Yield the assistant's reply incrementally, one text delta at a time.

    Raises:
        AzureClientError: on any failure, before or during the stream.
    """
    client = get_client()

    with _translate_errors():
        stream = client.chat.completions.create(
            model=settings.azure_openai_deployment,
            messages=_build_messages(message, history),
            temperature=0.3,
            max_tokens=2000,
            stream=True,
        )

    produced_any = False
    with _translate_errors():
        for chunk in stream:
            # Azure can emit chunks with no choices (e.g. content-filter
            # metadata); skip those safely.
            if not chunk.choices:
                continue
            delta = chunk.choices[0].delta
            if delta and delta.content:
                produced_any = True
                yield delta.content

    if not produced_any:
        raise AzureClientError(502, "Azure OpenAI returned an empty response.")
