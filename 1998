# ═══════════════ Phase 7 — Intelligent Feature Comparison (additive, new) ══
class CompareRequest(BaseModel):
    uploaded_text: str
    existing_text: str | None = None   # if omitted, auto-matched via Phase 6
    filename: str | None = None
    module_hint: str | None = None
    txn_hint: str | None = None


@app.post("/framework/compare")
def framework_compare(body: CompareRequest):
    """Structured diff: unchanged / new / deleted / modified scenarios, with
    step-level, Examples-level, and data-table-level detail for each modified
    scenario. If existing_text is omitted, the best match is found
    automatically (Phase 6). Not yet wired into /execute/upload."""
    try:
        if body.existing_text is not None:
            return feature_comparator.compare_features(body.existing_text, body.uploaded_text)
        return feature_comparator.compare_with_best_match(
            body.uploaded_text, body.filename, body.module_hint, body.txn_hint)
    except ValueError as e:
        raise HTTPException(400, str(e))


