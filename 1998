# Settings that must never be returned to the UI in clear text
SECRET_SETTINGS = ("prelogin_password", "prelogin_new_password")


# Locator values that shipped as wrong guesses in earlier builds; if a saved
# settings.json still contains them, they are replaced with the corrected
# default so users don't have to hunt down stale values by hand.
STALE_DEFAULTS = {
    "login_user_locator": ("id=UIPage_009750_userId",),
    "login_password_locator": ("id=UIPage_009750_password",),
    "login_submit_locator": ("id=UIPage_009750_login",),
}


def load_settings() -> dict:
    settings = dict(DEFAULT_SETTINGS)
    if SETTINGS_FILE.exists():
        try:
            settings.update(json.loads(SETTINGS_FILE.read_text()))
        except json.JSONDecodeError:
            pass
    migrated = False
    for key, stale_values in STALE_DEFAULTS.items():
        if settings.get(key) in stale_values:
            settings[key] = DEFAULT_SETTINGS[key]
            migrated = True
    if migrated and SETTINGS_FILE.exists():
        try:
            SETTINGS_FILE.write_text(json.dumps(settings, indent=2))
        except OSError:
            pass
    return settings


def save_settings(patch: dict) -> dict:
    settings = load_settings()
    settings.update({k: v for k, v in patch.items() if k in DEFAULT_SETTINGS})
    SETTINGS_FILE.write_text(json.dumps(settings, indent=2))
    return settings


def public_ai_config() -> dict:
    """Azure OpenAI config safe to show in the UI — key always masked."""
    return {
        "endpoint": AZURE_OPENAI_ENDPOINT,
        "deployment": AZURE_OPENAI_DEPLOYMENT,
        "api_version": AZURE_OPENAI_API_VERSION,
        "api_key_masked": mask_secret(AZURE_OPENAI_API_KEY),
        "configured": bool(AZURE_OPENAI_ENDPOINT and AZURE_OPENAI_API_KEY
                           and AZURE_OPENAI_DEPLOYMENT),
    }
