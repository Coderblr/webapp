class HealBody(BaseModel):
    key: str                      # "TXN/Screen/elementName" from the Java client
    failed_locator: str
    dom: str = ""


@app.get("/api/locator/resolve")
def resolve_locator(key: str):
    """Flat best-locator lookup for the Java framework's LocatorRepository.by().
    Returns the primary (or highest-confidence) locator for an element key."""
    name = [p for p in key.split("/") if p][-1] if key else ""
    db = models.SessionLocal()
    try:
        el = (db.query(Element).filter(Element.element_key.ilike(f"%{name}%"))
                .order_by(Element.id.desc()).first())
        if not el:
            return {"found": False}
        locs = sorted(el.locators, key=lambda l: (not l.is_primary, -l.confidence))
        if not locs:
            return {"found": False}
        best = locs[0]
        st = best.strategy if best.strategy in ("id", "name", "css") else "xpath"
        return {"found": True, "strategy": st, "value": best.value}
    finally:
        db.close()


@app.post("/api/heal")
async def heal_from_framework(body: HealBody):
    """Runtime self-healing hook called by core.LocatorRepository in the Java
    framework when an element is not found: resolves the element by key and
    runs the healing cascade against the DOM sent from the live browser."""
    parts = [p for p in body.key.split("/") if p]
    name = parts[-1] if parts else body.key
    db = models.SessionLocal()
    try:
        el = (db.query(Element)
                .filter(Element.element_key.ilike(f"%{name}%"))
                .order_by(Element.id.desc()).first())
        eid = el.id if el else None
    finally:
        db.close()
    if eid is None:
        return {"healed": False, "reason": "element not in repository"}
    result = await self_healing.heal(
        eid, body.failed_locator, body.dom,
        validate=lambda _v: True)  # final check happens in the Java browser
    if result.get("healed"):
        return {"healed": True, "type": result.get("strategy_type", "xpath"),
                "value": result.get("locator")}
    return {"healed": False, "reason": result.get("reason", "no candidate")}


