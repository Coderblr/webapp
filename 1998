@app.get("/cr/{run_id}/pending")
def cr_pending(run_id: str):
    """Consolidated review payload: every staged transaction's merged feature +
    generated java, editable before approval."""
    run = cr_pipeline.CR_RUNS.get(run_id)
    if not run:
        raise HTTPException(404, "unknown CR run")
    staged = [{
        "txn": i.txn, "module": (i.hit or {}).get("module"),
        "feature_path": (i.hit or {}).get("feature"),
        "feature_text": i.merged_feature, "files": i.gen_files,
        "scenarios_added": i.scenarios_added, "scenarios_replaced": i.scenarios_replaced,
        "undefined_steps": i.undefined_steps, "delta_notes": i.delta_notes,
        "warnings": i.warnings,
    } for i in run.items if i.status == "staged"]
    action_items = [{"txn": i.txn, "status": i.status, "action": i.action_required}
                    for i in run.items if i.action_required]
    return {"cr_run_id": run.id, "status": run.status, "cr_number": run.cr_number,
            "staged": staged, "action_items": action_items}


