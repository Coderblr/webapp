/* AI Automation Control Center — 100% plain JavaScript (no JSX/TS/React).
   A tiny DOM builder h() renders everything; each page is a function that
   returns a DOM element and manages its own refresh. */
(function () {
  "use strict";
  var api = window.API;
  var role = "Admin";  // auth removed — single-user local mode
  var root = document.getElementById("root");

  /* ---------- tiny DOM builder ---------- */
  function h(tag, props) {
    var el = document.createElement(tag);
    props = props || {};
    Object.keys(props).forEach(function (k) {
      var v = props[k];
      if (v == null) return;
      if (k === "class") el.className = v;
      else if (k === "style") Object.assign(el.style, v);
      else if (k.indexOf("on") === 0) el.addEventListener(k.slice(2), v);
      else if (k === "value") el.value = v;
      else if (k === "checked" || k === "disabled" || k === "selected") el[k] = v;
      else el.setAttribute(k, v);
    });
    for (var i = 2; i < arguments.length; i++) append(el, arguments[i]);
    return el;
  }
  function append(el, c) {
    if (c == null || c === false) return;
    if (Array.isArray(c)) return c.forEach(function (x) { append(el, x); });
    el.appendChild(c instanceof Node ? c : document.createTextNode(String(c)));
  }
  function clear(el) { while (el.firstChild) el.removeChild(el.firstChild); }
  function badge(kind, text) { return h("span", { class: "badge " + kind }, text); }
  function statusBadge(s) {
    var ok = ["passed", "written", "success", "approved"].indexOf(s) >= 0;
    var bad = ["failed", "rejected", "failure", "error"].indexOf(s) >= 0;
    var warn = ["running", "recording"].indexOf(s) >= 0;
    return badge(ok ? "ok" : bad ? "bad" : warn ? "warn" : "info", s);
  }
  function toast(msg) {
    var t = h("div", { class: "toast" }, msg);
    document.body.appendChild(t);
    setTimeout(function () { t.remove(); }, 2600);
  }
  function table(headers, rows) {
    return h("table", null,
      h("thead", null, h("tr", null, headers.map(function (x) { return h("th", null, x); }))),
      h("tbody", null, rows));
  }
  function muted(text) { return h("p", { class: "muted" }, text); }

  /* ================= 2. Dashboard ================= */
