<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Txn Automation Console</title>
<style>
  :root{
    --bg:#eef2f9; --card:#ffffff; --ink:#101a2e; --muted:#64748b; --line:#e2e8f2;
    --a1:#4f46e5; --a2:#0ea5e9; --grad:linear-gradient(135deg,#4f46e5 0%,#0ea5e9 100%);
    --pass:#16a34a; --pass-soft:#e7f6ec; --fail:#dc2626; --fail-soft:#fdecec;
    --warn:#b45309; --warn-soft:#fef3d8;
    --console:#0b1220; --console-ink:#cfe0f4;
    --mono:"Consolas","Cascadia Mono",monospace; --sans:"Segoe UI",system-ui,Arial,sans-serif;
    --shadow:0 10px 30px rgba(16,26,46,.08), 0 2px 6px rgba(16,26,46,.05);
  }
  *{box-sizing:border-box}
  body{margin:0;background:
       radial-gradient(1200px 400px at 80% -100px, rgba(79,70,229,.10), transparent 60%),
       radial-gradient(900px 380px at 10% -80px, rgba(14,165,233,.10), transparent 60%),
       var(--bg);
       color:var(--ink);font-family:var(--sans);min-height:100vh;font-size:15px}
  /* ── header ── */
  header{display:flex;align-items:center;gap:16px;padding:16px 28px}
  .logo{width:38px;height:38px;border-radius:11px;background:var(--grad);display:grid;place-items:center;
        color:#fff;font-weight:800;font-size:16px;box-shadow:0 6px 16px rgba(79,70,229,.35)}
  header h1{font-size:18px;margin:0;letter-spacing:.2px}
  header .sub{font-size:12px;color:var(--muted)}
  .spacer{flex:1}
  .btn{font:inherit;border:1px solid var(--line);background:#fff;color:var(--ink);
       padding:9px 16px;border-radius:10px;cursor:pointer;transition:.15s;box-shadow:0 1px 2px rgba(16,26,46,.05)}
  .btn:hover{border-color:var(--a1);transform:translateY(-1px)}
  .btn:focus-visible{outline:2px solid var(--a1);outline-offset:2px}
  .btn.primary{background:var(--grad);border:0;color:#fff;font-weight:700;letter-spacing:.3px;
               box-shadow:0 8px 20px rgba(79,70,229,.35)}
  .btn.primary:disabled{opacity:.55;cursor:not-allowed;transform:none}
  .btn.stop{background:linear-gradient(135deg,#ef4444,#b91c1c);border:0;color:#fff;font-weight:700;
            box-shadow:0 8px 20px rgba(220,38,38,.30);display:none}
  /* ── layout per sketch: [new execution | execution] then reports full width ── */
  main{display:grid;grid-template-columns:400px 1fr;gap:20px;padding:6px 28px 28px;max-width:1600px;margin:0 auto}
  #reportcard{grid-column:1 / -1}
  @media(max-width:1020px){main{grid-template-columns:1fr}}
  .card{background:var(--card);border:1px solid var(--line);border-radius:18px;padding:22px;box-shadow:var(--shadow)}
  .card h2{display:flex;align-items:center;gap:8px;font-size:13.5px;text-transform:uppercase;
           letter-spacing:1.2px;color:var(--muted);margin:0 0 16px;font-weight:700}
  .card h2::before{content:"";width:8px;height:8px;border-radius:3px;background:var(--grad)}
  /* tabs — Upload first & default */
  .tabs{display:flex;background:#f1f4fa;border-radius:12px;padding:4px;margin-bottom:18px}
  .tabs button{flex:1;font:inherit;font-weight:600;padding:10px;border:0;border-radius:9px;
               background:transparent;color:var(--muted);cursor:pointer;transition:.15s}
  .tabs button.active{background:#fff;color:var(--a1);box-shadow:0 2px 8px rgba(16,26,46,.10)}
  label{display:block;font-size:13px;color:var(--muted);margin:12px 0 6px;font-weight:600}
  input[type=file]{width:100%;font:inherit;padding:10px;border:1.5px dashed var(--line);border-radius:10px;background:#fafbfe}
  .check{display:flex;align-items:center;gap:8px;margin-top:12px;font-size:13px;color:var(--muted)}
  .hintbox{font-size:13px;color:var(--muted);background:#f6f8fd;border:1px solid var(--line);
           border-radius:10px;padding:10px 12px;margin-top:12px;line-height:1.5}
  .mono{font-family:var(--mono)}
  /* ── Txn combo: fixed label + searchable scrollable dropdown ── */
  .combo{position:relative}
  .combo .row{display:flex;border:1.5px solid var(--line);border-radius:10px;overflow:hidden;background:#fff;transition:.15s}
  .combo .row:focus-within{border-color:var(--a1);box-shadow:0 0 0 3px rgba(79,70,229,.12)}
  .chip{background:var(--grad);color:#fff;font-weight:700;padding:11px 16px;font-size:14px;letter-spacing:.5px}
  .combo input{flex:1;border:0;outline:0;font:inherit;padding:11px 12px;font-family:var(--mono)}
  .ddl{position:absolute;z-index:30;top:calc(100% + 6px);left:0;right:0;background:#fff;
       border:1px solid var(--line);border-radius:12px;box-shadow:var(--shadow);
       max-height:280px;overflow-y:auto;display:none}
  .ddl.open{display:block}
  .ddl .item{padding:10px 14px;cursor:pointer;display:flex;gap:10px;align-items:baseline;border-bottom:1px solid #f3f5fa}
  .ddl .item:hover,.ddl .item.hl{background:#f4f6ff}
  .ddl .num{font-family:var(--mono);font-weight:700;color:var(--a1);min-width:74px}
  .ddl .fname{font-size:12px;color:var(--muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;flex:1}
  .ddl .mod{font-size:10px;font-weight:700;text-transform:uppercase;color:#fff;background:#94a3b8;
            border-radius:20px;padding:2px 8px;letter-spacing:.5px}
  .ddl .empty{padding:14px;color:var(--muted);font-size:13px;text-align:center}
  /* ── execution panel ── */
  .rail{display:flex;margin:4px 0 16px}
  .stage{flex:1;text-align:center;font-size:12px;color:var(--muted);position:relative;padding-top:20px}
  .stage::before{content:"";width:13px;height:13px;border-radius:50%;background:#d3dced;
                 position:absolute;top:0;left:50%;transform:translateX(-50%);transition:.25s}
  .stage::after{content:"";position:absolute;top:6px;left:-50%;width:100%;height:2.5px;background:#d3dced;z-index:0;transition:.25s}
  .stage:first-child::after{display:none}
  .stage.on::before{background:var(--a1);box-shadow:0 0 0 4px rgba(79,70,229,.18)}
  .stage.on::after{background:var(--a1)}
  .stage.done::before{background:var(--pass)} .stage.done::after{background:var(--pass)}
  .stage.bad::before{background:var(--fail)}
  .badge{font-size:13px;font-weight:700;padding:4px 12px;border-radius:20px;text-transform:capitalize}
  .badge.idle,.badge.queued{background:#eef1f7;color:var(--muted)}
  .badge.running{background:#e6efff;color:var(--a1);animation:pulse 1.4s infinite}
  .badge.passed{background:var(--pass-soft);color:var(--pass)}
  .badge.failed,.badge.error{background:var(--fail-soft);color:var(--fail)}
  .badge.stopped,.badge.discarded{background:var(--warn-soft);color:var(--warn)}
  .badge.review{background:#f3e8ff;color:#7c3aed;animation:pulse 1.4s infinite}
  /* review editor */
  .rfile{margin:16px 0}
  .rfile .fhead{display:flex;align-items:center;gap:10px;font-family:var(--mono);font-size:13px;
                font-weight:700;color:var(--a1);margin-bottom:6px}
  .rfile .ftag{font-size:10px;font-weight:800;letter-spacing:.6px;color:#fff;background:var(--grad);
               border-radius:20px;padding:2px 10px;text-transform:uppercase}
  textarea.code{width:100%;min-height:230px;resize:vertical;font-family:var(--mono);font-size:13px;
                line-height:1.55;color:var(--console-ink);background:var(--console);border:1px solid #223049;
                border-radius:12px;padding:14px;box-shadow:inset 0 2px 10px rgba(0,0,0,.4);tab-size:4}
  textarea.code:focus-visible{outline:2px solid var(--a1)}
  .rmeta{font-size:13.5px;background:#f3f0ff;border:1px solid #e4dcfb;color:#5b21b6;
         border-radius:10px;padding:10px 14px;margin-bottom:6px}
  @keyframes pulse{50%{opacity:.55}}
  #console{background:var(--console);color:var(--console-ink);font-family:var(--mono);font-size:13px;
           line-height:1.6;border-radius:12px;padding:14px 16px;height:300px;overflow:auto;
           white-space:pre-wrap;word-break:break-word;box-shadow:inset 0 2px 12px rgba(0,0,0,.45)}
  #console:empty::before{content:"Console output will stream here once a run starts.";color:#5b6b85}
  /* ── reports ── */
  .kpis{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px;margin-bottom:22px}
  .kpi{border:1px solid var(--line);border-radius:14px;padding:16px 18px;background:linear-gradient(180deg,#fff, #fafbff)}
  .kpi b{display:block;font-size:36px;line-height:1.1;font-variant-numeric:tabular-nums}
  .kpi span{font-size:12.5px;color:var(--muted);text-transform:uppercase;letter-spacing:.7px;font-weight:600}
  .kpi.p b{color:var(--pass)} .kpi.f b{color:var(--fail)} .kpi.a b{background:var(--grad);
    -webkit-background-clip:text;background-clip:text;color:transparent}
  .charts{display:grid;grid-template-columns:1fr 1fr 1fr;gap:26px;align-items:start}
  .cols{display:flex;justify-content:center;align-items:flex-end;gap:44px;height:210px;padding-top:10px}
  .col{display:flex;flex-direction:column;align-items:center;gap:8px}
  .col .val{font-size:26px;font-weight:800;font-variant-numeric:tabular-nums}
  .col .bar{width:64px;border-radius:10px 10px 4px 4px;transition:height .7s ease;box-shadow:inset 0 -3px 8px rgba(0,0,0,.12)}
  .col .lab{font-size:13px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:.6px}
  @media(max-width:1100px){.charts{grid-template-columns:1fr}}
  .chart-title{font-size:14px;color:var(--muted);font-weight:700;text-transform:uppercase;
               letter-spacing:.8px;margin-bottom:12px;text-align:center}
  .legend{font-size:13.5px;color:var(--muted);display:flex;gap:16px;justify-content:center;margin-top:10px}
  .dot{display:inline-block;width:10px;height:10px;border-radius:3px;margin-right:5px;vertical-align:-1px}
  .barrow{display:grid;grid-template-columns:minmax(120px,260px) 1fr 58px;gap:12px;align-items:center;font-size:12px;margin:8px 0}
  .barrow .name{overflow:hidden;text-overflow:ellipsis;white-space:nowrap;color:#334155}
  .bartrack{background:#eef1f8;border-radius:6px;height:16px;overflow:hidden}
  .barfill{height:100%;border-radius:6px;min-width:5px;transition:width .6s ease}
  .stack{height:26px;border-radius:8px;overflow:hidden;display:flex;box-shadow:inset 0 1px 3px rgba(0,0,0,.08)}
  .stack div{transition:width .6s ease}
  .note{border-radius:10px;padding:10px 14px;font-size:13px;margin-top:18px;background:var(--warn-soft);color:var(--warn);display:none}
  #toast{position:fixed;bottom:22px;left:50%;transform:translateX(-50%);background:var(--ink);color:#fff;
         padding:11px 20px;border-radius:12px;font-size:13px;display:none;z-index:99;box-shadow:var(--shadow)}
</style>
</head>
<body>
<header>
  <div class="logo">Tx</div>
  <div>
    <h1>Txn Automation Console</h1>
    <div class="sub">NBC Cucumber framework &middot; executes via TestRunner on Microsoft Edge</div>
  </div>
  <div class="spacer"></div>
  <span id="idxinfo" class="sub"></span>
  <button class="btn" onclick="rebuildIndex()">&#8635; Rebuild index</button>
</header>

<main>
  <!-- ═════════ NEW EXECUTION (sketch: top-left) ═════════ -->
  <section class="card">
    <h2>New Execution</h2>
    <div class="tabs">
      <button id="tab-up" class="active" onclick="setTab('up')">Upload feature</button>
      <button id="tab-txn" onclick="setTab('txn')">Run by Txn No</button>
    </div>

    <div id="pane-up">
      <label for="file">Feature file (.feature)</label>
      <input id="file" type="file" accept=".feature">
      <label class="check"><input id="dry" type="checkbox" checked>
        Verify steps first (dry run &mdash; no browser, seconds)</label>
      <label class="check"><input id="ai" type="checkbox">
        <b>AI update</b>&nbsp;&mdash; compare with the existing feature, append missing
        scenarios/steps/locators to the framework (old versions archived), then run</label>
      <div class="hintbox">The file runs from the server's uploads folder — the framework source is never modified.</div>
    </div>

    <div id="pane-txn" style="display:none">
      <label>Transaction number</label>
      <div class="combo" id="combo">
        <div class="row">
          <span class="chip">Txn</span>
          <input id="txn" placeholder="type a number or click to browse&hellip;" autocomplete="off"
                 oninput="filterDdl()" onfocus="openDdl()">
        </div>
        <div class="ddl" id="ddl"></div>
      </div>
      <div class="hintbox">All <b id="featcount">&hellip;</b> feature files are listed — scroll or type to search.
        The backend verifies the matching tag exists inside the feature before launching.</div>
    </div>

    <button id="runbtn" class="btn primary" style="width:100%;margin-top:18px;padding:13px" onclick="run()">&#9654;&nbsp; Run on Edge</button>
    <button id="stopbtn" class="btn stop" style="width:100%;margin-top:10px;padding:13px" onclick="stopRun()">&#9632;&nbsp; Stop execution</button>
  </section>

  <!-- ═════════ EXECUTION (sketch: top-right) ═════════ -->
  <section class="card">
    <h2>Execution <span id="jobmeta" class="sub" style="text-transform:none;letter-spacing:0"></span>
        <span class="spacer"></span><span id="status" class="badge idle">idle</span></h2>
    <div class="rail">
      <div class="stage" id="s1">Lookup</div>
      <div class="stage" id="s2">Launch JVM</div>
      <div class="stage" id="s3">Edge run</div>
      <div class="stage" id="s4">Report</div>
    </div>
    <div id="console" role="log" aria-live="polite"></div>
  </section>

  <!-- ═════════ REVIEW & EDIT (AI changes await approval) ═════════ -->
  <section class="card" id="reviewcard" style="grid-column:1 / -1;display:none">
    <h2>Review AI Changes <span class="sub" style="text-transform:none;letter-spacing:0">
        &mdash; edit anything below, then approve to update the framework and run</span></h2>
    <div class="rmeta" id="rmeta"></div>
    <div id="rfiles"></div>
    <div style="display:flex;gap:12px;margin-top:16px">
      <button class="btn primary" style="padding:12px 26px" onclick="approve()">&#10003;&nbsp; Approve &amp; Run on Edge</button>
      <button class="btn" style="padding:12px 22px" onclick="discard()">&#10005;&nbsp; Discard changes</button>
    </div>
  </section>

  <!-- ═════════ REPORTS (sketch: full width below) ═════════ -->
  <section class="card" id="reportcard" style="display:none">
    <h2>Result Report <span class="spacer"></span>
      <button class="btn" style="text-transform:none;letter-spacing:0;font-size:13.5px"
              onclick="downloadReport()">&#8681;&nbsp; Download HTML report</button></h2>
    <div class="kpis" id="kpis"></div>
    <div class="charts">
      <div>
        <div class="chart-title">Scenario pass rate</div>
        <div style="text-align:center"><svg id="donut" width="210" height="210" viewBox="0 0 200 200" role="img"></svg></div>
        <div class="legend">
          <span><span class="dot" style="background:var(--pass)"></span>Passed</span>
          <span><span class="dot" style="background:var(--fail)"></span>Failed</span>
        </div>
      </div>
      <div>
        <div class="chart-title">Steps breakdown</div>
        <div style="text-align:center"><svg id="stepdonut" width="210" height="210" viewBox="0 0 200 200" role="img"></svg></div>
        <div class="legend">
          <span><span class="dot" style="background:var(--pass)"></span>Passed</span>
          <span><span class="dot" style="background:var(--fail)"></span>Failed</span>
          <span><span class="dot" style="background:#f59e0b"></span>Skipped</span>
        </div>
      </div>
      <div>
        <div class="chart-title">Scenario results</div>
        <div id="columns" class="cols"></div>
      </div>
    </div>
    <div class="note" id="undefnote"></div>
    <div class="note" id="errnote" style="background:var(--fail-soft);color:var(--fail)"></div>
  </section>
</main>
<div id="toast"></div>

<script>
const API = "";
let tab = "up", job = null, offset = 0, timer = null, allTxns = [];

function toast(m){ const t = document.getElementById("toast");
  t.textContent = m; t.style.display = "block"; setTimeout(() => t.style.display = "none", 4200); }
function v(id){ return document.getElementById(id).value.trim() || null; }

function setTab(t){ tab = t;
  document.getElementById("tab-up").classList.toggle("active", t === "up");
  document.getElementById("tab-txn").classList.toggle("active", t === "txn");
  document.getElementById("pane-up").style.display = t === "up" ? "" : "none";
  document.getElementById("pane-txn").style.display = t === "txn" ? "" : "none";
  closeDdl(); }

/* ── index + searchable dropdown ─────────────────────────────────────── */
async function loadTxns(){
  try{
    const r = await fetch(API + "/txns?all=1"); const d = await r.json();
    allTxns = d.txns || [];
    document.getElementById("idxinfo").textContent = d.count + " txns indexed";
    document.getElementById("featcount").textContent = d.count;
    renderDdl(allTxns);
  }catch(e){}
}
function renderDdl(items){
  const ddl = document.getElementById("ddl");
  if (!items.length){ ddl.innerHTML = `<div class="empty">No matching transaction</div>`; return; }
  ddl.innerHTML = items.slice(0, 400).map(x => {
    const num = x.txn.replace(/^txn/i, "");
    return `<div class="item" onmousedown="pick('${num}')">
      <span class="num">${num}</span><span class="fname">${x.file}</span>
      <span class="mod">${x.module}</span></div>`; }).join("")
    + (items.length > 400 ? `<div class="empty">&hellip; ${items.length - 400} more — keep typing to narrow</div>` : "");
}
function filterDdl(){
  const q = document.getElementById("txn").value.trim().toLowerCase().replace(/^txn/, "");
  openDdl();
  renderDdl(!q ? allTxns : allTxns.filter(x =>
    x.txn.toLowerCase().includes(q) || (x.file || "").toLowerCase().includes(q)));
}
function openDdl(){ document.getElementById("ddl").classList.add("open"); }
function closeDdl(){ document.getElementById("ddl").classList.remove("open"); }
function pick(num){ document.getElementById("txn").value = num; closeDdl(); }
document.addEventListener("click", e => { if (!document.getElementById("combo").contains(e.target)) closeDdl(); });

async function rebuildIndex(){
  const r = await fetch(API + "/index/rebuild", {method:"POST"}); const d = await r.json();
  toast("Index rebuilt: " + d.indexed_txns + " transactions"); loadTxns(); }

/* ── run / stop ──────────────────────────────────────────────────────── */
async function run(){
  resetPanels();
  const btn = document.getElementById("runbtn"); btn.disabled = true;
  try{
    let res;
    if (tab === "txn"){
      const num = v("txn");
      if (!num){ toast("Enter or select a transaction number."); btn.disabled = false; return; }
      const txn = "Txn" + num.replace(/^txn/i, "");
      stage("s1", "on");
      res = await fetch(API + "/execute/txn/" + encodeURIComponent(txn),
        {method:"POST", headers:{"Content-Type":"application/json"}, body:"{}"});
    } else {
      const f = document.getElementById("file").files[0];
      if (!f){ toast("Choose a .feature file."); btn.disabled = false; return; }
      stage("s1", "on");
      const fd = new FormData(); fd.append("file", f);
      const ai = document.getElementById("ai").checked;
      res = await fetch(API + "/execute/upload?ai=" + ai +
        "&dry_run=" + (ai ? false : document.getElementById("dry").checked),
        {method:"POST", body:fd});
    }
    const d = await res.json();
    if (!res.ok) throw new Error(d.detail || "Request failed");
    job = d.job_id; offset = 0;
    stage("s1", "done"); stage("s2", "on");
    document.getElementById("jobmeta").textContent =
      "— " + (d.txn ? d.txn + " (" + d.module + ")" : d.feature.split(/[\\\/]/).pop()) +
      (d.tag ? "  ·  " + d.tag : "");
    document.getElementById("stopbtn").style.display = "block";
    timer = setInterval(poll, 1500);
  }catch(err){ toast(err.message); setBadge("error"); btn.disabled = false; }
}

async function stopRun(){
  if (!job) return;
  try{
    const r = await fetch(API + `/jobs/${job}/stop`, {method:"POST"});
    if (r.ok) toast("Stopping execution — closing Edge…");
  }catch(e){}
}

let reviewShown = false;
function resetPanels(){
  reviewShown = false;
  document.getElementById("reviewcard").style.display = "none";
  document.getElementById("console").textContent = "";
  document.getElementById("reportcard").style.display = "none";
  document.getElementById("stopbtn").style.display = "none";
  ["s1","s2","s3","s4"].forEach(id => document.getElementById(id).className = "stage");
  setBadge("queued"); }
function stage(id, cls){ document.getElementById(id).className = "stage " + cls; }
function setBadge(s){ const b = document.getElementById("status"); b.className = "badge " + s; b.textContent = s; }

/* ── polling ─────────────────────────────────────────────────────────── */
async function poll(){
  const r = await fetch(API + `/jobs/${job}/logs?offset=${offset}`);
  const d = await r.json();
  if (d.log){
    const c = document.getElementById("console");
    c.textContent += d.log; c.scrollTop = c.scrollHeight; offset = d.next_offset;
    if (/Scenario|cucumber/i.test(d.log)){ stage("s3", "on"); stage("s2", "done"); }
  }
  setBadge(d.status);
  if (d.status === "review" && !reviewShown){
    reviewShown = true;
    clearInterval(timer);
    document.getElementById("stopbtn").style.display = "none";
    await showReview();
    return;
  }
  if (["passed","failed","error","stopped","discarded"].includes(d.status)){
    clearInterval(timer);
    document.getElementById("runbtn").disabled = false;
    document.getElementById("stopbtn").style.display = "none";
    stage("s2", "done");
    stage("s3", d.status === "passed" ? "done" : d.status === "failed" ? "done" : "bad");
    stage("s4", d.status === "passed" ? "done" : "bad");
    const jr = await fetch(API + "/jobs/" + job); renderReport(await jr.json());
  }
}

/* ── report (no error dumps — counts + 3 graphics only) ──────────────── */
function renderReport(j){
  const s = j.summary || {};
  document.getElementById("reportcard").style.display = "block";
  const total = s.scenarios_total ?? 0, pass = s.scenarios_passed ?? 0, fail = s.scenarios_failed ?? 0;
  const sp = s.steps_passed ?? 0, sf = s.steps_failed ?? 0, sk = s.steps_skipped ?? 0;
  const dur = (s.scenarios || []).reduce((a, x) => a + (x.duration_sec || 0), 0);
  const rate = total ? Math.round(100 * pass / total) : 0;
  const kpi = (n, label, cls="") => `<div class="kpi ${cls}"><b>${n}</b><span>${label}</span></div>`;
  document.getElementById("kpis").innerHTML =
    kpi(total, "scenarios") + kpi(pass, "passed", "p") + kpi(fail, "failed", "f") +
    kpi(rate + "%", "pass rate", "a") + kpi(sp, "steps passed", "p") +
    kpi(sf, "steps failed", "f") + kpi(sk, "steps skipped") +
    kpi(dur ? dur.toFixed(1) + "s" : "—", "total time", "a");

  lastReport = {summary: s, meta: document.getElementById("jobmeta").textContent,
                status: j.status, when: new Date().toLocaleString()};
  drawDonut(pass, fail);
  drawStepsDonut(sp, sf, sk);
  drawColumns(pass, fail);

  const en = document.getElementById("errnote");
  if (s.error){ en.style.display = "block"; en.textContent = s.error; }
  else en.style.display = "none";
  const u = document.getElementById("undefnote");
  if (s.undefined_steps && s.undefined_steps.length){
    u.style.display = "block";
    u.textContent = s.undefined_steps.length +
      " step(s) in this feature have no matching step definition in the framework — they were skipped.";
  } else u.style.display = "none";
}

function drawDonut(pass, fail){
  const total = pass + fail, svg = document.getElementById("donut");
  if (!total){ svg.innerHTML = `<text x="100" y="105" text-anchor="middle" fill="#64748b" font-size="13">no scenarios</text>`; return; }
  const R = 78, C = 2 * Math.PI * R, passLen = C * pass / total;
  svg.innerHTML = `
    <circle cx="100" cy="100" r="${R}" fill="none" stroke="#dc2626" stroke-width="26"/>
    <circle cx="100" cy="100" r="${R}" fill="none" stroke="#16a34a" stroke-width="26"
      stroke-linecap="${pass && fail ? "butt" : "round"}"
      stroke-dasharray="${passLen} ${C - passLen}" stroke-dashoffset="${C / 4}"
      style="transition:stroke-dasharray .8s ease"/>
    <circle cx="100" cy="100" r="52" fill="#fff"/>
    <text x="100" y="97" text-anchor="middle" font-size="30" font-weight="800" fill="#101a2e">${Math.round(100 * pass / total)}%</text>
    <text x="100" y="119" text-anchor="middle" font-size="11" fill="#64748b" letter-spacing="1">PASSED</text>`;
}

function drawStepsDonut(p, f, k){
  const svg = document.getElementById("stepdonut"), tot = p + f + k;
  if (!tot){ svg.innerHTML = `<text x="100" y="105" text-anchor="middle" fill="#64748b" font-size="13">no steps</text>`; return; }
  const R = 78, C = 2 * Math.PI * R, off = C / 4;
  const arc = (len, color) =>
    `<circle cx="100" cy="100" r="${R}" fill="none" stroke="${color}" stroke-width="26"
      stroke-dasharray="${len} ${C - len}" stroke-dashoffset="${off}" style="transition:stroke-dasharray .8s ease"/>`;
  // layered rings: skipped as the base, failed over [0, p+f), passed over [0, p)
  svg.innerHTML =
    `<circle cx="100" cy="100" r="${R}" fill="none" stroke="#f59e0b" stroke-width="26"/>` +
    arc(C * (p + f) / tot, "#dc2626") + arc(C * p / tot, "#16a34a") +
    `<circle cx="100" cy="100" r="52" fill="#fff"/>` +
    `<text x="100" y="93" text-anchor="middle" font-size="26" font-weight="800" fill="#101a2e">${tot}</text>` +
    `<text x="100" y="115" text-anchor="middle" font-size="11" fill="#64748b" letter-spacing="1">TOTAL STEPS</text>`;
}

function drawColumns(pass, fail){
  const max = Math.max(pass, fail, 1);
  const col = (v, color, lab) => `
    <div class="col">
      <span class="val" style="color:${color}">${v}</span>
      <div class="bar" style="height:${Math.max(10, 150 * v / max)}px;background:linear-gradient(180deg,${color},${color}cc)"></div>
      <span class="lab">${lab}</span>
    </div>`;
  document.getElementById("columns").innerHTML =
    col(pass, "#16a34a", "Passed") + col(fail, "#dc2626", "Failed");
}

let lastReport = null;
function downloadReport(){
  if (!lastReport) return;
  const s = lastReport.summary;
  const donut = document.getElementById("donut").outerHTML;
