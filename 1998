def is_scaffolded(root: Path) -> bool:
    return (root / "src/main/java/core/DriverFactory.java").exists()


def scaffold(path: str | None = None, force: bool = False) -> dict:
    """Create the base framework if it doesn't exist. Never overwrites
    existing files unless force=True. Returns a summary of what was created."""
    settings = config.load_settings()
    root = Path(path or settings.get("framework_path") or "")
    if not str(root):
        raise RuntimeError("Framework path is not configured in Settings.")
    created, skipped = [], []
    for rel, content in FILES.items():
        target = root / rel
        if target.exists() and not force:
            skipped.append(rel)
            continue
        target.parent.mkdir(parents=True, exist_ok=True)
        target.write_text(content, encoding="utf-8")
        created.append(rel)
    for d in ("libs", "src/test/resources/features", "out"):
        (root / d).mkdir(parents=True, exist_ok=True)
    return {"root": str(root), "created": created, "skipped": skipped,
            "already_scaffolded": not created,
            "next_step": "Populate libs/ with scripts/get-libs, then record & generate."}
