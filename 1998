"use client";
import { useState, useEffect } from "react";
import { styles } from "../../styles/AppStyles";

// Local styles for layout that AppStyles doesn't cover (table + bars + search).
// Move these into AppStyles if you prefer to keep styling centralized.
const local = {
    grid2: {
        display: "grid",
        gridTemplateColumns: "repeat(auto-fit, minmax(320px, 1fr))",
        gap: "20px",
    },
    stateText: { padding: "20px", color: "#888", fontSize: "14px" },
    scroll: { maxHeight: "360px", overflowY: "auto" },
    table: { width: "100%", borderCollapse: "collapse", fontSize: "14px" },
    th: {
        textAlign: "left",
        padding: "12px 16px",
        borderBottom: "2px solid #eee",
        color: "#666",
        fontWeight: 600,
        fontSize: "12px",
        textTransform: "uppercase",
        letterSpacing: "0.03em",
    },
    td: { padding: "12px 16px", borderBottom: "1px solid #f0f0f0", color: "#333" },
    searchInput: {
        width: "100%",
        boxSizing: "border-box",
        padding: "8px 12px",
        marginBottom: "12px",
        border: "1px solid #ddd",
        borderRadius: "6px",
        fontSize: "13px",
        outline: "none",
    },
    barRow: {
        display: "flex",
        alignItems: "center",
        gap: "12px",
        padding: "10px 16px",
        borderBottom: "1px solid #f0f0f0",
    },
    barLabel: {
        width: "130px",
        flexShrink: 0,
        fontSize: "13px",
        color: "#333",
        whiteSpace: "nowrap",
        overflow: "hidden",
        textOverflow: "ellipsis",
    },
    barTrack: {
        flex: 1,
        height: "10px",
        background: "#f0f0f0",
        borderRadius: "6px",
        overflow: "hidden",
    },
    barFill: { height: "100%", background: "#4f46e5", borderRadius: "6px" },
    barValue: {
        width: "48px",
        flexShrink: 0,
        textAlign: "right",
        fontSize: "13px",
        fontWeight: 600,
        color: "#333",
    },
};

export default function ActivityView() {
    const [deptSummary, setDeptSummary] = useState([]);
    const [productivity, setProductivity] = useState([]);
    const [trend, setTrend] = useState([]);

    const [deptLoading, setDeptLoading] = useState(false);
    const [prodLoading, setProdLoading] = useState(false);
    const [trendLoading, setTrendLoading] = useState(false);
    const [exportLoading, setExportLoading] = useState(false);

    const [search, setSearch] = useState("");
    const [error, setError] = useState("");

    const BASE_URL = process.env.NEXT_PUBLIC_API_URL;

    // Generic GET helper following the project's fetch pattern.
    const fetchData = async (endpoint, setData, setLoading) => {
        setLoading(true);
        setError("");
        try {
            const res = await fetch(`${BASE_URL}/${endpoint}`, {
                credentials: "include",
                method: "GET",
                headers: { "Content-Type": "application/json" },
            });

            if (!res.ok) {
                if (res.status === 401 || res.status === 403) {
                    setError("Session expired or unauthorized. Please log in again.");
                    window.location.reload();
                    return;
                }
                throw new Error(`API returned an error: ${res.status} ${res.statusText}`);
            }

            const data = await res.json();
            setData(Array.isArray(data) ? data : []);
        } catch (err) {
            console.error("Fetch error:", err);
            setError(err.message);
        } finally {
            setLoading(false);
        }
    };

    useEffect(() => {
        fetchData("department_user_summary", setDeptSummary, setDeptLoading);
        fetchData("employee_productivity", setProductivity, setProdLoading);
        fetchData("cif_trend", setTrend, setTrendLoading);
    }, []);

    // Export users -> downloads the .xlsx as a blob while keeping auth cookies.
    const handleExportUsers = async () => {
        setExportLoading(true);
        setError("");
        try {
            const res = await fetch(`${BASE_URL}/export-users`, {
                credentials: "include",
                method: "GET",
            });

            if (!res.ok) {
                if (res.status === 401 || res.status === 403) {
                    setError("Session expired or unauthorized. Please log in again.");
                    window.location.reload();
                    return;
                }
                throw new Error(`API returned an error: ${res.status} ${res.statusText}`);
            }

            const blob = await res.blob();
            const url = window.URL.createObjectURL(blob);
            const link = document.createElement("a");
            link.href = url;
            link.setAttribute("download", "users_export.xlsx");
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            window.URL.revokeObjectURL(url);
        } catch (err) {
            console.error("Export error:", err);
            setError(err.message);
        } finally {
            setExportLoading(false);
        }
    };

    const maxProd = Math.max(...productivity.map((p) => p.cif_count), 1);
    const maxTrend = Math.max(...trend.map((t) => t.count), 1);

    // Search filter for employee productivity (case-insensitive on username).
    const filteredProductivity = productivity.filter((p) =>
        (p.username || "").toLowerCase().includes(search.toLowerCase())
    );

    return (
        <div>
            <div style={styles.pageHeader}>
                <div>
                    <h1 style={styles.pageTitle}>Activity Dashboard</h1>
                    <p style={styles.pageSubtitle}>
                        User activity, productivity and CIF creation trends
                    </p>
                </div>
                <button
                    onClick={handleExportUsers}
                    style={styles.primaryButton}
                    disabled={exportLoading}
                >
                    {exportLoading ? "Exporting..." : "Export Users (Excel)"}
                </button>
            </div>

            {error && <div style={styles.errorMsg}>{error}</div>}

            {/* Department Summary */}
            <div style={styles.resultsCard}>
                <div style={styles.resultsHeader}>
                    <h3 style={styles.resultsTitle}>Department Summary</h3>
                </div>

                {deptLoading ? (
                    <div style={local.stateText}>Loading...</div>
                ) : deptSummary.length === 0 ? (
                    <div style={local.stateText}>No data available.</div>
                ) : (
                    <div style={local.scroll}>
                        <table style={local.table}>
                            <thead>
                                <tr>
                                    <th style={local.th}>Department</th>
                                    <th style={local.th}>Banker Total</th>
                                    <th style={local.th}>Banker Users</th>
                                    <th style={local.th}>Vendor Total</th>
                                    <th style={local.th}>Vendor Active</th>
                                </tr>
                            </thead>
                            <tbody>
                                {deptSummary.map((row, index) => (
                                    <tr key={index}>
                                        <td style={local.td}>{row.deparmentCode}</td>
                                        <td style={local.td}>{row.banker_total_users}</td>
                                        <td style={local.td}>{row.banker_active_users}</td>
                                        <td style={local.td}>{row.vendor_total_users}</td>
                                        <td style={local.td}>{row.vendor_active_users}</td>
                                    </tr>
                                ))}
                            </tbody>
                        </table>
                    </div>
                )}
            </div>

            <div style={local.grid2}>
                {/* Employee Productivity */}
                <div style={styles.resultsCard}>
                    <div style={styles.resultsHeader}>
                        <h3 style={styles.resultsTitle}>
                            Count of CIF per User ({filteredProductivity.length})
                        </h3>
                    </div>

                    <input
                        type="text"
                        placeholder="Search users..."
                        value={search}
                        onChange={(e) => setSearch(e.target.value)}
                        style={local.searchInput}
                    />

                    {prodLoading ? (
                        <div style={local.stateText}>Loading...</div>
                    ) : productivity.length === 0 ? (
                        <div style={local.stateText}>No data available.</div>
                    ) : filteredProductivity.length === 0 ? (
                        <div style={local.stateText}>No users match "{search}".</div>
                    ) : (
                        <div style={local.scroll}>
                            {filteredProductivity.map((p, index) => (
                                <div key={index} style={local.barRow}>
                                    <span style={local.barLabel} title={p.username}>
                                        {p.username}
                                    </span>
                                    <div style={local.barTrack}>
                                        <div
                                            style={{
                                                ...local.barFill,
                                                width: `${(p.cif_count / maxProd) * 100}%`,
                                            }}
                                        />
                                    </div>
                                    <span style={local.barValue}>{p.cif_count}</span>
                                </div>
                            ))}
                        </div>
                    )}
                </div>

                {/* CIF Trend */}
                <div style={styles.resultsCard}>
                    <div style={styles.resultsHeader}>
                        <h3 style={styles.resultsTitle}>CIF Trend</h3>
                    </div>

                    {trendLoading ? (
                        <div style={local.stateText}>Loading...</div>
                    ) : trend.length === 0 ? (
                        <div style={local.stateText}>No data available.</div>
                    ) : (
                        <div style={local.scroll}>
                            {trend.map((t, index) => (
                                <div key={index} style={local.barRow}>
                                    <span style={local.barLabel} title={t.date}>
                                        {t.date}
                                    </span>
                                    <div style={local.barTrack}>
                                        <div
                                            style={{
                                                ...local.barFill,
                                                width: `${(t.count / maxTrend) * 100}%`,
                                            }}
                                        />
                                    </div>
                                    <span style={local.barValue}>{t.count}</span>
                                </div>
                            ))}
                        </div>
                    )}
                </div>
            </div>
        </div>
    );
}
