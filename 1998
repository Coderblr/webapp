                  java: top.java, locator_type: top.locator_type,
                  locator_value: top.locator_value, screen: e.title, url: e.url});
  });
  const r = await (await fetch(API + "/recorder/save", {method:"POST",
    headers:{"Content-Type":"application/json"}, body: JSON.stringify({entries})})).json();
