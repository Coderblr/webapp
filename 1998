"""Module 22 — Execution Engine (+ Module 23 report data, Module 21 learning).

Compiles and runs the Java Selenium-Cucumber framework LIVE in a real, visible
Microsoft Edge browser (headless only if explicitly toggled). Streams every log
line / step / pass-fail to the frontend over WebSocket, captures failures,
parses the cucumber JSON report, and asks Azure OpenAI for root cause analysis.
The Edge/EdgeDriver versions are checked and must match; the execution session
uses its own Edge profile so it never conflicts with the Recorder's session.
"""
import asyncio
import json
import re
import os
import subprocess
from pathlib import Path

from .. import config
from ..ai import azure_client
from ..models import Execution, LearningEvent, SessionLocal, now

# execution_id → asyncio.Queue of live events (consumed by the WebSocket)
_streams: dict[int, asyncio.Queue] = {}
_procs: dict[int, subprocess.Popen] = {}


def check_edge_versions() -> dict:
    """Auto-detect Edge and EdgeDriver versions and verify they match."""
    s = config.load_settings()
    out = {"edge": None, "driver": None, "match": None}
    try:
        r = subprocess.run([s["edgedriver_path"], "--version"],
                           capture_output=True, text=True, timeout=10)
        m = re.search(r"(\d+)\.", r.stdout)
        out["driver"] = r.stdout.strip().split("\n")[0]
        drv_major = m.group(1) if m else None
    except Exception as e:
        out["driver"] = f"not found ({e})"
        drv_major = None
    for candidate in ([s["edge_binary_path"]] if s.get("edge_binary_path") else []) + \
                     ["microsoft-edge", "msedge"]:
        try:
            r = subprocess.run([candidate, "--version"], capture_output=True,
                               text=True, timeout=10)
            out["edge"] = r.stdout.strip()
            m = re.search(r"(\d+)\.", r.stdout)
            out["match"] = bool(m and drv_major and m.group(1) == drv_major)
            break
        except Exception:
            continue
    return out


async def _emit(execution_id: int, event: dict):
    q = _streams.get(execution_id)
    if q:
        await q.put(event)


def get_stream(execution_id: int) -> asyncio.Queue:
    return _streams.setdefault(execution_id, asyncio.Queue())


async def start_execution(transactions: list[str], environment: str = "SIT",
                          headless: bool | None = None) -> int:
    settings = config.load_settings()
    if headless is None:
        headless = settings["default_headless"]      # default: LIVE visible Edge
    db = SessionLocal()
    ex = Execution(transactions=transactions, environment=environment,
                   headless=headless)
    db.add(ex)
    db.commit()
    eid = ex.id
    db.close()
    get_stream(eid)
    asyncio.create_task(_run(eid, transactions, environment, headless, settings))
    return eid


async def _run(eid: int, transactions: list[str], environment: str,
               headless: bool, settings: dict):
    root = settings.get("framework_path")
    log_dir = config.ARTIFACTS_DIR / f"exec_{eid}"
    log_dir.mkdir(exist_ok=True)
    log_path = log_dir / "execution.log"
    tags = " or ".join(f"@{t}" for t in transactions) if transactions else ""

    # ---- Pure JDK runner (no Maven): javac compile + Cucumber CLI ----
    root_p = Path(root) if root else None
    java_home = settings.get("java_home", "")
    java = str(Path(java_home) / "bin" / "java") if java_home else "java"
    javac = str(Path(java_home) / "bin" / "javac") if java_home else "javac"

    libs = Path(settings.get("libs_path") or (root_p / "libs" if root_p else "libs"))
    out_dir = (root_p / "out") if root_p else Path("out")
    src_dirs = [root_p / d for d in ("src/main/java", "src/test/java")] if root_p else []
    src_dirs = [d for d in src_dirs if d.exists()] or ([root_p / "src"] if root_p and (root_p / "src").exists() else [])
    features = next((root_p / d for d in
                     ("src/test/resources/features", "src/test/resources", "features")
                     if root_p and (root_p / d).exists()), root_p)
    resources = root_p / "src/test/resources" if root_p else None

    def _jars(folder: Path) -> str:
        """Explicit jar list excluding sources/javadoc jars — javac otherwise
        compiles .java files found inside *-sources.jar (deprecation spam)."""
        jars = [str(j) for j in sorted(folder.glob("*.jar"))
                if not j.stem.endswith(("-sources", "-javadoc"))]
        return os.pathsep.join(jars) if jars else str(folder / "*")

    lib_cp = _jars(libs) if libs.exists() else str(libs / "*")
    cp_parts = [str(out_dir), lib_cp]
    if resources and resources.exists():
        cp_parts.append(str(resources))
    classpath = os.pathsep.join(cp_parts)

    java_flags = [f"-Denvironment={environment}",
                  "-Dbrowser=edge",
                  f"-Dheadless={'true' if headless else 'false'}",
                  f"-Dwebdriver.edge.driver={settings['edgedriver_path']}",
                  f"-Dedge.profile.dir={config.DATA_DIR / 'edge_exec_profile'}"]
    if settings.get("edge_binary_path"):
        java_flags.append(f"-Dedge.binary={settings['edge_binary_path']}")

    run_cmd = [java, "-cp", classpath, *java_flags,
               "io.cucumber.core.cli.Main",
               "--glue", settings.get("glue_package", "stepdefinitions"),
               "--plugin", "pretty",
               "--plugin", f"json:{log_dir}/cucumber.json",
               *(["--tags", tags] if tags else []),
               str(features)]

    await _emit(eid, {"type": "status", "message":
                      f"Compiling with javac, then launching {'headless' if headless else 'LIVE visible'} Edge…",
                      "cmd": " ".join(run_cmd)})
    db = SessionLocal()
    try:
        if not root or not Path(root).exists():
            raise RuntimeError("Framework path is not configured in Settings.")
        if not libs.exists() or not any(libs.glob("*.jar")):
            raise RuntimeError(f"No jars found in {libs}. Run get-libs script or set 'libs_path' in Settings.")

        # Phase 1: compile all .java sources with javac
        sources = [str(p) for d in src_dirs for p in d.rglob("*.java")]
        if sources:
            out_dir.mkdir(exist_ok=True)
            src_list = log_dir / "sources.txt"
            src_list.write_text("\n".join(sources))
            comp = subprocess.run(
                [javac, "-encoding", "UTF-8", "-implicit:none",
                 "-cp", lib_cp, "-d", str(out_dir), f"@{src_list}"],
                cwd=root, capture_output=True, text=True)
            for line in (comp.stdout + comp.stderr).splitlines():
                await _emit(eid, {"type": "log", "line": line})
            if comp.returncode != 0:
                raise RuntimeError("javac compilation failed — see log above.")
            await _emit(eid, {"type": "status",
                              "message": f"Compiled {len(sources)} Java files. Starting Cucumber…"})

        # Phase 2: run Cucumber CLI on the JDK, live-streamed
        proc = subprocess.Popen(run_cmd, cwd=root, stdout=subprocess.PIPE,
                                stderr=subprocess.STDOUT, text=True, bufsize=1)
        _procs[eid] = proc
        with open(log_path, "w") as lf:
            loop = asyncio.get_event_loop()
            while True:
                line = await loop.run_in_executor(None, proc.stdout.readline)
                if not line:
                    break
                lf.write(line)
                ev = {"type": "log", "line": line.rstrip()}
                if re.search(r"Scenario:|Given |When |Then ", line):
                    ev["type"] = "step"
                if re.search(r"PASSED|✔", line):
                    ev["result"] = "passed"
                elif re.search(r"FAILED|✘|Exception", line):
                    ev["result"] = "failed"
                    ev["type"] = "failure"
                await _emit(eid, ev)
        rc = proc.wait()
        report = _parse_cucumber(log_dir / "cucumber.json")
        rca = await _root_cause(report) if report.get("failed") else None
        db.query(Execution).filter_by(id=eid).update({
            "status": "passed" if rc == 0 else "failed",
            "passed": report.get("passed", 0), "failed": report.get("failed", 0),
            "skipped": report.get("skipped", 0), "finished_at": now(),
            "log_path": str(log_path),
            "report": {**report, "root_cause_analysis": rca}})
        db.add(LearningEvent(kind="execution", reference=str(eid),
                             detail={"rc": rc, "summary": report}))
        db.commit()
        await _emit(eid, {"type": "done", "status": "passed" if rc == 0 else "failed",
                          "report": report, "rca": rca})
    except Exception as e:
        db.query(Execution).filter_by(id=eid).update(
            {"status": "failed", "finished_at": now()})
        db.commit()
        await _emit(eid, {"type": "error", "message": str(e)})
    finally:
        db.close()
        _procs.pop(eid, None)


def stop_execution(eid: int) -> bool:
    p = _procs.get(eid)
    if p:
        p.terminate()
        return True
    return False


def _parse_cucumber(path: Path) -> dict:
    if not path.exists():
        return {"passed": 0, "failed": 0, "skipped": 0, "scenarios": []}
    try:
        data = json.loads(path.read_text())
    except Exception:
        return {"passed": 0, "failed": 0, "skipped": 0, "scenarios": []}
    passed = failed = skipped = 0
    scenarios = []
    for feature in data:
        for el in feature.get("elements", []):
            statuses = [s.get("result", {}).get("status") for s in el.get("steps", [])]
            st = ("failed" if "failed" in statuses
                  else "skipped" if "skipped" in statuses else "passed")
            passed += st == "passed"
            failed += st == "failed"
            skipped += st == "skipped"
            scenarios.append({"feature": feature.get("name"),
                              "scenario": el.get("name"), "status": st,
                              "error": next((s["result"].get("error_message", "")[:800]
                                             for s in el.get("steps", [])
                                             if s.get("result", {}).get("status") == "failed"), None)})
    return {"passed": passed, "failed": failed, "skipped": skipped,
            "scenarios": scenarios}


async def _root_cause(report: dict) -> list[dict]:
    """Module 23 — AI Root Cause Analysis for every failed scenario."""
    failures = [s for s in report.get("scenarios", []) if s["status"] == "failed"][:10]
    if not failures:
        return []
    result = await azure_client.chat_json(
        "You are a senior automation failure analyst for banking test suites. "
        "For each failure classify root cause (locator|data|environment|"
        "application_defect|timing), explain it, state business impact, give a "
        "confidence score 0-1 and a recommendation.",
        json.dumps(failures) +
        ' Return {"analysis": [{"scenario": "...", "root_cause": "...", '
        '"explanation": "...", "business_impact": "...", "confidence": 0.9, '
        '"recommendation": "..."}]}',
        max_tokens=3000)
    return result.get("analysis", [])
