# agents/framework_import_agent.py
#
# One-touch importer for an EXISTING java-framework — one you already had before
# the AI got involved, with real Page Objects, Step Definitions, and Feature
# files written by hand. This agent reads all of it straight off disk and loads
# it into the exact same knowledge graph (pages/locators/step_definitions) that
# every other AI agent already reads from and writes to.
#
# After this runs once, the AI treats your existing framework exactly like
# something it generated itself: FrameworkManagerAgent won't re-create pages or
# steps that already exist, JavaGeneratorAgent will reuse your real locators
# instead of guessing new ones, and SelfHealingAgent can heal your existing
# Page Objects when a locator breaks. Nothing on disk is modified — this only
# reads Java/feature files and writes rows into the database.

import os
import re
from database import SessionLocal, PageModel, LocatorModel, StepDefinitionModel
from paths import JAVA_FRAMEWORK_SRC


class FrameworkImportAgent:
    """Scans java-framework/src for Page Objects, Step Definitions, and Feature
    files, and ingests everything found into the knowledge graph database."""

    PAGES_DIR = os.path.join(JAVA_FRAMEWORK_SRC, "main", "java", "com", "nbc", "pages")
    STEPS_DIR = os.path.join(JAVA_FRAMEWORK_SRC, "test", "java", "com", "nbc", "steps")
    FEATURES_DIR = os.path.join(JAVA_FRAMEWORK_SRC, "test", "resources", "features")

    # By.id("x"), By.xpath("//..."), By.cssSelector("..."), By.name("x"), By.className("x"), ...
    LOCATOR_RE = re.compile(
        r'By\.(id|xpath|cssSelector|name|className|linkText|partialLinkText|tagName)\(\s*"((?:[^"\\]|\\.)*)"\s*\)'
    )
    # private final By fieldName = ...;   (also matches non-final/non-private variants)
    FIELD_RE = re.compile(
        r'(?:private|protected|public)?\s*(?:final\s+)?By\s+(\w+)\s*=\s*(.+?);', re.DOTALL
    )
    CLASS_RE = re.compile(r'\bclass\s+(\w+)\b')
    # @Given("...") / @When("...") / @Then("...") / @And("...") immediately above a method
    STEP_ANNOTATION_RE = re.compile(
        r'@(Given|When|Then|And)\(\s*"((?:[^"\\]|\\.)*)"\s*\)\s*\n\s*public\s+void\s+(\w+)\s*\([^)]*\)\s*\{'
    )
    SCENARIO_RE = re.compile(r'^\s*Scenario', re.MULTILINE)

    def import_all(self) -> dict:
        """Runs the full one-touch import and returns a summary for the UI."""
        pages_result = self._import_pages()
        steps_result = self._import_steps()
        features_result = self._scan_features()

        return {
            "pages_imported": pages_result["pages"],
            "locators_imported": pages_result["locators"],
            "page_names": pages_result["names"],
            "step_definitions_imported": steps_result["count"],
            "feature_files_found": features_result["count"],
            "scenarios_found": features_result["scenarios"],
            "warnings": pages_result["skipped"] + steps_result["skipped"] + features_result["skipped"],
            "message": (
                f"Imported {pages_result['pages']} page(s) with {pages_result['locators']} locator(s), "
                f"{steps_result['count']} step definition(s), and found {features_result['count']} feature "
                f"file(s) with {features_result['scenarios']} scenario(s). The AI now treats these as "
                f"existing framework knowledge — it won't regenerate or duplicate them."
            ),
        }

    # ─────────────────────────────────────────────
    #  Page Objects → PageModel + LocatorModel
    # ─────────────────────────────────────────────

    def _import_pages(self) -> dict:
        db = SessionLocal()
        imported_pages = []
        skipped = []
        locator_count = 0
        try:
            if not os.path.isdir(self.PAGES_DIR):
                return {"pages": 0, "locators": 0, "names": [], "skipped": [f"Pages folder not found: {self.PAGES_DIR}"]}

            for fname in sorted(os.listdir(self.PAGES_DIR)):
                if not fname.endswith(".java"):
                    continue
                fpath = os.path.join(self.PAGES_DIR, fname)
                try:
                    with open(fpath, "r", encoding="utf-8", errors="ignore") as f:
                        content = f.read()
                except Exception as e:
                    skipped.append(f"{fname}: could not read ({e})")
                    continue

                class_match = self.CLASS_RE.search(content)
                page_name = class_match.group(1) if class_match else fname.replace(".java", "")

                field_matches = self.FIELD_RE.findall(content)
                if not field_matches:
                    continue  # no By-typed fields in this file — nothing to import

                db_page = db.query(PageModel).filter(PageModel.name == page_name).first()
                if not db_page:
                    db_page = PageModel(name=page_name, url="", description=f"Imported from existing framework: {fname}")
                    db.add(db_page)
                    db.flush()

                page_locator_count = 0
                for field_name, expr in field_matches:
                    loc_match = self.LOCATOR_RE.search(expr)
                    if not loc_match:
                        continue
                    raw_type, raw_value = loc_match.group(1), loc_match.group(2)
                    selector_type = {
                        "cssSelector": "css", "className": "css", "tagName": "css",
                        "linkText": "xpath", "partialLinkText": "xpath",
                    }.get(raw_type, raw_type)  # id / xpath / name pass through unchanged

                    existing = db.query(LocatorModel).filter(
                        LocatorModel.page_id == db_page.id,
                        LocatorModel.element_name == field_name,
                    ).first()
                    if existing:
                        existing.selector_type = selector_type
                        existing.selector_value = raw_value
                    else:
                        db.add(LocatorModel(
                            page_id=db_page.id,
                            element_name=field_name,
                            selector_type=selector_type,
                            selector_value=raw_value,
                            description=f"Imported from existing framework: {fname}",
                        ))
                    page_locator_count += 1

                if page_locator_count:
                    imported_pages.append(page_name)
                    locator_count += page_locator_count

            db.commit()
        except Exception:
            db.rollback()
            raise
        finally:
            db.close()
        return {"pages": len(imported_pages), "locators": locator_count, "names": imported_pages, "skipped": skipped}

    # ─────────────────────────────────────────────
    #  Step Definitions → StepDefinitionModel
    # ─────────────────────────────────────────────

    def _import_steps(self) -> dict:
        db = SessionLocal()
        count = 0
        skipped = []
        try:
            if not os.path.isdir(self.STEPS_DIR):
                return {"count": 0, "skipped": [f"Steps folder not found: {self.STEPS_DIR}"]}

            for fname in sorted(os.listdir(self.STEPS_DIR)):
                if not fname.endswith(".java"):
                    continue
                fpath = os.path.join(self.STEPS_DIR, fname)
                try:
                    with open(fpath, "r", encoding="utf-8", errors="ignore") as f:
                        content = f.read()
                except Exception as e:
                    skipped.append(f"{fname}: could not read ({e})")
                    continue

                for _annotation, pattern, method_name in self.STEP_ANNOTATION_RE.findall(content):
                    body = self._extract_method_body(content, method_name)
                    existing = db.query(StepDefinitionModel).filter(
                        StepDefinitionModel.pattern == pattern
                    ).first()
                    if existing:
                        existing.java_method = method_name
                        existing.java_code = body
                    else:
                        db.add(StepDefinitionModel(
                            pattern=pattern,
                            java_method=method_name,
                            java_code=body,
                            page_associated=fname.replace(".java", ""),
                        ))
                    count += 1
            db.commit()
        except Exception:
            db.rollback()
            raise
        finally:
            db.close()
        return {"count": count, "skipped": skipped}

    def _extract_method_body(self, content: str, method_name: str) -> str:
        """Naive brace-matching to pull a method's full source given its name —
        consistent with the rest of this codebase's text-based (non-AST) Java handling."""
        marker = re.search(r'public\s+void\s+' + re.escape(method_name) + r'\s*\([^)]*\)\s*\{', content)
        if not marker:
            return ""
        start = marker.start()
        depth = 0
        for j in range(marker.end() - 1, len(content)):
            if content[j] == '{':
                depth += 1
            elif content[j] == '}':
                depth -= 1
                if depth == 0:
                    return content[start:j + 1]
        return content[start:start + 500]  # fallback if braces are unbalanced

    # ─────────────────────────────────────────────
    #  Feature files — counted for the summary (left on disk as-is)
    # ─────────────────────────────────────────────

    def _scan_features(self) -> dict:
        count = 0
        scenarios = 0
        skipped = []
        if not os.path.isdir(self.FEATURES_DIR):
            return {"count": 0, "scenarios": 0, "skipped": [f"Features folder not found: {self.FEATURES_DIR}"]}

        for fname in sorted(os.listdir(self.FEATURES_DIR)):
            if not fname.endswith(".feature"):
                continue
            count += 1
            try:
                with open(os.path.join(self.FEATURES_DIR, fname), "r", encoding="utf-8", errors="ignore") as f:
                    content = f.read()
                scenarios += len(self.SCENARIO_RE.findall(content))
            except Exception as e:
                skipped.append(f"{fname}: could not read ({e})")
        return {"count": count, "scenarios": scenarios, "skipped": skipped}
