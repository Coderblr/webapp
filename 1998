}

/* ── review editor ───────────────────────────────────────────────────── */
async function showReview(){
  const r = await fetch(API + `/jobs/${job}/pending`);
  if (!r.ok){ toast("Could not load pending changes."); return; }
  const p = await r.json();
  const m = p.meta || {};
  document.getElementById("rmeta").innerHTML =
    `<b>${(m.scenarios_added || []).length}</b> new scenario(s) &nbsp;&middot;&nbsp; ` +
    `<b>${(m.scenarios_replaced || []).length}</b> changed scenario(s) &nbsp;&middot;&nbsp; ` +
    `<b>${(m.undefined_steps || []).length}</b> step(s) got new java glue` +
    ((m.undefined_steps || []).length ? " — look for <b>// TODO QA: verify locator</b> markers in the java below" : "");
  const wrap = document.getElementById("rfiles");
  wrap.innerHTML = "";
  const addEditor = (label, tag, key, content) => {
    const div = document.createElement("div"); div.className = "rfile";
    const head = document.createElement("div"); head.className = "fhead";
    head.innerHTML = `<span class="ftag">${tag}</span> ${esc(label)}`;
    const ta = document.createElement("textarea");
    ta.className = "code"; ta.spellcheck = false; ta.value = content;
    ta.dataset.key = key;
    div.appendChild(head); div.appendChild(ta); wrap.appendChild(div);
  };
  addEditor("merged feature file (will replace the framework copy)", "feature", "__feature__", p.feature_text || "");
  for (const [rel, code] of Object.entries(p.files || {}))
    addEditor(rel, rel.includes("stepDefinitions") ? "steps" : "page/java", rel, code);
  document.getElementById("reviewcard").style.display = "block";
  document.getElementById("reviewcard").scrollIntoView({behavior: "smooth"});
  toast("AI changes are ready — review, edit if needed, then approve.");
}

async function approve(){
  const files = {}; let feature = null;
  document.querySelectorAll("#rfiles textarea.code").forEach(ta => {
    if (ta.dataset.key === "__feature__") feature = ta.value;
    else files[ta.dataset.key] = ta.value;
  });
  const r = await fetch(API + `/jobs/${job}/approve`, {
    method: "POST", headers: {"Content-Type": "application/json"},
    body: JSON.stringify({feature_text: feature, files})});
  const d = await r.json();
  if (r.status === 422){
    toast("Edited java does not compile — see console for errors.");
    const c = document.getElementById("console");
    c.textContent += "\n" + (d.detail || ""); c.scrollTop = c.scrollHeight;
    return;                                   // stay in review, user can fix
  }
  if (!r.ok){ toast(d.detail || "Approve failed"); return; }
  document.getElementById("reviewcard").style.display = "none";
  document.getElementById("stopbtn").style.display = "block";
  setBadge("running");
  timer = setInterval(poll, 1500);
}

async function discard(){
  const r = await fetch(API + `/jobs/${job}/discard`, {method: "POST"});
  if (r.ok){
    document.getElementById("reviewcard").style.display = "none";
    setBadge("discarded");
    document.getElementById("runbtn").disabled = false;
    toast("Changes discarded — the framework was not modified.");
  }
}

function esc(x){ return String(x ?? "").replace(/[&<>"]/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;"}[c])); }

loadTxns();
