"""Chat endpoints: standard (full reply) and streaming (SSE)."""

import json
import logging
from collections.abc import Iterator

from fastapi import APIRouter, HTTPException
from fastapi.responses import StreamingResponse

from .azure_client import AzureClientError, get_chat_completion, stream_chat_completion
from .models import ChatRequest, ChatResponse, ErrorResponse

logger = logging.getLogger(__name__)

router = APIRouter(tags=["chat"])

_ERROR_RESPONSES = {
    400: {"model": ErrorResponse},
    401: {"model": ErrorResponse},
    404: {"model": ErrorResponse},
    429: {"model": ErrorResponse},
    502: {"model": ErrorResponse},
    503: {"model": ErrorResponse},
}


@router.post(
    "/chat",
    response_model=ChatResponse,
    responses=_ERROR_RESPONSES,
    summary="Ask the AI coding assistant a question (full reply at once)",
)
def chat(request: ChatRequest) -> ChatResponse:
    """Send the user's message (plus optional history) to Azure OpenAI.

    Returns the assistant's complete Markdown-formatted reply. Errors are
    mapped to meaningful HTTP status codes with human-readable messages.
    """
    logger.info("Received chat message (%d chars).", len(request.message))

    try:
        reply = get_chat_completion(
            message=request.message,
            history=[m.model_dump() for m in request.history],
        )
    except AzureClientError as exc:
        raise HTTPException(status_code=exc.status_code, detail=exc.message) from exc
    except Exception:  # noqa: BLE001 - final safety net
        logger.exception("Unexpected error while generating a reply.")
        raise HTTPException(
            status_code=500,
            detail="An unexpected server error occurred. Please try again.",
        ) from None

    return ChatResponse(response=reply)


@router.post(
    "/chat/stream",
    summary="Ask the AI coding assistant a question (streamed reply)",
    response_description=(
        "A Server-Sent Events stream. Each event is a line of the form "
        '`data: {"delta": "..."}`; the stream ends with `data: [DONE]`. '
        'Failures are reported as `data: {"error": "..."}`.'
    ),
)
def chat_stream(request: ChatRequest) -> StreamingResponse:
    """Stream the assistant's reply incrementally using Server-Sent Events."""
    logger.info("Received streaming chat message (%d chars).", len(request.message))

    history = [m.model_dump() for m in request.history]

    def event_source() -> Iterator[str]:
        try:
            for delta in stream_chat_completion(request.message, history):
                yield f"data: {json.dumps({'delta': delta})}\n\n"
            yield "data: [DONE]\n\n"
        except AzureClientError as exc:
            # The HTTP status is already 200 once streaming starts, so
            # errors are delivered as a data event the client understands.
            yield f"data: {json.dumps({'error': exc.message})}\n\n"
        except Exception:  # noqa: BLE001 - final safety net
            logger.exception("Unexpected error during streaming reply.")
            yield (
                "data: "
                + json.dumps(
                    {"error": "An unexpected server error occurred. Please try again."}
                )
                + "\n\n"
            )

    return StreamingResponse(
        event_source(),
        media_type="text/event-stream",
        headers={
            "Cache-Control": "no-cache",
            "X-Accel-Buffering": "no",  # disable buffering behind nginx-style proxies
        },
    )
