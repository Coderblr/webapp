"""Platform configuration.

All secrets are read from environment variables (or an optional .env file).
Nothing sensitive is ever returned unmasked to the frontend or written to logs.
"""
import os
import json
from pathlib import Path

try:
    from dotenv import load_dotenv
    load_dotenv()
except ImportError:
    pass

BASE_DIR = Path(__file__).resolve().parent.parent
DATA_DIR = Path(os.getenv("PLATFORM_DATA_DIR", BASE_DIR / "data"))
DATA_DIR.mkdir(parents=True, exist_ok=True)
ARTIFACTS_DIR = DATA_DIR / "artifacts"          # screenshots, DOM snapshots, videos
ARTIFACTS_DIR.mkdir(exist_ok=True)
SETTINGS_FILE = DATA_DIR / "settings.json"       # non-secret, UI-editable settings

DB_URL = os.getenv("PLATFORM_DB_URL", f"sqlite:///{DATA_DIR / 'platform.db'}")

# ---- Azure OpenAI (secrets: env only) ----------------------------------
AZURE_OPENAI_ENDPOINT = os.getenv("AZURE_OPENAI_ENDPOINT", "")
AZURE_OPENAI_API_KEY = os.getenv("AZURE_OPENAI_API_KEY", "")
AZURE_OPENAI_DEPLOYMENT = os.getenv("AZURE_OPENAI_DEPLOYMENT", "")
AZURE_OPENAI_API_VERSION = os.getenv("AZURE_OPENAI_API_VERSION", "2024-06-01")


def mask_secret(value: str, show: int = 4) -> str:
    """Mask a secret for display: 'sk-abc...wxyz' style."""
    if not value:
        return ""
    if len(value) <= show * 2:
        return "*" * len(value)
    return f"{value[:show]}{'*' * 8}{value[-show:]}"


