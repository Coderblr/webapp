    function pollLiveStatus() {
        if (!liveId) return;
        fetch(`${API_BASE}/api/recorder/live/status/${liveId}`)
            .then(res => res.json())
            .then(data => {
                document.getElementById('live-step-count').textContent = data.count || 0;
                const feed = document.getElementById('live-feed');
                if (!data.steps || data.steps.length === 0) {
                    feed.innerHTML = '<div style="color:#666;">Waiting for interactions on the target site…</div>';
                    return;
                }
                const icon = { click:'👆', input:'⌨️', select:'🔽', navigate:'🌐', keypress:'⏎' };
                feed.innerHTML = data.steps.map(s => {
                    const ic = icon[s.action] || '•';
                    const loc = s.locator_type ? `<span style="color:#48cfad">[${s.locator_type}]</span> ${escapeHtml(s.locator_value || '')}` : '';
                    const val = s.value ? ` <span style="color:#ffb300">= "${escapeHtml(String(s.value).substring(0,30))}"</span>` : '';
                    return `<div style="padding:2px 0;border-bottom:1px solid rgba(255,255,255,0.04)">`
                        + `<span style="color:#6c63ff">#${s.step_index}</span> ${ic} `
                        + `<b style="color:#e0e0ff">${s.action}</b> `
                        + `<span style="color:#a78bfa">${escapeHtml(s.element_name || '')}</span> ${loc}${val}</div>`;
                }).join('');
                feed.scrollTop = feed.scrollHeight;
            })
            .catch(() => {});
