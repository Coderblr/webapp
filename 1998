@app.get("/jobs/{job_id}/pending")
def job_pending(job_id: str):
    """The proposed changes for the in-browser review editor."""
    job = executor.JOBS.get(job_id)
    if not job or job.status != "review" or not job.pending:
        raise HTTPException(404, "No changes awaiting review for this job.")
    p = job.pending
    hit = p.get("hit") or {}

    old_feature_text = ""
    if hit.get("feature"):
        try:
            old_feature_text = Path(hit["feature"]).read_text(encoding="utf-8", errors="ignore")
        except OSError:
            pass

    old_files: dict[str, str | None] = {}
    for rel in p["files"]:
        f = config.JAVA_SRC_ROOT / rel
        if f.exists():
            try:
                old_files[rel] = f.read_text(encoding="utf-8", errors="ignore")
            except OSError:
                old_files[rel] = None
        else:
            old_files[rel] = None  # brand-new file — every line is "added"

    return {
        "feature_text": p["feature_text"], "files": p["files"], "meta": p["meta"],
        "old_feature_text": old_feature_text, "old_files": old_files,
        "match": {
            "txn": hit.get("txn"), "module": hit.get("module"),
            "confidence": p["meta"].get("matched_via_fallback_score"),  # None = direct/exact match
            "is_new_feature": not bool(hit.get("feature")),
        },
    }


