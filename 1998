"""
paths.py — Central path configuration.

Every path the backend needs (frontend static files, the java-framework
folder it generates code into, the SQLite database) is computed relative
to THIS file's location by default. That means: unzip the project
anywhere, on any drive, on Windows or Linux, and it just works — no more
hardcoded "f:/nbccca/...".

Every value can still be overridden with an environment variable if you
ever want the pieces to live in different places (e.g. a shared
java-framework repo checked out elsewhere).
"""
import os
from typing import Optional

# backend/  (the folder this file lives in)
BACKEND_DIR = os.path.dirname(os.path.abspath(__file__))

# Project root = the parent of backend/ — normally contains
# backend/, frontend/, java-framework/, chrome-extension/
PROJECT_ROOT = os.getenv("NBCCCA_ROOT", os.path.dirname(BACKEND_DIR))

# Frontend static files served by main.py
FRONTEND_DIR = os.getenv("FRONTEND_DIR", os.path.join(PROJECT_ROOT, "frontend"))

# Java framework the AI agents generate/compile/run code in
JAVA_FRAMEWORK_DIR = os.getenv("JAVA_FRAMEWORK_PATH", os.path.join(PROJECT_ROOT, "java-framework"))
JAVA_FRAMEWORK_SRC = os.path.join(JAVA_FRAMEWORK_DIR, "src")
JAVA_FRAMEWORK_TARGET = os.path.join(JAVA_FRAMEWORK_DIR, "target")

# ─────────────────────────────────────────────────────────────────────────────
# Real framework structure — confirmed from the working java-orchestrator
# tool's config.py, which documents the ACTUAL layout (not a Maven-standard
# guess). Everything test-related — pages, step definitions, features, utils —
# lives under src/test/, not src/main/:
#   Pages:      <root>/src/test/java/com/nbc/pages/<module>/
#   Steps:      <root>/src/test/java/com/nbc/stepDefinitions/<module>/   (not "steps")
#   Features:   <root>/src/test/features/<module>/                       (not under resources/)
#   Utils:      <root>/src/test/java/com/nbc/utils/
#   Properties: <root>/src/test/resources/data/<environment>/common.properties
#               keys inside: baseUrl, makerID, makerPassword, checkerID, checkerPassword
# Known modules: batch, cash, cif, common, deposits, fileUpload, gl, healthCheck,
# loans, ndvp, parameters, sdv
# ─────────────────────────────────────────────────────────────────────────────
JAVA_PAGES_DIR = os.path.join(JAVA_FRAMEWORK_SRC, "test", "java", "com", "nbc", "pages")
JAVA_STEPS_DIR = os.path.join(JAVA_FRAMEWORK_SRC, "test", "java", "com", "nbc", "stepDefinitions")
JAVA_FEATURES_DIR = os.path.join(JAVA_FRAMEWORK_SRC, "test", "features")
JAVA_UTILS_DIR = os.path.join(JAVA_FRAMEWORK_SRC, "test", "java", "com", "nbc", "utils")
PROPERTIES_DATA_ROOT = os.path.join(JAVA_FRAMEWORK_SRC, "test", "resources", "data")
NBC_MODULES = ["batch", "cash", "cif", "common", "deposits", "fileUpload", "gl",
               "healthCheck", "loans", "ndvp", "parameters", "sdv"]

# Older/Maven-standard locations — kept only as a fallback for anything created
# before this was corrected, so nothing already generated there goes missing.
JAVA_FEATURES_DIR_LEGACY = os.path.join(JAVA_FRAMEWORK_SRC, "test", "resources", "features")
JAVA_PAGES_DIR_LEGACY = os.path.join(JAVA_FRAMEWORK_SRC, "main", "java", "com", "nbc", "pages")
JAVA_STEPS_DIR_LEGACY = os.path.join(JAVA_FRAMEWORK_SRC, "test", "java", "com", "nbc", "steps")

# Local WebDriver binaries (msedgedriver.exe, etc.) for offline/restricted-network
# machines that can't auto-download drivers. Convention: <project root>/drivers/
DRIVERS_DIR = os.getenv("DRIVERS_DIR", os.path.join(PROJECT_ROOT, "drivers"))


def default_edge_driver_path() -> Optional[str]:
    """Returns the local msedgedriver path if it exists under drivers/, else None
    (callers should fall back to Selenium Manager's auto-download in that case)."""
    for name in ("msedgedriver.exe", "msedgedriver"):
        candidate = os.path.join(DRIVERS_DIR, name)
        if os.path.exists(candidate):
            return candidate
    return None


def default_database_url() -> str:
    """sqlite:///<absolute path to backend/knowledge_graph.db>, forward-slashed
    so it's a valid SQLAlchemy URL on both Windows and Linux."""
    db_path = os.path.join(BACKEND_DIR, "knowledge_graph.db").replace(os.sep, "/")
    return f"sqlite:///{db_path}"


# Property key aliases: real key name <-> the generic/dotted name this codebase
# also uses in a few places. Populating both directions means callers can look
# up either name and always get a value if one form is present in the file.
_PROPERTY_ALIASES = {
    "baseUrl": "url", "url": "baseUrl",
    "makerID": "maker.username", "maker.username": "makerID",
    "makerPassword": "maker.password", "maker.password": "makerPassword",
    "checkerID": "checker.username", "checker.username": "checkerID",
    "checkerPassword": "checker.password", "checker.password": "checkerPassword",
}


def read_config_properties(environment: str = None) -> dict:
    """
    Reads the real per-environment properties file:
        java-framework/src/test/resources/data/<environment>/common.properties
    (keys inside: baseUrl, makerID, makerPassword, checkerID, checkerPassword, ...)

    environment defaults to the NBC_ENV env var, then "preprod", then "uat" —
    whichever is found first. Falls back to the older flat
    java-framework/src/main/resources/config.properties if neither per-
    environment file exists, so nothing already set up that way breaks.

    Every value is returned under BOTH its real key name and the equivalent
    dotted alias (see _PROPERTY_ALIASES) — callers can use either without
    needing to know which convention the actual file uses.
    """
    candidates = []
    env_order = [environment] if environment else [os.getenv("NBC_ENV"), "preprod", "uat"]
    for env in env_order:
        if env:
            candidates.append(os.path.join(PROPERTIES_DATA_ROOT, env, "common.properties"))
    # Legacy fallback: the older single flat file this project used before the
    # real per-environment structure was confirmed.
    candidates.append(os.path.join(JAVA_FRAMEWORK_SRC, "main", "resources", "config.properties"))

    values = {}
    config_path = next((c for c in candidates if os.path.exists(c)), None)
    if not config_path:
        return values

    try:
        with open(config_path, "r") as f:
            for line in f:
                line = line.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue
                key, _, value = line.partition("=")
                values[key.strip()] = value.strip()
    except Exception:
        return values

    for key, alias in list(_PROPERTY_ALIASES.items()):
        if key in values and alias not in values:
            values[alias] = values[key]
    return values
