        raise HTTPException(status_code=500, detail=f"Import failed: {e}")


@app.post("/api/framework/upload")
async def upload_existing_framework(file: UploadFile = File(...)):
    """
    Upload a .zip of an existing framework (Page Objects, Step Definitions,
    Feature files — any folder layout). Extracts it, sorts recognizable Java/
    feature files into this project's java-framework/src/ (matching how
    java-framework is actually laid out here), then runs the same import
    used by /api/framework/import so the knowledge graph picks it up too.
    """
    if not file.filename or not file.filename.lower().endswith(".zip"):
        raise HTTPException(status_code=400, detail="Please upload a .zip file of the existing framework.")

    import zipfile
    import tempfile
    import shutil

    pages_dest = JAVA_PAGES_DIR
    steps_dest = JAVA_STEPS_DIR
    features_dest = JAVA_FEATURES_DIR
    os.makedirs(pages_dest, exist_ok=True)
    os.makedirs(steps_dest, exist_ok=True)
    os.makedirs(features_dest, exist_ok=True)

    tmp_dir = tempfile.mkdtemp(prefix="fw_upload_")
    zip_path = os.path.join(tmp_dir, "upload.zip")
    copied = {"pages": [], "steps": [], "features": []}
    skipped = []

    try:
        with open(zip_path, "wb") as f:
            f.write(await file.read())

        extract_dir = os.path.join(tmp_dir, "extracted")
        os.makedirs(extract_dir, exist_ok=True)

        try:
            with zipfile.ZipFile(zip_path, "r") as zf:
                # zip-slip guard: refuse any entry that would extract outside extract_dir
                for member in zf.namelist():
                    member_path = os.path.normpath(os.path.join(extract_dir, member))
                    if not member_path.startswith(os.path.normpath(extract_dir) + os.sep) and member_path != os.path.normpath(extract_dir):
                        raise HTTPException(status_code=400, detail=f"Unsafe path in zip: {member}")
                zf.extractall(extract_dir)
        except zipfile.BadZipFile:
            raise HTTPException(status_code=400, detail="That file isn't a valid .zip archive.")

        # Walk everything extracted, sort recognizable files by path/extension.
        # Path-substring matching (not exact package names) so this works
        # regardless of the original project's package naming.
        #
        # IMPORTANT: each file is placed according to its OWN declared
        # "package x.y.z;" line, not flattened into one folder — a Java file
        # declaring package com.nbc.pages.common MUST physically live under
        # .../pages/common/, or javac rejects it with a package/directory
        # mismatch. Falls back to the flat pages/steps folder only if a file
        # has no package declaration at all. Both pages AND steps are rooted
        # under test/java — the real framework never uses main/java.
        test_java_dir = os.path.join(JAVA_FRAMEWORK_SRC, "test", "java")

        for root, _dirs, files in os.walk(extract_dir):
            if "__MACOSX" in root:
                continue
            lower_root = root.lower()
            for fname in files:
                src_path = os.path.join(root, fname)

                if fname.endswith(".java") and "page" in lower_root:
                    with open(src_path, "r", encoding="utf-8", errors="ignore") as f:
                        content = f.read()
                    package = detect_java_package(content)
                    dest_dir = package_to_dir(test_java_dir, package) if package else pages_dest
                    os.makedirs(dest_dir, exist_ok=True)
                    shutil.copy2(src_path, os.path.join(dest_dir, fname))
                    copied["pages"].append(fname)
                elif fname.endswith(".java") and "step" in lower_root:
                    with open(src_path, "r", encoding="utf-8", errors="ignore") as f:
                        content = f.read()
                    package = detect_java_package(content)
                    dest_dir = package_to_dir(test_java_dir, package) if package else steps_dest
                    os.makedirs(dest_dir, exist_ok=True)
                    shutil.copy2(src_path, os.path.join(dest_dir, fname))
                    copied["steps"].append(fname)
                elif fname.endswith(".feature"):
                    dest = os.path.join(features_dest, fname)
                    shutil.copy2(src_path, dest)
                    copied["features"].append(fname)
                elif fname.endswith(".java"):
                    # A .java file that's neither clearly a page nor a step —
                    # skip it rather than guess wrong.
                    skipped.append(fname)

    finally:
        shutil.rmtree(tmp_dir, ignore_errors=True)

    total_copied = len(copied["pages"]) + len(copied["steps"]) + len(copied["features"])
    if total_copied == 0:
        raise HTTPException(
            status_code=400,
            detail="No recognizable Page Object (.java in a 'pages' folder), Step Definition "
                   "(.java in a 'steps' folder), or .feature files were found in that zip."
        )

    # Now run the same import used by the one-touch button, so the knowledge
    # graph picks up everything that was just copied in.
    agent = FrameworkImportAgent()
    try:
        import_result = agent.import_all()
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Files were copied but import failed: {e}")

    import_result["files_copied"] = copied
    import_result["files_skipped"] = skipped
    import_result["message"] = (
        f"Copied {len(copied['pages'])} page file(s), {len(copied['steps'])} step file(s), "
        f"{len(copied['features'])} feature file(s) into java-framework, then " + import_result["message"]
    )
    return import_result


@app.post("/api/framework/fix-packages")
def fix_package_structure():
    """
    Repairs Page Object / Step Definition files that were flattened into a single
    folder by an earlier version of the importer, regardless of their own
    'package x.y.z;' declaration — the cause of "Package declaration X does not
    match directories path" compile errors. Moves each mismatched file to the
    directory its own package declaration requires. Safe to run any time —
    files already in the right place are left untouched.
    """
    agent = FrameworkImportAgent()
    try:
        return agent.fix_package_structure()
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Repair failed: {e}")


@app.post("/api/framework/clear")
def clear_uploaded_framework(confirm: bool = False):
    """
    DESTRUCTIVE. Deletes every uploaded/imported Page Object, Step Definition,
    and Feature file from disk, and clears the matching knowledge-graph rows —
    so a fresh upload/import starts completely clean. The hand-built common
    layer (LoginPage.java, DashboardPage.java, CommonSteps.java) is protected
    and never deleted, no matter which folder it's in.

    Requires confirm=true — a safety check independent of whatever confirmation
    the frontend already asks for, so this can never fire from a stray request.
    """
    if not confirm:
        raise HTTPException(
            status_code=400,
            detail="This deletes uploaded framework files and clears the knowledge graph. "
                   "Call again with confirm=true to proceed."
        )
    agent = FrameworkImportAgent()
    try:
        return agent.clear_uploaded_framework()
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Clear failed: {e}")


