            ? table(["Scenario", "Root cause", "Explanation", "Business impact",
                "Confidence", "Recommendation"],
              rca.map(function (x) {
                return h("tr", null, h("td", null, x.scenario),
                  h("td", null, badge("bad", x.root_cause)),
                  h("td", null, x.explanation), h("td", null, x.business_impact),
                  h("td", null, x.confidence), h("td", null, x.recommendation));
              }))
            : muted("No failures analyzed yet.")),
        ]);
      });
    return wrap;
  }

  /* ================= 10. UI version comparison ================= */
  function UIChangesPage() {
    var wrap = h("div", null);
    var list = h("div", null);
    var timeline = h("div", { class: "panel" });
    function load() {
      api.get("/api/ui/changes").then(function (changes) {
        clear(list);
        (changes || []).forEach(function (c) {
          var counts = ["added", "removed", "renamed", "moved", "changed_attributes"]
            .map(function (k) {
              return h("div", { class: "card" },
                h("div", { class: "num" }, ((c.diff || {})[k] || []).length),
                h("div", { class: "lbl" }, k.replace(/_/g, " ")));
            });
          var affected = ((c.impacted || {}).affected_transactions || []);
          var applyBtn = (role !== "Viewer" && c.status !== "updates_applied" &&
            affected.length > 0) ? h("button", {
              class: "primary", onclick: function () {
                api.post("/api/ui/changes/" + c.id + "/apply").then(load);
              },
            }, "Apply targeted updates") : null;
          append(list, h("div", { class: "panel" },
            h("b", null, c.screen), " ",
            badge("info", "v" + c.from + " → v" + c.to), " ",
            statusBadge(c.status === "updates_applied" ? "success" : "running"),
            h("span", { class: "muted" },
              " · visual diff " + c.visual_score + "% · " + c.at),
            c.summary ? h("p", null, c.summary) : null,
            h("div", { class: "cards" }, counts),
            muted("Impacted transactions: " + (affected.join(", ") || "none")),
            applyBtn));
        });
      });
      api.get("/api/ui/versions").then(function (versions) {
        clear(timeline);
        append(timeline, table(["Screen", "Version", "Source", "Captured"],
          (versions || []).map(function (v) {
            return h("tr", null, h("td", null, v.screen), h("td", null, "v" + v.version),
              h("td", null, badge("info", v.source)),
              h("td", { class: "muted" }, v.at));
          })));
      });
    }
    append(wrap, [h("div", { class: "topbar" }, h("h1", null, "UI version comparison")),
      list, h("h2", null, "Screen version timeline"), timeline]);
    load();
    return wrap;
  }

  /* ================= 11. Settings ================= */
  function SettingsPage() {
    var wrap = h("div", null, muted("Loading…"));
    api.get("/api/settings").then(function (data) {
      clear(wrap);
      var f = data.settings;
      function field(label, key, placeholder) {
        var inp = h("input", {
          type: "text", value: f[key] || "", placeholder: placeholder || "",
          oninput: function (e) { f[key] = e.target.value; },
        });
        return [h("label", null, label), inp];
      }
      var headSel = h("select", {
        onchange: function (e) { f.default_headless = e.target.value === "1"; },
      },
        h("option", { value: "0", selected: !f.default_headless },
          "Live — visible Edge window (recommended)"),
        h("option", { value: "1", selected: !!f.default_headless }, "Headless"));
      var conf = h("input", {
        type: "number", step: "0.05", min: "0", max: "1",
        value: f.ai_confidence_threshold,
        oninput: function (e) { f.ai_confidence_threshold = parseFloat(e.target.value); },
      });
      var masks = h("input", {
        type: "text", value: (f.mask_fields || []).join(", "),
        oninput: function (e) {
          f.mask_fields = e.target.value.split(",").map(function (s) { return s.trim(); });
        },
      });
      var edgeInfo = h("p", { class: "mono" });
      var ai = data.ai;
      append(wrap, [
        h("div", { class: "topbar" }, h("h1", null, "Settings")),
        h("div", { class: "panel" },
          h("h2", null, "Framework & browser"),
          field("Java framework path — the framework is CREATED and stored here",
            "framework_path", "C:\\automation\\bank-framework"),
          field("EdgeDriver path (msedgedriver)", "edgedriver_path"),
          field("Edge browser binary path (optional)", "edge_binary_path"),
          field("JAVA_HOME (blank = java/javac on PATH) — pure JDK runner, no Maven",
            "java_home"),
          field("Jars folder (blank = <framework>/libs — populate with scripts/get-libs)",
            "libs_path"),
          field("Cucumber glue package", "glue_package"),
          h("label", null, "Default run mode"), headSel,
          h("div", { style: { marginTop: "12px" } },
            h("button", {
              class: "ghost", onclick: function () {
                api.get("/api/edge/versions").then(function (e) {
                  clear(edgeInfo);
                  append(edgeInfo, ["Edge: " + (e.edge || "not detected") +
                    " · Driver: " + (e.driver || "not detected") + " · ",
                  e.match === true ? badge("ok", "versions match")
                    : e.match === false ? badge("bad", "version mismatch")
                      : badge("warn", "unknown")]);
                });
              },
            }, "Check Edge / EdgeDriver versions"),
            h("button", {
              class: "ghost", style: { marginLeft: "8px" }, onclick: function () {
                api.post("/api/framework/scaffold", {}).then(function (r) {
                  alert(r.already_scaffolded
                    ? "Framework already exists — nothing overwritten."
                    : "Framework created at " + r.root + "\n\n" + r.created.length +
                      " files: DriverFactory, Hooks, LocatorRepository, ConfigReader, " +
                      "run scripts.\n\nNext: populate libs/ with scripts/get-libs.");
                }).catch(function (e) { alert(e.message); });
              },
            }, "Create framework skeleton (JDK-only)"),
            h("button", {
              class: "ghost", style: { marginLeft: "8px" }, onclick: function (e) {
                var b = e.target; b.disabled = true; b.textContent = "Repairing\u2026";
                api.post("/api/framework/repair", {}).then(function (r) {
                  var lines = [r.summary, ""];
                  (r.renamed || []).forEach(function (x) {
                    lines.push("renamed: " + x.from + " -> " + x.to); });
                  (r.fixed || []).forEach(function (x) {
                    lines.push(x.file + ": " + x.fixes.join(", ")); });
                  (r.needs_attention || []).forEach(function (x) {
                    lines.push("MANUAL: " + x.file + " - " + x.problems.join(", ")); });
                  alert(lines.join("\n"));
                }).catch(function (err) { alert(err.message); })
                  .then(function () {
                    b.disabled = false; b.textContent = "Repair generated code"; });
              },
            }, "Repair generated code"),
            edgeInfo)),
        h("div", { class: "panel" },
          h("h2", null, "Azure OpenAI"),
          h("p", { class: "mono" },
            "Endpoint: " + (ai.endpoint || "not set"), h("br"),
            "Deployment: " + (ai.deployment || "not set"), h("br"),
            "API version: " + ai.api_version, h("br"),
            "API key: " + (ai.api_key_masked || "not set") + " ",
            ai.configured ? badge("ok", "configured") : badge("bad", "missing")),
          muted("Credentials are read from environment variables on the server " +
            "and are never shown unmasked or written to logs."),
          h("label", null, "AI confidence threshold"), conf),
        h("div", { class: "panel" },
          h("h2", null, "Pre-recording flow (login \u2192 password change \u2192 re-login)"),
          muted("Runs automatically before every recording so capture starts on the " +
            "home screen. These actions are NOT recorded as part of the transaction."),
          h("label", null, "Enable pre-recording login flow"),
          h("select", {
            onchange: function (e) { f.prelogin_enabled = e.target.value === "1"; },
          },
            h("option", { value: "0", selected: !f.prelogin_enabled }, "Disabled"),
            h("option", { value: "1", selected: !!f.prelogin_enabled }, "Enabled")),
          field("Test URL (used by 'Test pre-login flow')", "prelogin_test_url"),
          field("User ID (or set env NBC_USER_ID)", "prelogin_user_id"),
          field("Current password (or env NBC_PASSWORD) \u2014 stored masked",
            "prelogin_password"),
          field("New password for forced change (or env NBC_NEW_PASSWORD)",
            "prelogin_new_password"),
          muted("Credentials are masked in this screen and never written to logs. " +
            "Environment variables take priority. After a successful change the " +
            "platform swaps the two passwords so repeat runs never lock the user out."),
          h("h2", null, "Login / password-change locators"),
          field("Login \u2014 user field", "login_user_locator"),
          field("Login \u2014 password field", "login_password_locator"),
          field("Login \u2014 submit button", "login_submit_locator"),
          field("Password change \u2014 old password", "pwd_old_locator"),
          field("Password change \u2014 new password", "pwd_new_locator"),
          field("Password change \u2014 confirm password", "pwd_confirm_locator"),
          field("Password change \u2014 submit", "pwd_submit_locator"),
          field("Success alert \u2014 OK button", "pwd_alert_ok_locator"),
          field("Home screen ready element (optional)", "home_ready_locator"),
          field("Spinner / loading overlay", "spinner_locator"),
          h("label", null, "Seconds to wait for the password-change screen after login"),
          h("input", {
            type: "number", min: "5", max: "120",
            value: f.pwd_screen_wait_seconds || 20,
            oninput: function (e) {
              f.pwd_screen_wait_seconds = parseInt(e.target.value, 10) || 20; },
          }),
          muted("Format: id=elementId, name=x, css=.sel, xpath=//x (bare value = xpath)"),
          h("div", { style: { marginTop: "12px" } },
            h("button", {
              class: "ghost", onclick: function (e) {
                var b = e.target; b.disabled = true; b.textContent = "Running\u2026";
                api.post("/api/prelogin/test", {}).then(function (r) {
                  var msg = "Pre-login test\n\n" + (r.log || []).join("\n") +
                    "\n\nLogged in: " + r.logged_in +
                    "\nPassword changed: " + r.password_changed +
                    "\nRe-login: " + r.relogin;
                  if (r.page_after_login) {
                    var p = r.page_after_login;
                    msg += "\n\n--- Page after login ---\n" + p.title +
                      "\n" + p.url + "\niframes: " + p.frames +
                      "\ninputs: " + (p.inputs || []).join(", ") +
                      "\nbuttons: " + (p.buttons || []).join(", ");
                  }
                  alert(msg);
                }).catch(function (err) { alert(err.message); })
                  .then(function () { b.disabled = false; b.textContent = "Test pre-login flow"; });
              },
            }, "Test pre-login flow"),
            h("button", {
              class: "ghost", style: { marginLeft: "8px" }, onclick: function (e) {
                var b = e.target; b.disabled = true; b.textContent = "Detecting\u2026";
                api.post("/api/prelogin/detect", {}).then(function (r) {
                  var lines = ["Detected login form:", "",
                    "user field : " + (r.user || "not found"),
                    "password   : " + (r.password || "not found"),
                    "submit     : " + (r.submit || "not found"), "",
                    "All visible inputs:"];
                  (r.all_inputs || []).forEach(function (i) {
                    lines.push("  " + i.locator + "  (type=" + i.type +
                      (i.placeholder ? ", placeholder=" + i.placeholder : "") + ")");
                  });
                  lines.push("", "Buttons:");
                  (r.all_buttons || []).forEach(function (i) {
                    lines.push("  " + i.locator + "  \"" + i.text + "\"");
                  });
                  lines.push("", "Copy the right ones into the locator fields below, then Save.");
                  alert(lines.join("\n"));
                }).catch(function (err) { alert(err.message); })
                  .then(function () {
                    b.disabled = false; b.textContent = "Detect login fields"; });
              },
            }, "Detect login fields"))),
        h("div", { class: "panel" },
          h("h2", null, "Data masking"),
          h("label", null, "Masked field keywords (comma-separated)"), masks),
        role === "Viewer" ? null : h("button", {
          class: "primary", onclick: function () {
            api.post("/api/settings", f).then(function () { toast("Settings saved"); });
          },
        }, "Save settings"),
      ]);
