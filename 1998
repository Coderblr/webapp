/* ── vanilla-JS line diff (LCS-based) — highlights added/removed lines ─── */
function diffLines(oldText, newText){
  const a = oldText ? oldText.split("\n") : [];
  const b = newText ? newText.split("\n") : [];
  const n = a.length, m = b.length;
  const dp = Array.from({length: n + 1}, () => new Int32Array(m + 1));
  for (let i = n - 1; i >= 0; i--)
    for (let j = m - 1; j >= 0; j--)
      dp[i][j] = a[i] === b[j] ? dp[i+1][j+1] + 1 : Math.max(dp[i+1][j], dp[i][j+1]);
  const ops = [];
  let i = 0, j = 0;
  while (i < n && j < m){
    if (a[i] === b[j]){ ops.push({type:"same", line:a[i]}); i++; j++; }
    else if (dp[i+1][j] >= dp[i][j+1]){ ops.push({type:"removed", line:a[i]}); i++; }
    else { ops.push({type:"added", line:b[j]}); j++; }
  }
  while (i < n){ ops.push({type:"removed", line:a[i]}); i++; }
  while (j < m){ ops.push({type:"added", line:b[j]}); j++; }
  return ops;
}

async function approve(){
  const files = {}; let feature = null;
  document.querySelectorAll("#rfiles textarea.code").forEach(ta => {
    if (ta.dataset.key === "__feature__") feature = ta.value;
    else files[ta.dataset.key] = ta.value;
  });
  const r = await fetch(API + `/jobs/${job}/approve`, {
    method: "POST", headers: {"Content-Type": "application/json"},
    body: JSON.stringify({feature_text: feature, files})});
  const d = await r.json();
  if (r.status === 422){
    toast("Edited java does not compile — see console for errors.");
    const c = document.getElementById("console");
    c.textContent += "\n" + (d.detail || ""); c.scrollTop = c.scrollHeight;
    return;                                   // stay in review, user can fix
  }
  if (!r.ok){ toast(d.detail || "Approve failed"); return; }
  document.getElementById("reviewcard").style.display = "none";
  document.getElementById("stopbtn").style.display = "block";
  setBadge("running");
  timer = setInterval(poll, 1500);
}

async function discard(){
  const r = await fetch(API + `/jobs/${job}/discard`, {method: "POST"});
  if (r.ok){
    document.getElementById("reviewcard").style.display = "none";
    setBadge("discarded");
    document.getElementById("runbtn").disabled = false;
    toast("Changes discarded — the framework was not modified.");
  }
}

function esc(x){ return String(x ?? "").replace(/[&<>"]/g, c => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;"}[c])); }

/* ── CR Pipeline (multi-transaction BRD change request) ─────────────── */
let crRun = null, crOffset = 0, crTimer = null, crReportData = null;

const CR_BADGE = {queued:"idle", searching:"running", comparing:"running", merging:"running",
  dry_run:"running", generating:"running", staged:"review", unchanged:"passed",
  not_found:"failed", locator_required:"failed", failed:"failed", skipped:"idle",
  committing:"running", ready:"review", executing:"running", passed:"passed",
  exec_failed:"failed", stopped:"stopped", error:"failed"};

function esc(s){ return String(s == null ? "" : s).replace(/[&<>"]/g,
  c => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;"}[c])); }

function startCr(d){
  crRun = d.cr_run_id; crOffset = 0; crReportData = null;
  document.getElementById("crcard").style.display = "";
  document.getElementById("crreview").style.display = "none";
  document.getElementById("crreport").style.display = "none";
  document.getElementById("crconsole").textContent = "";
  document.getElementById("crcard").scrollIntoView({behavior:"smooth"});
  crRender(d);
  if (crTimer) clearInterval(crTimer);
  crTimer = setInterval(crPoll, 1500);
}

async function crPoll(){
  try{
    const lg = await (await fetch(API + `/cr/${crRun}/logs?offset=${crOffset}`)).json();
    if (lg.log){
      const c = document.getElementById("crconsole");
      c.textContent += lg.log; crOffset = lg.offset; c.scrollTop = c.scrollHeight;
    }
    const d = await (await fetch(API + `/cr/${crRun}`)).json();
    crRender(d);
    if (d.status === "review" && document.getElementById("crreview").style.display === "none")
      crLoadReview();
    if (["ready","done","error","discarded"].includes(d.status)){
      clearInterval(crTimer); crTimer = null;
      if (d.status === "error") toast(d.error || "CR pipeline error");
      else crLoadReport();
    }
  }catch(e){}
}

function crRender(d){
  const badgeCls = {analyzing:"running", processing:"running", review:"review",
                    committing:"running", ready:"review", executing:"running",
                    done:"passed", error:"failed",
                    discarded:"discarded"}[d.status] || "idle";
  const st = document.getElementById("crstatus");
  st.textContent = d.status; st.className = "badge " + badgeCls;
  document.getElementById("crmeta").textContent =
    ` — ${esc(d.brd)}${d.cr_number ? " · CR " + esc(d.cr_number) : ""}` +
    `${d.parent_cr ? " (parent " + esc(d.parent_cr) + ")" : ""}` +
    ` · ${d.transactions.length} transaction(s)`;
  const canLaunch = ["ready","done"].includes(d.status);
  const nReady = d.transactions.filter(t => ["ready","stopped","exec_failed"].includes(t.status)).length;
  document.getElementById("crrunall").style.display = (canLaunch && nReady) ? "" : "none";
  document.getElementById("crrunall").textContent = `\u25B6\u00A0 Run all ready (${nReady})`;
  document.getElementById("crstop").style.display = d.status === "executing" ? "" : "none";
  if (!d.transactions.length){ document.getElementById("crtable").innerHTML = ""; return; }
  document.getElementById("crtable").innerHTML =
    `<table style="width:100%;border-collapse:collapse;font-size:13px">
     <tr style="text-align:left;color:var(--muted)">
       <th style="padding:6px 10px">Txn</th><th>Module</th><th>Status</th>
       <th>+Scen</th><th>~Scen</th><th>Java files</th><th>Notes / action required</th><th></th></tr>` +
    d.transactions.map(t => {
      const runnable = canLaunch && ["ready","stopped","exec_failed"].includes(t.status);
      return `<tr style="border-top:1px solid rgba(128,128,128,.2)">
       <td style="padding:6px 10px"><b>Txn${esc(t.txn)}</b></td>
       <td>${esc(t.module || "—")}</td>
       <td><span class="badge ${CR_BADGE[t.status] || "idle"}">${esc(t.status)}</span></td>
       <td>${t.scenarios_added.length}</td><td>${t.scenarios_replaced.length}</td>
       <td>${t.java_files.length}</td>
       <td style="max-width:380px;color:var(--muted)">${esc(t.action_required || t.error ||
          (t.exec_summary && t.exec_summary.scenarios_total != null
            ? `${t.exec_summary.scenarios_passed || 0}/${t.exec_summary.scenarios_total} scenarios passed` : ""))}</td>
       <td style="text-align:right;white-space:nowrap">${runnable
          ? `<button class="btn primary" style="padding:5px 12px;font-size:12px"
               onclick="crExec('${esc(t.txn)}')">\u25B6\u00A0 Run${t.status !== "ready" ? " again" : ""}</button>` : ""}</td>
     </tr>`; }).join("") + "</table>";
}

async function crExec(txn){
  const r = await fetch(API + `/cr/${crRun}/execute`, {method:"POST",
    headers:{"Content-Type":"application/json"},
    body: JSON.stringify({txns: txn ? [txn] : null})});
  const d = await r.json();
  if (!r.ok){ toast(d.detail || "Could not start execution"); return; }
  if (!crTimer) crTimer = setInterval(crPoll, 1500);
}

async function crStop(){
  const r = await fetch(API + `/cr/${crRun}/stop`, {method:"POST"});
  const d = await r.json();
  if (!r.ok){ toast(d.detail || "Nothing is executing"); return; }
  toast("Stopping — the current transaction is being killed; the rest stay ready.");
}

async function crLoadReview(){
  const d = await (await fetch(API + `/cr/${crRun}/pending`)).json();
  const box = document.getElementById("crstaged");
  box.innerHTML = d.staged.map((s, i) => `
    <div style="border:1px solid rgba(128,128,128,.25);border-radius:10px;padding:12px;margin-top:12px">
      <label class="check"><input type="checkbox" class="crchk" data-txn="${esc(s.txn)}" checked>
        <b>Txn${esc(s.txn)}</b> &nbsp;(${esc(s.module || "?")}) — ${s.scenarios_added.length} new,
        ${s.scenarios_replaced.length} changed scenario(s), ${Object.keys(s.files).length} java file(s)</label>
      <div class="sub" style="text-transform:none;letter-spacing:0;margin:6px 0">${esc(s.delta_notes).slice(0, 400)}</div>
      ${(s.warnings || []).length ? `<div style="background:#fff4e5;border:1px solid #ffcc80;color:#8a5a00;
          border-radius:8px;padding:8px 12px;margin:6px 0;font-size:12.5px">
          <b>&#9888; Review carefully before approving:</b>
          <ul style="margin:4px 0 0 18px;padding:0">
            ${s.warnings.map(w => `<li>${esc(w)}</li>`).join("")}
          </ul></div>` : ""}
      <details><summary style="cursor:pointer">Merged feature (editable)</summary>
        <textarea class="crfeat" data-txn="${esc(s.txn)}" spellcheck="false"
          style="width:100%;min-height:220px;font:12px ui-monospace,Consolas,monospace">${esc(s.feature_text)}</textarea>
      </details>
      ${Object.entries(s.files).map(([rel, code]) => `
        <details><summary style="cursor:pointer">${esc(rel)} (editable)</summary>
          <textarea class="crjava" data-txn="${esc(s.txn)}" data-rel="${esc(rel)}" spellcheck="false"
            style="width:100%;min-height:220px;font:12px ui-monospace,Consolas,monospace">${esc(code)}</textarea>
        </details>`).join("")}
    </div>`).join("") || `<div class="hintbox">Nothing staged — no framework changes required.</div>`;
  document.getElementById("cractions").innerHTML = d.action_items.length
    ? `<div class="hintbox" style="margin-top:12px"><b>Action items (isolated, did not stop the queue):</b><ul>`
      + d.action_items.map(a => `<li><b>Txn${esc(a.txn)}</b> (${esc(a.status)}): ${esc(a.action)}</li>`).join("")
      + `</ul></div>` : "";
  document.getElementById("crreview").style.display = "";
}

async function crApprove(){
  const approved = [...document.querySelectorAll(".crchk")].filter(c => c.checked).map(c => c.dataset.txn);
  const edits = {};
  document.querySelectorAll(".crfeat").forEach(t => {
    edits[t.dataset.txn] = edits[t.dataset.txn] || {files:{}};
    edits[t.dataset.txn].feature_text = t.value; });
  document.querySelectorAll(".crjava").forEach(t => {
    edits[t.dataset.txn] = edits[t.dataset.txn] || {files:{}};
    edits[t.dataset.txn].files[t.dataset.rel] = t.value; });
  const r = await fetch(API + `/cr/${crRun}/approve`, {method:"POST",
    headers:{"Content-Type":"application/json"},
    body: JSON.stringify({approved_txns: approved, edits})});
  const d = await r.json();
  if (!r.ok){ toast(d.detail || "Approve failed"); return; }
  document.getElementById("crreview").style.display = "none";
  toast("Committing approved changes — nothing runs until you press a Run button.");
  if (!crTimer) crTimer = setInterval(crPoll, 1500);
}

async function crDiscard(){
  const r = await fetch(API + `/cr/${crRun}/discard`, {method:"POST"});
  if (r.ok){ document.getElementById("crreview").style.display = "none";
    toast("CR discarded — framework untouched."); crPoll(); }
}

async function crLoadReport(){
  const rep = await (await fetch(API + `/cr/${crRun}/report`)).json();
  crReportData = rep;
  const kpi = (label, val, cls) => `<div class="kpi${cls ? " " + cls : ""}"><b>${esc(val)}</b><span>${esc(label)}</span></div>`;
  document.getElementById("crkpis").innerHTML =
    kpi("Overall", rep.overall_status, rep.overall_status === "PASSED" ? "p" : "f") +
    kpi("Identified", rep.transactions_identified.length) +
    kpi("Updated", rep.transactions_updated.length) +
    kpi("Unchanged", rep.transactions_unchanged.length) +
    kpi("Failed", rep.transactions_failed.length, rep.transactions_failed.length ? "f" : "") +
    kpi("Not run yet", (rep.transactions_pending_execution || []).length) +
    kpi("Skipped", rep.transactions_skipped.length) +
    kpi("Methods +", rep.methods_added_estimate) +
    kpi("Locators +", rep.locators_added_estimate);
  document.getElementById("crreportbody").innerHTML =
    (rep.transactions_failed.length ? `<div class="hintbox"><b>Failure summary:</b><ul>` +
      rep.transactions_failed.map(f => `<li><b>Txn${esc(f.txn)}</b>: ${esc(f.reason)}<br>
        <i>Recovery:</i> ${esc(f.recovery_action || "—")}${f.retried ? " (auto-retried once)" : ""}</li>`).join("")
      + `</ul></div>` : "") +
    (rep.feature_files_modified.length ? `<div class="sub" style="text-transform:none;letter-spacing:0;margin-top:8px">
      <b>Feature files modified:</b> ${rep.feature_files_modified.map(esc).join(" · ")}</div>` : "") +
    (rep.java_files_modified.length ? `<div class="sub" style="text-transform:none;letter-spacing:0;margin-top:4px">
      <b>Java files modified:</b> ${rep.java_files_modified.map(esc).join(" · ")}</div>` : "");
  document.getElementById("crreport").style.display = "";
}

function crDownload(){
  if (!crReportData) return;
  const blob = new Blob([JSON.stringify(crReportData, null, 2)], {type:"application/json"});
  const a = document.createElement("a");
  a.href = URL.createObjectURL(blob);
  a.download = `CR_report_${crReportData.cr_number || crRun}.json`;
  a.click(); URL.revokeObjectURL(a.href);
}

loadTxns();
