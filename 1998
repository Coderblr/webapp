"""
Standalone Record -> Generate flow for BRAND-NEW transactions.

The CR pipeline (cr_pipeline.py) deliberately REFUSES transactions that have no
existing feature/page/steps — it only merges deltas into files that already
exist (README §1: framework files are never written without compile + Approve;
merge_engine only appends/replaces within an existing file). That is correct,
but it leaves a gap: a BRD covering hundreds of transactions hits some the
framework has never automated, and those fall out as `not_found` action items
with nothing generated.

This module fills that gap WITHOUT weakening any invariant. A human records the
transaction once (recorder.py, which now also captures typed values); this
module turns that single recording into a full three-file scaffold —
feature + page object + step definitions — that is then compiled in quarantine
and staged for the SAME human Approve gate every other framework write goes
through. Once approved and indexed, future BRDs reconcile against it via the
normal CR pipeline.

VALUE / SECURITY MODEL (safe-middle, matches Phase 22 "keys only, values never
captured"):
  * Ordinary fields -> the real typed value becomes an Examples parameter, so
    the generated Scenario Outline is runnable out of the box.
  * Sensitive fields (password / account / PAN / PII) were already redacted to
    '[REDACTED]' IN THE BROWSER by the recorder, so no secret ever reaches this
    module. Here they resolve at runtime through the framework's own
    properties reader (src/test/resources/data/<env>/<module>.properties) via a
    util method discovered dynamically from framework_scanner — the orchestrator
    only ever emits a property KEY, never a secret.

GHERKIN SHAPE (hybrid, decided per recording):
  * If the recording has >=1 non-sensitive input value -> Scenario Outline +
    Examples (parameterized, runnable).
  * Otherwise (pure click/navigation flow, or every input sensitive) -> a plain
    Scenario. An empty Examples table is noise; we don't emit one.
"""
import re
from pathlib import Path

from . import config, recorder


# ─────────────────────── properties-util discovery ──────────────────────────
_GETTER_RE = re.compile(r"get|read|fetch|prop|config|value", re.I)


def discover_property_reader() -> dict | None:
    """Find the framework's properties-reader util (class + method) so
    generated steps resolve sensitive values through the REAL mechanism the
    framework already uses. Returns {"class":..., "method":..., "params":[...]}
    or None if the framework scan hasn't run / no such util exists."""
    try:
        from . import framework_scanner
        kb = framework_scanner.get_framework_knowledge()
    except Exception:  # noqa: BLE001
        return None
    best = None
    for util in kb.get("utils", []):
        cls = util.get("class", "")
        cls_is_propish = bool(re.search(r"prop|config|data|env|read", cls, re.I))
        for m in util.get("methods", []):
            name = m.get("name", "")
            if not _GETTER_RE.search(name):
                continue
            # a String getter taking a single key arg is the ideal shape
            params = m.get("params", [])
            score = 0
            if cls_is_propish:
                score += 2
            if len(params) == 1:
                score += 2
            if re.search(r"get|read|prop", name, re.I):
                score += 1
            if best is None or score > best[0]:
                best = (score, {"class": cls, "method": name, "params": params})
    return best[1] if best else None


# ─────────────────────── recording -> step model (pure) ─────────────────────
def build_step_model(session: dict) -> dict:
    """Turn a saved recording session into an ordered, deduplicated model the
    templates and the LLM both consume:

      {
        "txn": "Txn123",
        "steps": [ {action, name, locator (top candidate), param, value,
                    sensitive, tag, type, screen} ],
        "params":     [ {name, example} ],      # non-sensitive, for Examples
        "sensitive":  [ {name, key} ],          # resolve via properties util
        "screens":    [ ...distinct titles... ],
        "outline": bool,                        # Scenario Outline vs plain
      }
    """
    events = session.get("events", [])
    steps, params, sensitive, screens = [], [], [], []
    seen_param = set()

    for ev in events:
        cands = ev.get("candidates") or ev.get("derived") or []
        top = cands[0] if cands else None
        name = ev.get("suggested_name") or "element"
        title = (ev.get("title") or "").strip()
        if title and title not in screens:
            screens.append(title)

        if ev.get("kind") == "input" and ev.get("had_value"):
            pname = ev.get("param_name") or recorder._param_name_for(ev) or "value"
            if ev.get("sensitive"):
                key = _property_key(session.get("txn", ""), pname)
                if pname not in seen_param:
                    sensitive.append({"name": pname, "key": key})
                    seen_param.add(pname)
                steps.append({"action": "enter_secret", "name": name, "locator": top,
                              "param": pname, "value": None, "sensitive": True,
                              "key": key, "tag": ev.get("tag"), "type": ev.get("type"),
                              "screen": title})
            else:
                val = ev.get("value")
                if pname not in seen_param:
                    params.append({"name": pname, "example": val if val is not None else ""})
                    seen_param.add(pname)
                steps.append({"action": "enter", "name": name, "locator": top,
                              "param": pname, "value": val, "sensitive": False,
                              "tag": ev.get("tag"), "type": ev.get("type"),
                              "screen": title})
        else:
            # click / navigation
            steps.append({"action": "click", "name": name, "locator": top,
                          "param": None, "value": None, "sensitive": False,
                          "tag": ev.get("tag"), "type": ev.get("type"), "screen": title})

    return {"txn": session.get("txn", "unknown"), "steps": steps,
            "params": params, "sensitive": sensitive, "screens": screens,
            "outline": bool(params)}


def _property_key(txn: str, param: str) -> str:
    """Deterministic property key for a sensitive field, namespaced by txn so
    two transactions' 'password' fields don't collide."""
    t = re.sub(r"[^A-Za-z0-9]", "", txn or "txn").lower()
    p = re.sub(r"[^A-Za-z0-9]", "", param or "value")
    return f"{t}.{p}"


# ─────────────────────── deterministic scaffold assembly ────────────────────
def _module_for(txn: str) -> str:
    return "recorded"  # brand-new txns land in a dedicated module until re-homed


def render_feature(model: dict) -> str:
    """Deterministic Gherkin. Scenario Outline + Examples when there are
    non-sensitive params; plain Scenario otherwise."""
    txn = model["txn"]
    lines = [f"Feature: {txn} (recorded)", "",
             f"  @recorded @{txn.lower()}"]
    if model["outline"]:
        lines.append(f"  Scenario Outline: {txn} recorded flow")
    else:
        lines.append(f"  Scenario: {txn} recorded flow")

    for st in model["steps"]:
        if st["action"] == "click":
            lines.append(f"    When the user clicks {_phrase(st['name'])}")
        elif st["action"] == "enter":
            lines.append(f"    When the user enters \"<{st['param']}>\" in {_phrase(st['name'])}"
                         if model["outline"]
                         else f"    When the user enters \"{st['value']}\" in {_phrase(st['name'])}")
        elif st["action"] == "enter_secret":
            # secret resolved from properties inside the step; no value in Gherkin
            lines.append(f"    When the user enters the secure value for {_phrase(st['name'])}")
    lines.append("    Then the transaction completes successfully")

    if model["outline"]:
        lines.append("")
        cols = [p["name"] for p in model["params"]]
        header = " | ".join(cols)
        row = " | ".join(str(p["example"]) for p in model["params"])
        lines.append("    Examples:")
        lines.append(f"      | {header} |")
        lines.append(f"      | {row} |")
    return "\n".join(lines) + "\n"


def _phrase(field_name: str) -> str:
    """customerNameTextbox -> 'the customer name textbox' for readable Gherkin."""
    words = re.findall(r"[A-Z]+(?![a-z])|[A-Z][a-z]*|[a-z]+", field_name)
    return "the " + " ".join(w.lower() for w in words)


# ─────────────────────── LLM assembly for Java files ────────────────────────
_SYSTEM = """You are a senior Java/Selenium/Cucumber automation engineer. You are given a
RECORDED transaction: an ordered list of real UI actions with REAL, human-verified
locators captured from the live application. Produce a Page Object and a Step
Definitions class that implement the provided feature file.

HARD RULES:
- Use ONLY the locators provided. Never invent an id/xpath/css that is not given.
  Every provided locator was verified by a human on the real app — use it verbatim.
- Sensitive fields (marked SECURE) must NOT be hardcoded. Resolve them at runtime
  through the provided properties-reader util and property KEY. If no util is
  provided, read the key with a // TODO QA marker naming the exact key.
- Match the framework's package/style conventions shown in the examples.
- Output EXACTLY two files in this format and nothing else:
===FILE: <relative/path/Page.java>
<code>
===END
===FILE: <relative/path/Steps.java>
<code>
===END
"""


def _build_user_prompt(model: dict, feature_text: str, reader: dict | None,
                       page_examples: str, step_examples: str) -> str:
    loc_lines = []
    for st in model["steps"]:
        loc = st.get("locator") or {}
        loc_lines.append(
            f'- {st["action"].upper()} field="{st["name"]}" '
            f'{"SECURE key=" + st["key"] if st.get("sensitive") else ""} '
            f'locator={loc.get("java", "// TODO QA: verify locator")}')
    reader_txt = (f'{reader["class"]}.{reader["method"]}(<key>)'
                  if reader else "(no properties util found — emit // TODO QA with the key)")
    return f"""## TARGET TRANSACTION: {model['txn']}

## FEATURE FILE to implement (already written; do not change it):
```gherkin
{feature_text}
```

## RECORDED ACTIONS with REAL locators (use verbatim; never invent):
{chr(10).join(loc_lines)}

## SENSITIVE FIELDS -> resolve via the framework properties reader:
{chr(10).join(f'- {s["name"]} -> key "{s["key"]}"' for s in model['sensitive']) or '(none)'}

## PROPERTIES READER util to call for secure values:
{reader_txt}

## EXISTING PAGE-OBJECT style to match:
```java
{page_examples or '(none — follow standard PageFactory/By style in com.nbc.pages)'}
```

## EXISTING STEP-DEFINITION style to match:
```java
{step_examples or '(none — follow standard Cucumber @When/@Then style in com.nbc.stepDefinitions)'}
```

Produce the Page Object and Step Definitions now, in the required ===FILE/===END format."""


def generate_scaffold(txn: str, log=lambda m: None) -> dict:
    """Full standalone generation for one recorded transaction. Returns
    {feature, files:{rel_path:code}, model, reader} — does NOT write into the
    framework; the caller stages it through the normal compile+Approve gate."""
    session = recorder.latest_session(txn)
    if not session or not session.get("events"):
        raise RuntimeError(
            f"No recorded session found for {txn}. Record the transaction first "
            "(Locator Recorder, scaffold mode), then generate.")

    model = build_step_model(session)
    feature_text = render_feature(model)
    log(f">>> [{model['txn']}] built model: {len(model['steps'])} step(s), "
        f"{len(model['params'])} example param(s), {len(model['sensitive'])} secure field(s), "
        f"gherkin={'Scenario Outline' if model['outline'] else 'Scenario'}.")

    reader = discover_property_reader()
    if reader:
        log(f">>> [{model['txn']}] secure values will resolve via "
            f"{reader['class']}.{reader['method']}(key).")
    elif model["sensitive"]:
        log(f">>> [{model['txn']}] no properties util found — secure fields get "
            "// TODO QA markers naming the exact key.")

    # gather framework style examples (best-effort)
    page_examples = step_examples = ""
    try:
        from . import knowledge
        module = _module_for(model["txn"])
        page_examples = knowledge.page_catalog(module) or ""
        step_examples = knowledge.step_catalog(module) or ""
    except Exception:  # noqa: BLE001
        pass

    from . import generator
    reply = generator._azure_chat([
        {"role": "system", "content": _SYSTEM},
        {"role": "user", "content": _build_user_prompt(
            model, feature_text, reader, page_examples, step_examples)},
    ])
    files = _parse_files(reply)
    if not files:
        raise RuntimeError("Generation returned no parseable files — check the model reply.")
    log(f">>> [{model['txn']}] generated {len(files)} java file(s) from the recording.")
    return {"feature": feature_text, "files": files, "model": model, "reader": reader}


_FILE_RE = re.compile(r"===FILE:\s*(.+?)\s*\n(.*?)\n===END", re.S)


def _parse_files(reply: str) -> dict:
    """Parse the generator's ===FILE/===END envelope into {rel_path: code}."""
    out = {}
    for m in _FILE_RE.finditer(reply or ""):
        path = m.group(1).strip()
        code = m.group(2)
        if path:
            out[path] = code
    return out
