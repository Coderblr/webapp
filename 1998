  /* ================= App shell ================= */
  var NAV = [
    ["Operate", [
      ["dashboard", "Home dashboard", Dashboard],
      ["brd", "BRD intelligence", BRDPage],
      ["recording", "Recording console", RecordingPage],
      ["execution", "Execution console", ExecutionPage]]],
    ["Knowledge", [
      ["knowledge", "Knowledge base", KnowledgePage],
      ["locators", "Locator repository", LocatorPage],
      ["uichanges", "UI version compare", UIChangesPage]]],
    ["Review", [
      ["generation", "Generation review", GenerationPage],
      ["reports", "AI reports", ReportsPage],
      ["settings", "Settings", SettingsPage]]],
  ];
  var page = "dashboard";
  var dark = false;

  function renderApp() {
    clear(root);
    document.documentElement.dataset.theme = dark ? "dark" : "light";
    var main = h("main", { class: "main" });
    var navButtons = {};
    function go(key, fn) {
      page = key;
      Object.keys(navButtons).forEach(function (k) {
        navButtons[k].className = k === page ? "active" : "";
      });
      clear(main);
      main.appendChild(fn());
    }
    var groups = NAV.map(function (g) {
      var div = h("div", null, h("div", { class: "group" }, g[0]));
      g[1].forEach(function (item) {
        var btn = h("button", {
          class: item[0] === page ? "active" : "",
          onclick: function () { go(item[0], item[2]); },
        }, item[1]);
        navButtons[item[0]] = btn;
        div.appendChild(btn);
      });
      return div;
    });
    var themeBtn = h("button", {
      class: "ghost",
      style: { width: "100%", marginBottom: "8px", color: "var(--navy-ink)" },
      onclick: function () {
        dark = !dark;
        document.documentElement.dataset.theme = dark ? "dark" : "light";
        themeBtn.textContent = dark ? "Light theme" : "Dark theme";
      },
    }, "Dark theme");
    root.appendChild(h("div", { class: "layout" },
      h("aside", { class: "sidebar" },
        h("div", { class: "brand" }, "AI Automation",
          h("small", null, "Control Center")),
        h("nav", { class: "nav" }, groups),
        h("div", { style: { padding: "0 20px" } },
          themeBtn)),
      main));
    var current = null;
    NAV.forEach(function (g) {
      g[1].forEach(function (item) { if (item[0] === page) current = item; });
    });
    main.appendChild(current[2]());
  }

  renderApp();
})();
