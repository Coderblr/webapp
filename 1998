  /* ================= 8. Execution console ================= */
  function ExecutionPage() {
    var wrap = h("div", null);
    var liveId = null, sock = null;
    var txns = h("input", { type: "text", placeholder: "TXN-2041, TXN-2042" });
    var mode = h("select", null,
      h("option", { value: "0" }, "Live — visible Edge window"),
      h("option", { value: "1" }, "Headless"));
    var runBtn = h("button", { class: "primary", onclick: startStop }, "Run tests");
    var livePanel = h("div", { class: "panel", style: { display: "none" } });
    var liveTitle = h("h2", null);
    var log = h("div", { class: "log" });
    var hist = h("div", { class: "panel" });
    livePanel.appendChild(liveTitle);
    livePanel.appendChild(log);

    function addLine(ev) {
      var text = ev.line || ev.message ||
        (ev.type === "done" ? "— Finished: " + ev.status + " (" +
          ((ev.report || {}).passed || 0) + " passed, " +
          ((ev.report || {}).failed || 0) + " failed)" : "");
      if (!text) return;
      var cls = ev.result === "failed" ? "fail" : ev.result === "passed" ? "pass" : "";
      log.appendChild(h("div", cls ? { class: cls } : null, text));
      while (log.childNodes.length > 500) log.removeChild(log.firstChild);
      log.scrollTop = 1e9;
    }
    function startStop() {
      if (!liveId) {
        clear(log);
        livePanel.style.display = "block";
        clear(liveTitle);
        append(liveTitle, [h("span", { class: "pulse" }), "Live execution"]);
        api.post("/api/executions/start", {
          transactions: txns.value.split(",").map(function (s) { return s.trim(); })
            .filter(Boolean),
          headless: mode.value === "1",
        }).then(function (r) {
          liveId = r.execution_id;
          runBtn.textContent = "Stop";
          runBtn.className = "danger";
          sock = api.ws("/ws/executions/" + liveId, function (ev) {
            addLine(ev);
            if (ev.type === "done" || ev.type === "error") finish();
          });
          load();
        }).catch(function (e) { toast(e.message); });
      } else {
        api.post("/api/executions/" + liveId + "/stop");
      }
    }
    function finish() {
      if (sock) sock.close();
      liveId = null;
      runBtn.textContent = "Run tests";
      runBtn.className = "primary";
      liveTitle.textContent = "Last run output";
      load();
    }
    function load() {
      api.get("/api/executions").then(function (execs) {
        clear(hist);
        append(hist, table(
          ["ID", "Transactions", "Mode", "Status", "Passed", "Failed", "Started"],
          (execs || []).map(function (e) {
            return h("tr", null, h("td", null, e.id),
              h("td", { class: "mono" }, (e.transactions || []).join(", ") || "full suite"),
              h("td", null, e.headless ? "headless" : "live Edge"),
              h("td", null, statusBadge(e.status)),
              h("td", null, e.passed), h("td", null, e.failed),
              h("td", { class: "muted" }, e.started_at));
          })));
      });
    }
    var form = role === "Viewer" ? null : h("div", { class: "panel" },
      h("div", { class: "row" },
        h("div", null,
          h("label", null, "Transactions (comma-separated, empty = full suite)"), txns),
        h("div", { style: { flex: "0", minWidth: "180px" } },
          h("label", null, "Run mode"), mode),
        runBtn));
    append(wrap, [h("div", { class: "topbar" }, h("h1", null, "Execution console")),
      form, livePanel, h("h2", null, "Execution history"), hist]);
    load();
    return wrap;
  }

  /* ================= 9. AI reports (SVG chart, no libraries) ================= */
  function svgTrend(trend) {
    var W = 800, H = 220, P = 30;
    var ns = "http://www.w3.org/2000/svg";
    var svg = document.createElementNS(ns, "svg");
    svg.setAttribute("viewBox", "0 0 " + W + " " + H);
    svg.setAttribute("width", "100%");
    svg.setAttribute("height", H);
    if (!trend || trend.length === 0) return svg;
    var max = 1;
    trend.forEach(function (t) { max = Math.max(max, t.passed || 0, t.failed || 0); });
    function pts(key) {
      return trend.map(function (t, i) {
        var x = P + (W - 2 * P) * (trend.length === 1 ? 0.5 : i / (trend.length - 1));
        var y = H - P - (H - 2 * P) * ((t[key] || 0) / max);
        return x + "," + y;
      }).join(" ");
    }
    [["passed", "var(--teal)"], ["failed", "var(--crimson)"]].forEach(function (s) {
      var line = document.createElementNS(ns, "polyline");
      line.setAttribute("points", pts(s[0]));
      line.setAttribute("fill", "none");
      line.setAttribute("stroke", s[1]);
      line.setAttribute("stroke-width", "2");
      svg.appendChild(line);
    });
    var axis = document.createElementNS(ns, "line");
    axis.setAttribute("x1", P); axis.setAttribute("y1", H - P);
    axis.setAttribute("x2", W - P); axis.setAttribute("y2", H - P);
    axis.setAttribute("stroke", "var(--line)");
    svg.appendChild(axis);
    return svg;
  }
