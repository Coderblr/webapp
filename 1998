<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Autonomous Enterprise AI Test Automation Platform</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div class="glass-bg-glow"></div>
    <div class="app-container">
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <div class="brand">
                <span class="brand-icon">⚡</span>
                <div class="brand-text">
                    <h1>A3E Platform</h1>
                    <span class="subtext">Autonomous QA Agent</span>
                </div>
            </div>
            
            <nav class="nav-menu">
                <button class="nav-item active" data-tab="dashboard">
                    <span class="icon">📊</span> Dashboard
                </button>
                <button class="nav-item" data-tab="requirements">
                    <span class="icon">📄</span> BRD & Scenarios
                </button>
                <button class="nav-item" data-tab="recorder">
                    <span class="icon">🎬</span> Transaction Recorder
                </button>
                <button class="nav-item" data-tab="components">
                    <span class="icon">🧩</span> Component Registry
                </button>
                <button class="nav-item" data-tab="graph">
                    <span class="icon">🌐</span> Knowledge Graph
                </button>
                <button class="nav-item" data-tab="runner">
                    <span class="icon">⚙️</span> Test Runner
                </button>
                <button class="nav-item" data-tab="healing">
                    <span class="icon">🩺</span> Self-Healing
                </button>
            </nav>

            <div class="sidebar-footer">
                <div class="status-indicator">
                    <span class="dot pulse-green"></span>
                    <span class="status-label">Agent Engine Idle</span>
                </div>
                <div class="version">Version 1.0.4</div>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="main-content">
            <!-- Top Bar -->
            <header class="top-bar">
                <div class="page-title">
                    <h2 id="current-tab-title">Platform Dashboard</h2>
                </div>
                <div class="system-controls">
                    <div class="control-group">
                        <label for="env-selector">Env:</label>
                        <select id="env-selector" class="glass-select">
                            <option value="staging">STAGING (Edge)</option>
                            <option value="uat">UAT (Edge)</option>
                            <option value="prod-mock">PROD-MOCK</option>
                        </select>
                    </div>
                    <button class="btn btn-secondary" id="diagnostics-btn">🔍 Verify Env</button>
                </div>
            </header>

            <!-- Dashboard Tab -->
            <section class="tab-pane active" id="tab-dashboard">
                <div class="stats-grid">
                    <div class="stat-card glass-card">
                        <div class="stat-icon">📄</div>
                        <div class="stat-info">
                            <span class="stat-label">Mapped Pages</span>
                            <h3 id="stat-pages">0</h3>
                        </div>
                    </div>
                    <div class="stat-card glass-card">
                        <div class="stat-icon">📍</div>
                        <div class="stat-info">
                            <span class="stat-label">Active Locators</span>
                            <h3 id="stat-locators">0</h3>
                        </div>
                    </div>
                    <div class="stat-card glass-card">
                        <div class="stat-icon">📖</div>
                        <div class="stat-info">
                            <span class="stat-label">Step Definitions</span>
                            <h3 id="stat-steps">0</h3>
                        </div>
                    </div>
                    <div class="stat-card glass-card">
                        <div class="stat-icon">🧱</div>
                        <div class="stat-info">
                            <span class="stat-label">Registry Components</span>
                            <h3 id="stat-components">0</h3>
                        </div>
                    </div>
                </div>

                <div class="dashboard-grid">
                    <div class="glass-card flex-2">
                        <div class="card-header">
                            <h4>Framework Evolution Activity</h4>
                            <span class="badge">VCS History</span>
                        </div>
                        <div class="table-container">
                            <table class="glass-table">
                                <thead>
                                    <tr>
                                        <th>Version</th>
                                        <th>Commit Message</th>
                                        <th>Compiled</th>
                                        <th>Date</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody id="version-table-body">
                                    <!-- Dynamic rows -->
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <div class="glass-card flex-1">
                        <div class="card-header">
                            <h4>Recent Executions</h4>
                        </div>
                        <ul class="execution-list" id="execution-list-items">
                            <!-- Dynamic items -->
                        </ul>
                    </div>
                </div>
            </section>

            <!-- Transaction Recorder Tab -->
            <section class="tab-pane" id="tab-recorder">
                <!-- Live Recorder Panel (in-frontend, no extension) -->
                <div class="glass-card" id="live-recorder-card" style="margin-bottom:16px;border:1px solid rgba(108,99,255,0.3);background:linear-gradient(135deg,rgba(108,99,255,0.08),rgba(72,207,173,0.05));">
                    <div class="card-header">
                        <h4>🎬 Live Transaction Recorder</h4>
                        <span class="badge" id="live-rec-badge" style="background:rgba(120,120,120,0.2);color:#aaa">Idle</span>
                    </div>

                    <div style="padding:0 0 8px;display:flex;gap:24px;flex-wrap:wrap;align-items:flex-start;">
                        <!-- Controls -->
                        <div style="flex:1;min-width:280px;">
                            <p class="description-text" style="margin-bottom:12px;">
                                Record any banking transaction directly from here — no Chrome extension needed.
                                Start a session, run the <strong>Recorder</strong> on the target site, perform the transaction,
                                then come back and <strong>Stop &amp; Save</strong>. Every click, input, and dropdown is captured with its best locator.
                            </p>

                            <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:12px;">
                                <input type="text" id="live-session-name" placeholder="Session name (e.g. Fund Transfer)"
                                    style="flex:1;min-width:180px;background:rgba(0,0,0,0.25);border:1px solid rgba(255,255,255,0.12);border-radius:8px;padding:9px 12px;color:#e0e0ff;font-size:13px;" />
                                <select id="live-txn-type"
                                    style="background:rgba(0,0,0,0.25);border:1px solid rgba(255,255,255,0.12);border-radius:8px;padding:9px 12px;color:#e0e0ff;font-size:13px;">
                                    <option value="fund_transfer">Fund Transfer</option>
                                    <option value="bill_payment">Bill Payment</option>
                                    <option value="account_opening">Account Opening</option>
                                    <option value="loan_application">Loan Application</option>
                                    <option value="login">Login</option>
                                    <option value="generic" selected>Generic</option>
                                </select>
                            </div>

                            <div style="display:flex;gap:8px;flex-wrap:wrap;">
                                <button class="btn btn-primary" id="btn-live-start" onclick="startLiveRecording()">🔴 Start Recording</button>
                                <button class="btn btn-primary" id="btn-live-stop" onclick="stopLiveRecording()" style="display:none;background:linear-gradient(135deg,#ff5252,#ff8a80);">⏹ Stop &amp; Save</button>
                                <button class="btn btn-secondary" id="btn-live-video" onclick="toggleScreenVideo()">🎥 Also Record Video</button>
                                <button class="btn btn-secondary" onclick="loadRecorderSessions()">🔄 Refresh Sessions</button>
                            </div>

                            <div id="live-rec-hint" style="margin-top:10px;font-size:12px;color:#888;"></div>
                        </div>

                        <!-- Bookmarklet / activation -->
                        <div style="background:rgba(0,0,0,0.2);border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:14px;min-width:240px;max-width:340px;">
                            <div style="font-size:11px;color:#888;margin-bottom:8px;text-transform:uppercase;letter-spacing:0.8px;">Arm the recorder on the target tab</div>

                            <a id="recorder-bookmarklet" href="#"
                                style="display:inline-block;background:linear-gradient(135deg,#6c63ff,#48cfad);color:#fff;text-decoration:none;font-weight:700;font-size:13px;padding:9px 16px;border-radius:8px;cursor:grab;margin-bottom:6px;">
                                🎬 AI Recorder
                            </a>
                            <div style="font-size:11px;color:#888;margin-bottom:14px;">Drag to your bookmarks bar once, then click it on the target tab.</div>

                            <button class="btn btn-secondary" id="btn-copy-console-script" onclick="copyConsoleScript()" style="width:100%;font-size:12px;margin-bottom:6px;">
                                📋 Copy Recorder Code
                            </button>
                            <div style="font-size:11px;color:#888;">
                                Then either: paste into DevTools (F12) → Console and press Enter,
                                <strong>or</strong> click the target tab's address bar, type <code>javascript:</code> first,
                                paste right after it, and press Enter. (Browsers strip a pasted <code>javascript:</code> prefix
                                as a safety measure — typing it yourself first works around that.)
                            </div>
                        </div>

                        <!-- Manual type-it-yourself fallback: no clipboard, no DevTools, no bookmarks needed -->
                        <div style="background:rgba(255,152,0,0.06);border:1px solid rgba(255,152,0,0.3);border-radius:12px;padding:14px;min-width:240px;max-width:420px;">
                            <div style="font-size:11px;color:#ffb300;margin-bottom:8px;text-transform:uppercase;letter-spacing:0.8px;">
                                Clipboard, DevTools, and bookmarks all blocked? Type this by hand
                            </div>
                            <div style="font-size:11px;color:#ccc;margin-bottom:8px;line-height:1.6;">
                                On the target tab: click the address bar, clear it, then type <code>javascript:</code> yourself
                                followed by the exact text below, and press Enter.
                            </div>
                            <div id="recorder-manual-code"
                                style="background:rgba(0,0,0,0.35);border:1px solid rgba(255,255,255,0.1);border-radius:8px;padding:10px;font-family:monospace;font-size:12px;color:#ffe082;word-break:break-all;line-height:1.6;user-select:all;">
                                (loading…)
                            </div>
                            <div style="font-size:11px;color:#888;margin-top:8px;">
                                If Edge refuses to navigate or shows a warning after pressing Enter, <code>javascript:</code>
                                links are blocked at the policy level too — no browser-side method will work on this machine;
                                ask IT for an exception on one of the three, or ask about the proxy-based alternative.
                            </div>
                        </div>
                    </div>

                    <!-- Live step feed (visible while recording) -->
                    <div id="live-feed-wrap" style="display:none;margin-top:8px;border-top:1px solid rgba(255,255,255,0.08);padding-top:12px;">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
                            <span style="font-size:12px;color:#a78bfa;font-weight:700;">● LIVE FEED</span>
                            <span style="font-size:12px;color:#48cfad;"><strong id="live-step-count">0</strong> steps captured</span>
                        </div>
                        <div id="live-feed" style="max-height:240px;overflow-y:auto;font-family:monospace;font-size:12px;color:#cfcfe0;background:rgba(0,0,0,0.25);border-radius:8px;padding:8px 10px;">
                            <div style="color:#666;">Waiting for interactions on the target site…</div>
                        </div>
                        <!-- Video preview -->
                        <video id="live-video-preview" style="display:none;width:100%;max-height:220px;margin-top:10px;border-radius:8px;border:1px solid rgba(255,255,255,0.1);background:#000;" muted></video>
                    </div>
                </div>

                <!-- Locator Workflow Diagram -->
                <div class="glass-card" style="margin-bottom:16px;">
                    <div class="card-header"><h4>⚡ Locator Discovery Pipeline</h4></div>
                    <div style="display:flex;align-items:center;gap:0;overflow-x:auto;padding:8px 0;">
                        <div class="pipeline-step" style="background:rgba(108,99,255,0.15);border-color:rgba(108,99,255,0.3);">
                            <div class="pipe-icon">🎬</div>
                            <div class="pipe-label">User Records<br>Transaction</div>
                        </div>
                        <div class="pipe-arrow">→</div>
                        <div class="pipeline-step" style="background:rgba(72,207,173,0.1);border-color:rgba(72,207,173,0.3);">
                            <div class="pipe-icon">🔍</div>
                            <div class="pipe-label">DOM Event<br>Captured</div>
                        </div>
                        <div class="pipe-arrow">→</div>
                        <div class="pipeline-step" style="background:rgba(255,179,0,0.1);border-color:rgba(255,179,0,0.3);">
                            <div class="pipe-icon">🎯</div>
                            <div class="pipe-label">Best Locator<br>Discovered</div>
                        </div>
                        <div class="pipe-arrow">→</div>
                        <div class="pipeline-step" style="background:rgba(255,82,82,0.1);border-color:rgba(255,82,82,0.3);">
                            <div class="pipe-icon">🗄️</div>
                            <div class="pipe-label">Stored in<br>Knowledge DB</div>
                        </div>
                        <div class="pipe-arrow">→</div>
                        <div class="pipeline-step" style="background:rgba(108,99,255,0.15);border-color:rgba(108,99,255,0.3);">
                            <div class="pipe-icon">☕</div>
                            <div class="pipe-label">Java Page Object<br>Generated</div>
                        </div>
                        <div class="pipe-arrow">→</div>
                        <div class="pipeline-step" style="background:rgba(72,207,173,0.1);border-color:rgba(72,207,173,0.3);">
                            <div class="pipe-icon">🥒</div>
                            <div class="pipe-label">Feature File<br>Generated</div>
                        </div>
                    </div>
                </div>

                <!-- Locator Priority Legend -->
                <div class="glass-card" style="margin-bottom:16px;">
                    <div class="card-header"><h4>🏆 Locator Priority (Best → Worst)</h4></div>
                    <div style="display:flex;gap:10px;flex-wrap:wrap;padding-bottom:4px;">
                        <div class="locator-badge" style="background:rgba(72,207,173,0.15);border-color:#48cfad;color:#48cfad;">🥇 id="value"</div>
                        <div class="locator-badge" style="background:rgba(108,99,255,0.15);border-color:#6c63ff;color:#a78bfa;">🥈 name="value"</div>
                        <div class="locator-badge" style="background:rgba(255,179,0,0.12);border-color:#ffb300;color:#ffb300;">🥉 [data-testid]</div>
                        <div class="locator-badge" style="background:rgba(255,100,100,0.12);border-color:#ff6464;color:#ff9494;">[aria-label]</div>
                        <div class="locator-badge" style="background:rgba(180,180,255,0.08);border-color:rgba(180,180,255,0.2);color:#888;">CSS Selector</div>
                        <div class="locator-badge" style="background:rgba(100,100,100,0.1);border-color:rgba(255,255,255,0.1);color:#666;">XPath (last resort)</div>
                    </div>
                </div>

                <!-- Recorded Sessions Table -->
                <div class="glass-card">
                    <div class="card-header">
                        <h4>📋 Recorded Sessions</h4>
                        <span class="badge" id="sessions-count-badge">0 sessions</span>
                    </div>
                    <div class="table-container">
                        <table class="glass-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Session Name</th>
                                    <th>Type</th>
                                    <th>Steps</th>
                                    <th>Duration</th>
                                    <th>Status</th>
                                    <th>Recorded</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="recorder-sessions-body">
                                <tr><td colspan="8" style="text-align:center;color:#555;padding:24px;">No sessions recorded yet. Use the Chrome Extension to record a transaction.</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Session Detail Panel (hidden until clicked) -->
                <div class="glass-card" id="session-detail-panel" style="display:none;margin-top:16px;">
                    <div class="card-header">
                        <h4 id="session-detail-title">Session Details</h4>
                        <div style="display:flex;gap:8px;">
                            <button class="btn btn-primary" id="btn-regenerate" onclick="regenerateSession()">🔄 Regenerate Framework</button>
                            <button class="btn btn-secondary" onclick="closeSessionDetail()">✕ Close</button>
                        </div>
                    </div>

                    <!-- Generated Files Info -->
                    <div id="generated-files-info" style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:14px;"></div>

                    <!-- Steps Table -->
                    <div class="table-container">
                        <table class="glass-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Action</th>
                                    <th>Page</th>
                                    <th>Element</th>
                                    <th>Best Locator</th>
                                    <th>Locator Value</th>
                                    <th>Value Entered</th>
                                </tr>
                            </thead>
                            <tbody id="session-steps-body">
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <!-- BRD & Scenarios Tab -->
            <section class="tab-pane" id="tab-requirements">

                <div class="grid-layout">
                    <div class="glass-card">
                        <div class="card-header">
                            <h4>Upload Requirement Document</h4>
                        </div>
                        <p class="description-text">Upload your BRD, Solution Document, or Cucumber Feature file to automatically extract scenarios and generate tests.</p>
                        
                        <div class="upload-dropzone" id="upload-zone">
                            <div class="dropzone-content">
                                <span class="upload-icon">📁</span>
                                <p>Drag and drop BRD files, or click to browse</p>
                                <span class="sub-dropzone-text">Supports .txt, .feature, .md, .docx</span>
                            </div>
                        </div>

                        <div class="textarea-container">
                            <label for="brd-text-input">Or paste requirement text directly:</label>
                            <textarea id="brd-text-input" placeholder="Scenario: Customer Transfer Money&#10;  Given User is on login page 'http://bank.com'&#10;  When User enters credentials and clicks login&#10;  Then Account balance should reflect transfer..."></textarea>
                        </div>
                        <button class="btn btn-primary btn-full" id="analyze-brd-btn">🧠 Extract Scenarios</button>
                    </div>

                    <div class="glass-card">
                        <div class="card-header">
                            <h4>Extracted Scenarios & Impact Analysis</h4>
                            <span class="badge" id="scenarios-count-badge">0 Found</span>
                        </div>
                        
                        <div class="analysis-results-container" id="analysis-empty-state">
                            <div class="empty-state">
                                <span>🔍</span>
                                <p>No scenarios extracted yet. Parse a document to view impact and code diffs.</p>
                            </div>
                        </div>

                        <div id="analysis-results" style="display: none;">
                            <div class="impact-summary">
                                <div class="impact-item">
                                    <span class="impact-title">Reused Step Definitions</span>
                                    <span class="impact-value text-green" id="impact-reused-count">0</span>
                                </div>
                                <div class="impact-item">
                                    <span class="impact-title">Missing Code Modules</span>
                                    <span class="impact-value text-orange" id="impact-missing-count">0</span>
                                </div>
                            </div>

                            <div class="scenarios-list" id="extracted-scenarios-list">
                                <!-- Dynamic scenarios list -->
                            </div>

                            <!-- Locator mapper for missing elements -->
                            <div class="locator-mapper-card" id="locator-mapper-card" style="display: none;">
                                <h5>Required Locators Assignment</h5>
                                <div id="locator-fields-container"></div>
                            </div>

                            <button class="btn btn-success btn-full" id="build-framework-btn">🚀 Append & Evolve Framework</button>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Component Registry Tab -->
            <section class="tab-pane" id="tab-components">
                <div class="components-grid-container">
                    <div class="glass-card col-span-3">
                        <div class="card-header">
                            <h4>Component Registry</h4>
                            <p class="description-text">These are the reusable Java-Selenium action plugins. The AI agent searches here first to avoid creating duplicate steps.</p>
                        </div>
                        <div class="components-grid" id="components-list">
                            <!-- Dynamic components -->
                        </div>
                    </div>
                    <div class="glass-card">
                        <div class="card-header">
                            <h4>Add Custom Component</h4>
                        </div>
                        <div class="form-group">
                            <label for="comp-name">Component Name:</label>
                            <input type="text" id="comp-name" class="glass-input" placeholder="e.g. AGGridTableAction">
                        </div>
                        <div class="form-group">
                            <label for="comp-type">Action Type:</label>
                            <select id="comp-type" class="glass-select">
                                <option value="click">Click Interaction</option>
                                <option value="input">Input / Entering Text</option>
                                <option value="dropdown">Selection Dropdown</option>
                                <option value="custom">Custom Banking Widget</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="comp-desc">Description:</label>
                            <textarea id="comp-desc" class="glass-textarea" placeholder="Describe the component actions..."></textarea>
                        </div>
                        <div class="form-group">
                            <label for="comp-code">Java Template Code:</label>
                            <textarea id="comp-code" class="glass-textarea code-area" placeholder="public void selectItem(...) { ... }"></textarea>
                        </div>
                        <button class="btn btn-primary btn-full" id="add-component-btn">➕ Register Component</button>
                    </div>
                </div>
            </section>

            <!-- Knowledge Graph Tab -->
            <section class="tab-pane" id="tab-graph">
                <div class="glass-card" style="margin-bottom:16px;border:1px solid rgba(108,99,255,0.3);background:linear-gradient(135deg,rgba(108,99,255,0.08),rgba(72,207,173,0.05));">
                    <div class="card-header">
                        <h4>📥 Import Existing Framework</h4>
                        <span class="badge" id="import-status-badge" style="background:rgba(120,120,120,0.2);color:#aaa">Ready</span>
                    </div>
                    <p class="description-text">
                        Already have a hand-written java-framework — Page Objects, Step Definitions, Feature files? One touch reads all
                        of it and loads it into the knowledge graph below. From then on, the AI reuses your existing locators and steps
                        instead of regenerating or duplicating them.
                    </p>
                    <button class="btn btn-primary" id="btn-import-framework" onclick="importExistingFramework()">📥 Import Existing Framework</button>
                    <div id="import-result" style="margin-top:12px;font-size:13px;color:#ccc;"></div>
                </div>

                <div class="glass-card graph-full-card">
                    <div class="card-header">
                        <h4>Semantic Knowledge Graph</h4>
                        <div class="graph-legend">
                            <span class="legend-item"><span class="legend-dot color-page"></span> Page Object</span>
                            <span class="legend-item"><span class="legend-dot color-locator"></span> Locator</span>
                            <span class="legend-item"><span class="legend-dot color-step"></span> Cucumber Step</span>
                        </div>
                    </div>
                    <p class="description-text">Real-time mapping showing how Pages, Step Definitions, and DOM elements link together. The AI framework utilizes these relationships to self-heal and avoid duplicates.</p>
                    
                    <div class="graph-viewer-container">
                        <div class="graph-canvas-wrapper">
                            <!-- SVG network graph goes here -->
                            <svg id="knowledge-graph-svg" width="100%" height="500"></svg>
                        </div>
                        <div class="graph-details-panel" id="graph-details">
                            <h5>Node Inspector</h5>
                            <div class="empty-state-panel">
                                <p>Click any node in the network to inspect its locators, steps, and associated source code.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Test Runner Tab -->
            <section class="tab-pane" id="tab-runner">
                <div class="grid-layout">
                    <div class="glass-card">
                        <div class="card-header">
                            <h4>Execution Console</h4>
                        </div>
                        <div class="runner-controls">
                            <button class="btn btn-secondary" id="compile-btn">🔨 Compile Framework</button>
                            <button class="btn btn-primary" id="run-tests-btn">▶️ Run Automation Suite</button>
                        </div>
                        
                        <div class="logs-console">
                            <div class="console-header">
                                <span class="console-title">Maven / TestNG Terminal Output</span>
                                <button class="btn-clear" id="clear-logs-btn">Clear</button>
                            </div>
                            <pre class="console-output" id="terminal-logs">Autonomous Platform ready. Select Compile or Run to start...</pre>
                        </div>
                    </div>

                    <div class="glass-card">
                        <div class="card-header">
                            <h4>Live Browser State & HTML Report</h4>
                        </div>
                        <div class="browser-state-mock">
                            <div class="browser-address-bar">
                                <span class="browser-dots">🔴 🟡 🟢</span>
                                <input type="text" value="https://example.com" class="browser-url" readonly id="browser-address">
                            </div>
                            <div class="browser-body" id="browser-view">
                                <div class="browser-screenshot">
                                    <div class="mock-browser-ui">
                                        <h4 style="margin-bottom:10px;">Browser Live View</h4>
                                        <p>Running in Microsoft Edge...</p>
                                        <div class="pulse-indicator"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="report-box" style="margin-top:20px;">
                            <h5>Latest Extent Report:</h5>
                            <a href="/api/report" target="_blank" class="report-link" id="view-report-link">Open HTML Report in browser</a>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Self-Healing Tab -->
            <section class="tab-pane" id="tab-healing">
                <div class="grid-layout">
                    <div class="glass-card">
                        <div class="card-header">
                            <h4>Trigger Failure & Self-Heal Demo</h4>
                        </div>
                        <p class="description-text">Simulate a locator failure (such as an element XPath changes on the target page) to verify how the Self-Healing Agent detects the issue, scans the DOM, repairs the XPath selector, and updates the Java source code automatically.</p>
                        
                        <div class="form-group">
                            <label for="heal-page">Failed Page Class:</label>
                            <input type="text" id="heal-page" class="glass-input" value="LoginPage">
                        </div>
                        <div class="form-group">
                            <label for="heal-element">Failed Element Name:</label>
                            <input type="text" id="heal-element" class="glass-input" value="loginButton">
                        </div>
                        <div class="form-group">
                            <label for="heal-error">Exception Message:</label>
                            <textarea id="heal-error" class="glass-textarea">org.openqa.selenium.NoSuchElementException: no such element: Unable to locate element: {"method":"xpath","selector":"//*[@id='old-submit-btn']"}</textarea>
                        </div>
                        <div class="form-group">
                            <label for="heal-html">New DOM Snapshot Snippet:</label>
                            <textarea id="heal-html" class="glass-textarea code-area"><div class="login-box">
  <button id="loginbutton" class="btn btn-primary">Login Now</button>
</div></textarea>
                        </div>
                        <button class="btn btn-primary btn-full" id="trigger-healing-btn">🩹 Repair & Heal Element</button>
                    </div>

                    <div class="glass-card">
                        <div class="card-header">
                            <h4>Healing Log & Code Diff</h4>
                        </div>
                        
                        <div class="healing-summary-container" id="healing-logs-empty">
                            <div class="empty-state">
                                <span>🩹</span>
                                <p>No healing operations executed yet.</p>
                            </div>
                        </div>

                        <div id="healing-results-panel" style="display: none;">
                            <div class="healing-status-banner success">
                                <strong>Status:</strong> Success! Code updated.
                            </div>
                            
                            <div class="logs-console" style="margin-top: 15px;">
                                <div class="console-header">
                                    <span class="console-title">Healing Agent Execution Trail</span>
                                </div>
                                <pre class="console-output" id="healing-console-logs" style="height: 120px;"></pre>
                            </div>

                            <h5 style="margin-top:20px;">Code Patch Diff</h5>
                            <div class="code-diff-container">
                                <pre class="diff-output"><span class="diff-removed">- private By loginButton = By.xpath("//*[@id='old-submit-btn']");</span>
<span class="diff-added">+ private By loginButton = By.xpath("//*[@id='loginbutton']");</span></pre>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </main>
    </div>
    <script src="app.js"></script>
