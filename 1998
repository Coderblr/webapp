FILES["src/main/java/core/DriverFactory.java"] = r"""package core;

import org.openqa.selenium.WebDriver;
import org.openqa.selenium.edge.EdgeDriver;
import org.openqa.selenium.edge.EdgeOptions;
import java.time.Duration;

/** Creates the Edge driver. Live (visible) by default; controlled by -D flags
 *  supplied by the AI Automation Platform execution engine. */
public final class DriverFactory {
    private static final ThreadLocal<WebDriver> DRIVER = new ThreadLocal<>();

    public static WebDriver get() {
        if (DRIVER.get() == null) {
            String edgeDriver = System.getProperty("webdriver.edge.driver", "msedgedriver");
            System.setProperty("webdriver.edge.driver", edgeDriver);
            EdgeOptions options = new EdgeOptions();
            String binary = System.getProperty("edge.binary", "");
            if (!binary.isEmpty()) options.setBinary(binary);
            String profile = System.getProperty("edge.profile.dir", "");
            if (!profile.isEmpty()) options.addArguments("--user-data-dir=" + profile);
            if (Boolean.getBoolean("headless")) options.addArguments("--headless=new");
            options.addArguments("--start-maximized", "--remote-allow-origins=*");
            WebDriver d = new EdgeDriver(options);
            d.manage().timeouts().implicitlyWait(Duration.ofSeconds(10));
            DRIVER.set(d);
        }
        return DRIVER.get();
    }

    public static void quit() {
        if (DRIVER.get() != null) { DRIVER.get().quit(); DRIVER.remove(); }
    }
}
"""

FILES["src/main/java/core/ConfigReader.java"] = r"""package core;

import java.io.FileInputStream;
import java.util.Properties;

/** Reads src/test/resources/config/<environment>.properties (default SIT). */
public final class ConfigReader {
    private static Properties props;

    public static String get(String key) {
        if (props == null) {
            props = new Properties();
            String env = System.getProperty("environment", "SIT");
            try (FileInputStream in = new FileInputStream(
                    "src/test/resources/config/" + env + ".properties")) {
                props.load(in);
            } catch (Exception e) {
                throw new RuntimeException("Cannot load config for env " + env, e);
            }
        }
        return props.getProperty(key, "");
    }
}
"""

FILES["src/main/java/core/LocatorRepository.java"] = r"""package core;

import org.openqa.selenium.By;
import org.openqa.selenium.NoSuchElementException;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import java.io.BufferedReader;
import java.io.InputStreamReader;
import java.io.OutputStream;
import java.net.HttpURLConnection;
import java.net.URL;
import java.nio.charset.StandardCharsets;

/** Client for the AI Automation Platform's central locator repository.
 *  find() resolves an element and, on failure, calls the self-healing API
 *  so tests keep running when the UI changes. Falls back to the inline
 *  locator if the platform is offline. */
public final class LocatorRepository {
    private static final String BASE =
        System.getProperty("platform.url", "http://localhost:8000");

    /** Primary API for page objects: resolve from the central repository,
     *  fall back to the inline recorded locator if the platform is offline. */
    public static By by(String txn, String screen, String key, By fallback) {
        try {
            String resp = httpGet(BASE + "/api/locator/resolve?key=" +
                java.net.URLEncoder.encode(key, "UTF-8"));
            String strategy = json(resp, "strategy"), value = json(resp, "value");
            if (strategy != null && value != null) return toBy(strategy, value);
        } catch (Exception ignore) { /* platform offline: use inline fallback */ }
        return fallback;
    }

    private static String httpGet(String url) throws Exception {
        HttpURLConnection c = (HttpURLConnection) new URL(url).openConnection();
        c.setConnectTimeout(2000); c.setReadTimeout(5000);
        StringBuilder sb = new StringBuilder();
        try (BufferedReader r = new BufferedReader(
                new InputStreamReader(c.getInputStream(), StandardCharsets.UTF_8))) {
            String line; while ((line = r.readLine()) != null) sb.append(line);
        }
        return sb.toString();
    }

    /** Find with self-healing. key format: "TXN/Screen/elementName". */
    public static WebElement find(WebDriver driver, String key, By fallback) {
        try {
            return driver.findElement(fallback);
        } catch (NoSuchElementException first) {
            try {
                String dom = driver.getPageSource();
                if (dom.length() > 200_000) dom = dom.substring(0, 200_000);
                String body = "{\"key\":" + q(key)
                    + ",\"failed_locator\":" + q(fallback.toString())
                    + ",\"dom\":" + q(dom) + "}";
                String resp = post(BASE + "/api/heal", body);
                String type = json(resp, "type"), value = json(resp, "value");
                if (type != null && value != null) {
                    By healed = toBy(type, value);
                    WebElement el = driver.findElement(healed);
                    System.out.println("[SELF-HEALED] " + key + " -> " + healed);
                    return el;
                }
            } catch (Exception ignore) { /* platform offline: fall through */ }
            throw first;
        }
    }

    private static By toBy(String type, String value) {
        switch (type) {
            case "id": return By.id(value);
            case "name": return By.name(value);
            case "css": return By.cssSelector(value);
            default: return By.xpath(value);
        }
    }

    private static String post(String url, String body) throws Exception {
        HttpURLConnection c = (HttpURLConnection) new URL(url).openConnection();
        c.setRequestMethod("POST");
        c.setRequestProperty("Content-Type", "application/json");
        c.setConnectTimeout(3000); c.setReadTimeout(15000); c.setDoOutput(true);
        try (OutputStream os = c.getOutputStream()) {
            os.write(body.getBytes(StandardCharsets.UTF_8));
        }
        StringBuilder sb = new StringBuilder();
        try (BufferedReader r = new BufferedReader(
                new InputStreamReader(c.getInputStream(), StandardCharsets.UTF_8))) {
            String line; while ((line = r.readLine()) != null) sb.append(line);
        }
        return sb.toString();
    }

    private static String q(String s) {
        return "\"" + s.replace("\\", "\\\\").replace("\"", "\\\"")
                       .replace("\n", "\\n").replace("\r", "") + "\"";
    }

    private static String json(String body, String field) {
        int i = body.indexOf("\"" + field + "\"");
        if (i < 0) return null;
        int a = body.indexOf('"', body.indexOf(':', i) + 1);
        int b = body.indexOf('"', a + 1);
        return (a < 0 || b < 0) ? null : body.substring(a + 1, b);
    }
}
"""

FILES["src/test/java/stepdefinitions/Hooks.java"] = r"""package stepdefinitions;

import core.DriverFactory;
import io.cucumber.java.After;
import io.cucumber.java.Before;
import io.cucumber.java.Scenario;
import org.openqa.selenium.OutputType;
import org.openqa.selenium.TakesScreenshot;

public class Hooks {
    @Before
    public void setUp() { DriverFactory.get(); }

    @After
    public void tearDown(Scenario scenario) {
        if (scenario.isFailed()) {
            byte[] shot = ((TakesScreenshot) DriverFactory.get())
                .getScreenshotAs(OutputType.BYTES);
            scenario.attach(shot, "image/png", scenario.getName());
        }
        DriverFactory.quit();
    }
}
"""

