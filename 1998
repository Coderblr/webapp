  a.click(); URL.revokeObjectURL(a.href);
}

/* ── review editor ───────────────────────────────────────────────────── */
async function showReview(){
  const r = await fetch(API + `/jobs/${job}/pending`);
  if (!r.ok){ toast("Could not load pending changes."); return; }
  const p = await r.json();
  const m = p.meta || {};
  const match = p.match || {};

  // ── match banner: which existing feature this was compared against ──
  const mb = document.getElementById("matchbar");
  if (match.is_new_feature){
    mb.className = "matchbar newfeat";
    mb.innerHTML = `&#9888;&nbsp; No existing feature matched — treated as a <b>brand-new transaction</b>. `
      + `Locators for any new UI elements will need manual verification.`;
  } else {
    const conf = match.confidence != null ? ` &middot; matched by content (confidence ${Math.round(match.confidence * 100)}%)` : ` &middot; exact transaction match`;
    mb.className = "matchbar";
    mb.innerHTML = `&#128269;&nbsp; Compared against <b>${esc(match.txn || "")}</b> `
      + `(module: ${esc(match.module || "")})${conf}`;
  }

  // ── compile status badge ──
  const cb = document.getElementById("compilebadge");
  const fileCount = Object.keys(p.files || {}).length;
  cb.innerHTML = fileCount
    ? `<span class="compilebadge">&#10003; ${fileCount} java file(s) generated &amp; compiled successfully</span>`
    : `<span class="compilebadge" style="background:#eef1f7;color:var(--muted)">No new java needed — all steps already have glue</span>`;

  // ── comparison summary cards ──
  const cs = m.comparison_summary || {};
  const untouchedCount = (m.scenarios_unreferenced || []).length;
  document.getElementById("comparecards").innerHTML = [
    ["unchanged", cs.unchanged ?? 0, "Unchanged"],
    ["new", (m.scenarios_added || []).length, "New"],
    ["modified", (m.scenarios_replaced || []).length, "Modified"],
    ["kept", untouchedCount, "Kept (not deleted)"],
  ].map(([cls, n, label]) => `<div class="ccard ${cls}"><b>${n}</b><span>${label}</span></div>`).join("");

  // ── AI decisions: what normalization changed before generation ran ──
  const norm = m.normalization || {};
  const rows = [];
  (norm.tags_normalized || []).forEach(x => rows.push(
    `<span class="tag">tag</span> <code>${esc(x.from)}</code> &rarr; <code>${esc(x.to)}</code> (matched framework convention)`));
  (norm.scenarios_renamed || []).forEach(x => rows.push(
    `<span class="tag" style="background:#0ea5e9">rename</span> "${esc(x.from)}" &rarr; "${esc(x.to)}" (${Math.round(x.similarity*100)}% match to existing scenario)`));
  (norm.steps_normalized || []).forEach(x => rows.push(
    `<span class="tag" style="background:#16a34a">step</span> <code>${esc(x.from)}</code> &rarr; <code>${esc(x.to)}</code>`));
  (norm.examples_headers_normalized || []).forEach(x => rows.push(
    `<span class="tag" style="background:#f59e0b">examples</span> [${x.from.join(", ")}] &rarr; [${x.to.join(", ")}]`));
  document.getElementById("aidecisions").innerHTML = rows.length
    ? `<div class="ai-decisions"><b style="font-size:12px;color:var(--muted)">AI DECISIONS &mdash; wording aligned to framework conventions before generation:</b>`
      + rows.map(r => `<div class="row">${r}</div>`).join("") + `</div>` : "";

  document.getElementById("rmeta").innerHTML =
    `<b>${(m.scenarios_added || []).length}</b> new scenario(s) &nbsp;&middot;&nbsp; ` +
    `<b>${(m.scenarios_replaced || []).length}</b> changed scenario(s) &nbsp;&middot;&nbsp; ` +
    `<b>${(m.undefined_steps || []).length}</b> step(s) got new java glue` +
    ((m.undefined_steps || []).length ? " — look for <b>// TODO QA: verify locator</b> markers in the java below" : "");
  const wrap = document.getElementById("rfiles");
  wrap.innerHTML = "";
  const addEditor = (label, tag, key, content, oldContent) => {
    const div = document.createElement("div"); div.className = "rfile";
    const head = document.createElement("div"); head.className = "fhead";
    head.innerHTML = `<span class="ftag">${tag}</span> ${esc(label)}`;
    const editBtn = document.createElement("button");
    editBtn.className = "edittoggle"; editBtn.type = "button"; editBtn.textContent = "Edit";
    head.appendChild(editBtn);

    const ta = document.createElement("textarea");
    ta.className = "code"; ta.spellcheck = false; ta.value = content;
    ta.dataset.key = key; ta.style.display = "none";

    const ops = diffLines(oldContent || "", content || "");
    const added = ops.filter(o => o.type === "added").length;
    const removed = ops.filter(o => o.type === "removed").length;
    const summary = document.createElement("div"); summary.className = "diffsummary";
    summary.innerHTML = (oldContent == null)
      ? `<span>New file — every line added</span>`
      : `<b class="added">+${added}</b> <span>added</span> &nbsp; <b class="removed">-${removed}</b> <span>removed</span>`;

    const dv = document.createElement("div"); dv.className = "diffview";
    dv.innerHTML = ops.map(o =>
      `<div class="dline ${o.type}">${esc(o.line)}</div>`).join("") || `<div class="dline same">(empty)</div>`;

    editBtn.onclick = () => {
      const editing = ta.style.display !== "none";
      ta.style.display = editing ? "none" : "block";
      dv.style.display = editing ? "block" : "none";
      summary.style.display = editing ? "flex" : "none";
      editBtn.textContent = editing ? "Edit" : "Done editing";
    };

    div.appendChild(head); div.appendChild(summary); div.appendChild(dv); div.appendChild(ta);
    wrap.appendChild(div);
  };
  addEditor("merged feature file (will replace the framework copy)", "feature", "__feature__",
           p.feature_text || "", p.old_feature_text || "");
  for (const [rel, code] of Object.entries(p.files || {}))
    addEditor(rel, rel.includes("stepDefinitions") ? "steps" : "page/java", rel, code,
             (p.old_files || {})[rel]);
  document.getElementById("reviewcard").style.display = "block";
  document.getElementById("reviewcard").scrollIntoView({behavior: "smooth"});
  toast("Framework Intelligence changes are ready — review, edit if needed, then approve.");
}

