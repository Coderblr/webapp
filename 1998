<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="AI Developer Assistant — a lightweight ChatGPT-style coding assistant." />
  <title>AI Developer Assistant</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap"
    rel="stylesheet"
  />
  <!-- highlight.js: syntax highlighting for code blocks -->
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css"
  />
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <div class="app">
    <!-- ============ Sidebar: conversation list ============ -->
    <aside id="sidebar" class="sidebar">
      <div class="sidebar__header">
        <span class="sidebar__brand">
          <span class="sidebar__logo" aria-hidden="true">&lt;/&gt;</span>
          Chats
        </span>
        <button id="sidebar-close-btn" class="icon-btn sidebar__close" type="button" aria-label="Close sidebar">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M18 6L6 18M6 6l12 12" />
          </svg>
        </button>
      </div>

      <button id="new-chat-btn" class="sidebar__new" type="button">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M12 5v14M5 12h14" />
        </svg>
        New Chat
      </button>

      <nav id="conversation-list" class="sidebar__list" aria-label="Conversations"></nav>

      <p class="sidebar__footer">Stored locally in your browser</p>
    </aside>

    <!-- Backdrop shown behind the sidebar on small screens -->
    <div id="sidebar-backdrop" class="sidebar-backdrop" hidden></div>

    <!-- ============ Main column ============ -->
    <div class="main">
      <header class="header">
        <div class="header__brand">
          <button id="sidebar-open-btn" class="icon-btn header__menu" type="button" aria-label="Open sidebar">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor"
                 stroke-width="2" stroke-linecap="round" aria-hidden="true">
              <path d="M3 6h18M3 12h18M3 18h18" />
            </svg>
          </button>
          <div class="header__titles">
            <h1 class="header__title">AI Developer Assistant</h1>
            <p class="header__subtitle">Powered by Azure OpenAI</p>
          </div>
        </div>
        <div class="header__actions">
          <span id="connection-status" class="status status--unknown" title="Backend status">
            <span class="status__dot"></span>
            <span class="status__label">Checking…</span>
          </span>
        </div>
      </header>

      <main id="chat-window" class="chat" aria-live="polite">
        <div id="messages" class="chat__messages"></div>

        <!-- Empty state shown when the active conversation has no messages -->
        <div id="empty-state" class="empty">
          <div class="empty__icon" aria-hidden="true">&lt;/&gt;</div>
          <h2 class="empty__title">What are you building today?</h2>
          <p class="empty__text">
            Ask a programming question, paste a stack trace, or request a code review.
          </p>
          <div class="empty__suggestions">
            <button class="chip" type="button" data-suggestion="Explain Python decorators with a simple example">
              Explain Python decorators
            </button>
            <button class="chip" type="button" data-suggestion="Write a SQL query to find duplicate rows in a table">
              Find duplicate rows in SQL
            </button>
            <button class="chip" type="button" data-suggestion="What is the difference between REST and GraphQL?">
              REST vs GraphQL
            </button>
            <button class="chip" type="button" data-suggestion="Debug this error: TypeError: Cannot read properties of undefined (reading 'map')">
              Debug a JavaScript TypeError
            </button>
          </div>
        </div>
      </main>

      <footer class="composer">
        <div class="composer__box">
          <textarea
            id="message-input"
            class="composer__input"
            rows="1"
            placeholder="Ask a coding question…  (Enter to send, Shift+Enter for a new line)"
            aria-label="Message"
          ></textarea>
          <button id="send-btn" class="composer__send" type="button" aria-label="Send message" disabled>
            <svg id="send-icon" viewBox="0 0 24 24" width="18" height="18" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round"
                 stroke-linejoin="round" aria-hidden="true">
              <path d="M22 2L11 13" />
              <path d="M22 2l-7 20-4-9-9-4 20-7z" />
            </svg>
            <span id="send-spinner" class="spinner" hidden aria-hidden="true"></span>
          </button>
        </div>
        <p class="composer__hint">The assistant can make mistakes — verify important code before shipping.</p>
      </footer>
    </div>
  </div>

  <!-- highlight.js core (auto-detects common languages) -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
  <script src="script.js"></script>
</body>
</html>
