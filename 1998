@app.get("/api/knowledge-graph")
def get_knowledge_graph():
    db = SessionLocal()
    try:
        pages = db.query(PageModel).all()
        steps = db.query(StepDefinitionModel).all()
        
        nodes = []
        links = []
        
        # Add Page nodes
        for page in pages:
            nodes.append({"id": f"page_{page.id}", "label": page.name, "type": "page", "details": page.description})
            # Fetch locators for this page
            for loc in page.locators:
                loc_node_id = f"loc_{loc.id}"
                nodes.append({"id": loc_node_id, "label": f"{loc.element_name} ({loc.selector_type})", "type": "locator", "details": loc.selector_value})
                links.append({"source": f"page_{page.id}", "target": loc_node_id, "rel": "has_element"})
                
        # Add Step nodes and link to pages
        for step in steps:
            step_node_id = f"step_{step.id}"
            nodes.append({"id": step_node_id, "label": step.pattern, "type": "step", "details": step.java_method})
            
            # Find associated page in our graph
            assoc_page = db.query(PageModel).filter(PageModel.name == step.page_associated).first()
            if assoc_page:
                links.append({"source": step_node_id, "target": f"page_{assoc_page.id}", "rel": "interacts_with"})
                
        return {"nodes": nodes, "links": links}
    finally:
        db.close()

