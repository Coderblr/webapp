"""
Pre-recording flow (runs BEFORE transaction capture starts).

Mirrors the bank's real entry sequence:

    open target URL
      -> login (userId + password)
        -> if the "password expired / forced change" screen appears:
             enter old password, new password, confirm, submit, dismiss success alert
             -> re-login with the NEW password
          -> land on the home screen
    ... only THEN does transaction recording begin.

Everything here is executed by the platform, not recorded as part of the
transaction, so generated feature files describe the business transaction only
and the login/password-change plumbing stays in shared common steps.

Password rotation: banks force a NEW password each time, so the flow supports
"password ping-pong" — after a successful change the new password is written
back to settings as the current one (and the previous one becomes the next
target), so repeated runs never lock the test user out.

Credentials come from environment variables (preferred) or settings; they are
masked everywhere they are displayed or logged.
"""
from __future__ import annotations

import os
import time

from selenium.common.exceptions import TimeoutException
from selenium.webdriver.common.by import By
from selenium.webdriver.support import expected_conditions as EC
from selenium.webdriver.support.ui import WebDriverWait

from .. import config

# Default locators — overridable in Settings so no code change is needed
# when the bank's login/password screens differ.
DEFAULTS = {
    "login_user_locator": "name=loginId",
    "login_password_locator": "name=password",
    "login_submit_locator": "id=login_button",
    "pwd_old_locator": "id=UIPage_009750_oldPassword",
    "pwd_new_locator": "id=UIPage_009750_newPassword",
    "pwd_confirm_locator": "id=UIPage_009750_confirmNewPassword",
    "pwd_submit_locator": "id=UIPage_009750_submit",
    "pwd_alert_ok_locator": "id=ok-button",
    "home_ready_locator": "",          # optional: element proving login succeeded
    "spinner_locator": "css=.spinner, .loading, .blockUI",
}


def _by(spec: str):
    """Parse "id=foo" / "css=.bar" / "xpath=//x" / bare xpath into a Selenium By."""
    if not spec:
        return None
    if "=" in spec:
        kind, _, value = spec.partition("=")
        kind = kind.strip().lower()
        value = value.strip()
        if kind == "id":
            return (By.ID, value)
        if kind == "name":
            return (By.NAME, value)
        if kind == "css":
            return (By.CSS_SELECTOR, value)
        if kind == "xpath":
            return (By.XPATH, value)
    return (By.XPATH, spec)


def _settings() -> dict:
    s = dict(DEFAULTS)
    s.update({k: v for k, v in config.load_settings().items() if k in DEFAULTS})
    return s


def credentials() -> dict:
    """Env vars win over settings. NEVER logged in clear text."""
    st = config.load_settings()
    return {
        "user_id": os.getenv("NBC_USER_ID") or st.get("prelogin_user_id", ""),
        "password": os.getenv("NBC_PASSWORD") or st.get("prelogin_password", ""),
        "new_password": os.getenv("NBC_NEW_PASSWORD") or st.get("prelogin_new_password", ""),
    }


def _wait_spinner(driver, spec: str, timeout: int = 30) -> None:
    target = _by(spec)
    if not target:
        return
    try:
        WebDriverWait(driver, timeout).until(
            EC.invisibility_of_element_located(target))
    except TimeoutException:
        pass


def _present(driver, spec: str, timeout: int = 5) -> bool:
    target = _by(spec)
    if not target:
        return False
    try:
        WebDriverWait(driver, timeout).until(
            EC.visibility_of_element_located(target))
        return True
    except TimeoutException:
        return False


def _type(driver, spec: str, value: str, timeout: int = 20) -> None:
    target = _by(spec)
    el = WebDriverWait(driver, timeout).until(
        EC.visibility_of_element_located(target))
    el.clear()
    el.send_keys(value)


def _click(driver, spec: str, timeout: int = 20) -> None:
    target = _by(spec)
    el = WebDriverWait(driver, timeout).until(EC.element_to_be_clickable(target))
    el.click()



def detect_login_fields(driver) -> dict:
    """Inspect the current page and suggest locators for the login form.
    Used by the "Detect login fields" button and as an automatic fallback."""
    js = """
    function sel(el){
      if(!el) return null;
      if(el.id) return 'id=' + el.id;
      if(el.name) return 'name=' + el.name;
      var p=[],n=el;
      while(n && n.nodeType===1 && p.length<6){
        var i=1,s=n.previousElementSibling;
        while(s){ if(s.tagName===n.tagName) i++; s=s.previousElementSibling; }
        p.unshift(n.tagName.toLowerCase()+'['+i+']'); n=n.parentElement;
      }
      return 'xpath=//'+p.join('/');
    }
    function visible(e){var r=e.getBoundingClientRect();
      return r.width>0 && r.height>0 && getComputedStyle(e).visibility!=='hidden';}
    var pwd=null, inputs=[].slice.call(document.querySelectorAll('input'));
    var vis = inputs.filter(visible);
    for(var i=0;i<vis.length;i++){ if(vis[i].type==='password'){ pwd=vis[i]; break; } }
    var user=null;
    if(pwd){ var idx=vis.indexOf(pwd);
      for(var j=idx-1;j>=0;j--){ var t=vis[j].type;
        if(t==='text'||t==='email'||t===''||t==='tel'){ user=vis[j]; break; } } }
    if(!user){ for(var k=0;k<vis.length;k++){ var t2=vis[k].type;
        if(t2==='text'||t2==='email'){ user=vis[k]; break; } } }
    var btn=null, cands=[].slice.call(document.querySelectorAll(
        "button,input[type=submit],input[type=button],a[role=button]")).filter(visible);
    for(var b=0;b<cands.length;b++){
      var txt=((cands[b].innerText||cands[b].value||'')+'').toLowerCase();
      if(txt.indexOf('log')>=0||txt.indexOf('sign')>=0||txt.indexOf('submit')>=0){
        btn=cands[b]; break; } }
    if(!btn && cands.length) btn=cands[0];
    return {
      user: sel(user), password: sel(pwd), submit: sel(btn),
      all_inputs: vis.slice(0,25).map(function(e){
        return {tag:e.tagName.toLowerCase(), type:e.type||'', id:e.id||'',
                name:e.name||'', placeholder:e.placeholder||'', locator:sel(e)}; }),
      all_buttons: cands.slice(0,15).map(function(e){
        return {text:((e.innerText||e.value||'')+'').trim().slice(0,40),
                id:e.id||'', locator:sel(e)}; })
    };
    """
    try:
        return driver.execute_script("return (function(){" + js + "})();") or {}
    except Exception as e:
        return {"error": str(e)}


def _login(driver, cfg: dict, user_id: str, password: str, log) -> None:
    _wait_spinner(driver, cfg["spinner_locator"])
    _type(driver, cfg["login_user_locator"], user_id)
    _type(driver, cfg["login_password_locator"], password)
    log("Submitting login…")
    _click(driver, cfg["login_submit_locator"])
    _wait_spinner(driver, cfg["spinner_locator"])


def run(driver, url: str, log=None) -> dict:
    """Execute the full entry sequence. Returns a summary dict.
    `log` is a callable used to stream status to the recording console."""
    log = log or (lambda _m: None)
    cfg = _settings()
    creds = credentials()
    result = {"logged_in": False, "password_changed": False, "relogin": False,
              "steps": []}

    if not creds["user_id"] or not creds["password"]:
        log("Pre-login skipped: no credentials configured (Settings or env vars).")
        result["skipped"] = "no credentials"
        return result

    def step(msg):
        log(msg)
        result["steps"].append(msg)

    step(f"Opening {url}")
    driver.get(url)

    step(f"Logging in as {creds['user_id']}")
    try:
        _login(driver, cfg, creds["user_id"], creds["password"], log)
    except TimeoutException:
        found = detect_login_fields(driver)
        result["detected"] = found
        if found.get("user") and found.get("password"):
            step("Configured login locators did not match. Auto-detected: "
                 f"user={found['user']}, password={found['password']}, "
                 f"submit={found.get('submit')} — retrying with these.")
            cfg = dict(cfg, login_user_locator=found["user"],
                       login_password_locator=found["password"],
                       login_submit_locator=found.get("submit")
                       or cfg["login_submit_locator"])
            _login(driver, cfg, creds["user_id"], creds["password"], log)
            result["autodetected_locators"] = {
                "login_user_locator": cfg["login_user_locator"],
                "login_password_locator": cfg["login_password_locator"],
                "login_submit_locator": cfg["login_submit_locator"]}
            step("Save these locators in Settings to make this permanent.")
        else:
            raise RuntimeError(
                "Login user field not found using "
                f"'{cfg['login_user_locator']}'. Fields visible on the page: "
                + ", ".join(
                    f"{i.get('locator')} (type={i.get('type')}, "
                    f"placeholder={i.get('placeholder')})"
                    for i in (found.get("all_inputs") or [])[:8])
                or "no input fields detected — is this the login page?")
    result["logged_in"] = True

    # --- forced password change, only if the screen actually appears ---
    if _present(driver, cfg["pwd_old_locator"], timeout=8):
        new_pwd = creds["new_password"]
        if not new_pwd:
            step("Password change screen appeared but NBC_NEW_PASSWORD is not "
                 "set — cannot continue automatically.")
            result["error"] = "password change required but no new password configured"
            return result

        step("Password change screen detected — changing password")
        _type(driver, cfg["pwd_old_locator"], creds["password"])
        _type(driver, cfg["pwd_new_locator"], new_pwd)
        _type(driver, cfg["pwd_confirm_locator"], new_pwd)
        _wait_spinner(driver, cfg["spinner_locator"])
        _click(driver, cfg["pwd_submit_locator"])
        _wait_spinner(driver, cfg["spinner_locator"])

        if _present(driver, cfg["pwd_alert_ok_locator"], timeout=15):
            _click(driver, cfg["pwd_alert_ok_locator"])
        result["password_changed"] = True

        # Rotate stored credentials so the NEXT run logs in with the new
        # password and changes it back — prevents lockout on repeat runs.
        st = config.load_settings()
        st["prelogin_password"] = new_pwd
        st["prelogin_new_password"] = creds["password"]
        config.save_settings(st)
        step("Credentials rotated for the next run (ping-pong).")

        step("Re-logging in with the new password")
        _wait_spinner(driver, cfg["spinner_locator"])
        if _present(driver, cfg["login_user_locator"], timeout=15):
            _login(driver, cfg, creds["user_id"], new_pwd, log)
        result["relogin"] = True
    else:
        step("No password change prompted — continuing.")

    if cfg["home_ready_locator"]:
        if _present(driver, cfg["home_ready_locator"], timeout=30):
            step("Home screen ready.")
        else:
            step("Warning: home screen element not found; continuing anyway.")

    time.sleep(1)
    step("Pre-flow complete — recording of the transaction starts now.")
    return result
