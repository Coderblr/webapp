    await ws.accept()
    q = execution.get_stream(eid)
    try:
        while True:
            ev = await q.get()
            await ws.send_json(ev)
            if ev.get("type") in ("done", "error"):
                break
    except WebSocketDisconnect:
        pass


# ---------------- reporting (M23) ----------------
@app.get("/api/reports/summary")
def report_summary(db=Depends(db_dep), user=Depends(current_user)):
    execs = db.query(Execution).order_by(Execution.id).all()
    total_p = sum(e.passed for e in execs)
    total_f = sum(e.failed for e in execs)
    return {
        "executions": len(execs),
        "passed": total_p, "failed": total_f,
        "skipped": sum(e.skipped for e in execs),
        "pass_pct": round(100 * total_p / (total_p + total_f), 1)
        if total_p + total_f else 0,
        "trend": [{"id": e.id, "passed": e.passed, "failed": e.failed,
                   "at": str(e.started_at)} for e in execs[-20:]],
        "self_healed": db.query(HealingEvent).filter_by(success=True).count(),
        "framework_changes": db.query(GeneratedArtifact)
                               .filter_by(status="written").count(),
        "ui_changes": db.query(UIChange).count(),
    }


