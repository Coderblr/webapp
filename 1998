# Initialize LLM Client dynamically based on environment
def get_llm_client():
    api_key = os.getenv("AZURE_OPENAI_API_KEY")
    endpoint = os.getenv("AZURE_OPENAI_ENDPOINT")
    
    if api_key and endpoint:
        logger.info("Using Azure OpenAI client.")
        return AzureOpenAI(
            api_key=api_key,
            api_version=os.getenv("AZURE_OPENAI_API_VERSION", "2023-12-01-preview"),
            azure_endpoint=endpoint
        )
    
    # Fallback to standard OpenAI if api_key exists
    standard_key = os.getenv("OPENAI_API_KEY")
    if standard_key:
        logger.info("Using standard OpenAI client.")
        return OpenAI(api_key=standard_key)
        
    logger.warning("No LLM keys found. Running in offline/template mode.")
    return None

class RequirementAgent:
    """Extracts scenarios, steps, and parameters from BRD text or Feature files."""
    def extract_requirements(self, text: str) -> List[Dict[str, Any]]:
        client = get_llm_client()
        if client:
            try:
                deployment = os.getenv("AZURE_OPENAI_DEPLOYMENT_NAME", "gpt-4o")
                prompt = (
                    "Analyze the following Business Requirement Document (BRD) or Feature File. "
                    "Extract all executable test scenarios. For each scenario, define the steps in Cucumber format "
                    "(Given, When, Then) and identify the target pages, locators, and actions needed. "
                    "Return a JSON list of scenarios with the format:\n"
                    "[\n"
                    "  {\n"
                    "    \"scenario\": \"Scenario name\",\n"
                    "    \"steps\": [\n"
                    "      {\"type\": \"Given\", \"text\": \"User is on login page\", \"page\": \"LoginPage\", \"action\": \"navigate\", \"params\": [\"url\"]},\n"
                    "      {\"type\": \"When\", \"text\": \"User enters username 'admin' and password 'admin123'\", \"page\": \"LoginPage\", \"action\": \"input\", \"params\": [\"username\", \"password\"]}\n"
                    "    ]\n"
                    "  }\n"
                    "]"
                )
                response = client.chat.completions.create(
                    model=deployment,
                    messages=[
                        {"role": "system", "content": "You are an expert requirement extraction assistant."},
                        {"role": "user", "content": f"{prompt}\n\nDocument:\n{text}"}
                    ],
                    response_format={"type": "json_object"}
                )
                res_content = response.choices[0].message.content
                data = json.loads(res_content)
                return data.get("scenarios", data)
            except Exception as e:
                logger.error(f"Error during LLM extraction: {e}. Falling back to template mode.")
        
        return self._offline_extract(text)

    def _offline_extract(self, text: str) -> List[Dict[str, Any]]:
        scenarios = []
        current_scenario = None
        
        for line in text.splitlines():
            line = line.strip()
            if line.startswith("Scenario:") or line.startswith("Scenario Outline:"):
                if current_scenario:
                    scenarios.append(current_scenario)
                current_scenario = {"scenario": line.split(":", 1)[1].strip(), "steps": []}
            elif current_scenario and any(line.startswith(prefix) for prefix in ["Given ", "When ", "Then ", "And ", "But "]):
                parts = line.split(" ", 1)
                step_type = parts[0]
                step_text = parts[1]
                
                # Guess page and actions
                page = "GeneralPage"
                action = "click"
                if "login" in step_text.lower() or "username" in step_text.lower():
                    page = "LoginPage"
                elif "search" in step_text.lower():
                    page = "SearchPage"
                
                if "click" in step_text.lower() or "press" in step_text.lower():
                    action = "click"
                elif "enter" in step_text.lower() or "type" in step_text.lower() or "fill" in step_text.lower():
                    action = "input"
                elif "select" in step_text.lower() or "choose" in step_text.lower():
                    action = "dropdown"
                elif "contain" in step_text.lower() or "verify" in step_text.lower() or "should" in step_text.lower():
                    action = "assert"
                
                current_scenario["steps"].append({
                    "type": step_type,
                    "text": step_text,
                    "page": page,
                    "action": action,
                    "params": []
                })
        
        if current_scenario:
            scenarios.append(current_scenario)
            
        if not scenarios:
            # Check if this looks like a generic text request and convert to scenario
            scenarios.append({
                "scenario": "Auto-Extracted Banking Transaction Flow",
                "steps": [
                    {"type": "Given", "text": "User is on home page \"https://www.google.com\"", "page": "LoginPage", "action": "navigate", "params": []},
                    {"type": "When", "text": "User searches for query \"Selenium TestNG\"", "page": "LoginPage", "action": "input", "params": []},
                    {"type": "Then", "text": "Page title should contain \"Selenium\"", "page": "LoginPage", "action": "assert", "params": []}
                ]
            })
        return scenarios

class FrameworkManagerAgent:
    """Maintains Knowledge Graph, detects duplicates, and determines what needs to be created."""
    def analyze_impact(self, extracted_scenarios: List[Dict[str, Any]]) -> Dict[str, Any]:
        db = SessionLocal()
        try:
            missing_steps = []
            missing_pages = {}
            reused_steps = []
            
            for sc in extracted_scenarios:
                for step in sc["steps"]:
                    pattern = step["text"]
                    # Normalize text parameters
                    normalized = re.sub(r"'.*?'|\".*?\"|\d+", "{param}", pattern)
                    
                    db_step = db.query(StepDefinitionModel).filter(
                        StepDefinitionModel.pattern.like(normalized.replace("{param}", "%"))
                    ).first()
                    
                    if db_step:
                        reused_steps.append({"step": pattern, "matched_pattern": db_step.pattern})
                    else:
                        missing_steps.append(step)
                        page_name = step["page"]
                        db_page = db.query(PageModel).filter(PageModel.name == page_name).first()
                        if not db_page:
                            if page_name not in missing_pages:
                                missing_pages[page_name] = []
                            missing_pages[page_name].append(step)
            
            return {
                "missing_steps": missing_steps,
                "missing_pages": missing_pages,
                "reused_steps": reused_steps
            }
        finally:
            db.close()

class ComponentDiscoveryAgent:
    """Discovers custom UI elements and registers them."""
    def discover_and_register(self, element_name: str, html_snippet: str) -> str:
        db = SessionLocal()
        try:
            element_name_clean = element_name.replace(" ", "")
            action_type = "click"
            
            if "select" in html_snippet.lower():
                action_type = "dropdown"
            elif "input type=\"checkbox\"" in html_snippet.lower():
                action_type = "checkbox"
            elif "input type=\"password\"" in html_snippet.lower() or "input type=\"text\"" in html_snippet.lower():
                action_type = "input"
                
            db_comp = db.query(ComponentRegistryModel).filter(ComponentRegistryModel.name == element_name_clean).first()
            if not db_comp:
                new_comp = ComponentRegistryModel(
                    name=element_name_clean,
                    action_type=action_type,
                    java_code=f"// Dynamically discovered component {element_name_clean}\npublic void interactWith{element_name_clean}() {{\n    // code\n}}",
                    description=f"Auto-discovered widget from HTML snippet: {html_snippet[:100]}"
                )
                db.add(new_comp)
                db.commit()
                return f"Discovered new component: {element_name_clean} of type {action_type}"
            return f"Reused existing component: {element_name_clean}"
        finally:
            db.close()

class JavaGeneratorAgent:
    """Generates Java PageObjects, StepDefinitions, and Feature files without duplicating code."""
    def generate_step_definition_code(self, step_text: str, page_name: str, action_type: str) -> Tuple[str, str]:
        clean_text = re.sub(r"'.*?'|\".*?\"", "\"(.*?)\"", step_text)
        method_name = re.sub(r"[^a-zA-Z0-9]", "_", step_text).lower()
        method_name = re.sub(r"_+", "_", method_name).strip("_")
        
        matches = re.findall(r"'.*?'|\".*?\"", step_text)
        args_def = ""
        for i in range(len(matches)):
            args_def += f"String arg{i}, "
        if args_def.endswith(", "):
            args_def = args_def[:-2]

        java_code = (
            f"    @io.cucumber.java.en.When(\"^{clean_text}$\")\n"
            f"    public void {method_name}({args_def}) {{\n"
            f"        // Generated Step implementation linking to page actions\n"
            f"        // {page_name} action: {action_type}\n"
            f"    }}\n"
        )
        return clean_text, java_code

    def append_locator_to_page(self, page_name: str, element_name: str, selector_type: str, selector_val: str):
        file_path = os.path.join(JAVA_FRAMEWORK_SRC, "main", "java", "com", "nbc", "pages", f"{page_name}.java")

        if not os.path.exists(file_path):
            os.makedirs(os.path.dirname(file_path), exist_ok=True)
            initial_content = (
                f"package com.nbc.pages;\n\n"
                f"import com.nbc.base.BaseActions;\n"
                f"import org.openqa.selenium.By;\n"
                f"import org.openqa.selenium.WebDriver;\n\n"
                f"public class {page_name} extends BaseActions {{\n"
                f"    public {page_name}(WebDriver driver) {{\n"
                f"        super(driver);\n"
                f"    }}\n"
                f"}}\n"
            )
            with open(file_path, "w") as f:
                f.write(initial_content)
                
        with open(file_path, "r") as f:
            content = f.read()

        locator_var = re.sub(r"[^a-zA-Z0-9]", "", element_name).lower()
        if f"By {locator_var}" in content:
            return
            
        by_clause = f"By.xpath(\"{selector_val}\")"
        if selector_type == "css":
            by_clause = f"By.cssSelector(\"{selector_val}\")"
        elif selector_type == "id":
            by_clause = f"By.id(\"{selector_val}\")"
        elif selector_type == "name":
            by_clause = f"By.name(\"{selector_val}\")"
            
        new_locator_code = f"    private By {locator_var} = {by_clause};\n"
        new_action_code = (
            f"\n    public void perform{element_name.replace(' ', '')}() {{\n"
            f"        click({locator_var});\n"
            f"    }}\n"
        )
        
        last_brace = content.rfind("}")
        if last_brace != -1:
            updated_content = content[:last_brace] + new_locator_code + new_action_code + "\n" + content[last_brace:]
            with open(file_path, "w") as f:
                f.write(updated_content)

        db = SessionLocal()
        try:
            page_db = db.query(PageModel).filter(PageModel.name == page_name).first()
            if not page_db:
                page_db = PageModel(name=page_name, url="", description="Auto-generated page class")
                db.add(page_db)
                db.commit()
                db.refresh(page_db)
                
            locator_db = db.query(LocatorModel).filter(
                LocatorModel.page_id == page_db.id,
                LocatorModel.element_name == element_name
            ).first()
            if not locator_db:
                locator_db = LocatorModel(
                    page_id=page_db.id,
                    element_name=element_name,
                    selector_type=selector_type,
                    selector_value=selector_val,
                    description=f"Auto-generated locator for {element_name}"
                )
                db.add(locator_db)
                db.commit()
        finally:
            db.close()

    def append_step_definition(self, step_text: str, page_name: str, action_type: str):
        file_path = os.path.join(JAVA_FRAMEWORK_SRC, "test", "java", "com", "nbc", "steps", "SampleSteps.java")
        os.makedirs(os.path.dirname(file_path), exist_ok=True)
        
        # Create SampleSteps file if it doesn't exist
        if not os.path.exists(file_path):
            initial_content = (
                f"package com.nbc.steps;\n\n"
                f"import io.cucumber.java.en.Given;\n"
                f"import io.cucumber.java.en.When;\n"
                f"import io.cucumber.java.en.Then;\n\n"
                f"public class SampleSteps {{\n"
                f"}}\n"
            )
            with open(file_path, "w") as f:
                f.write(initial_content)

        with open(file_path, "r") as f:
            content = f.read()
            
        pattern, java_method_code = self.generate_step_definition_code(step_text, page_name, action_type)
        if pattern in content or step_text in content:
            return
            
        last_brace = content.rfind("}")
        if last_brace != -1:
            updated_content = content[:last_brace] + "\n" + java_method_code + "\n" + content[last_brace:]
            with open(file_path, "w") as f:
                f.write(updated_content)
                
        db = SessionLocal()
        try:
            db_step = db.query(StepDefinitionModel).filter(StepDefinitionModel.pattern == pattern).first()
            if not db_step:
                db_step = StepDefinitionModel(
                    pattern=pattern,
                    java_method=re.sub(r"[^a-zA-Z0-9]", "_", step_text).lower(),
                    java_code=java_method_code,
                    page_associated=page_name
                )
                db.add(db_step)
                db.commit()
        finally:
            db.close()

        # Update the features folder to save a sample feature
        feature_path = os.path.join(JAVA_FRAMEWORK_SRC, "test", "resources", "features", "Sample.feature")
        os.makedirs(os.path.dirname(feature_path), exist_ok=True)
        
        # Read existing feature lines
        feature_content = ""
        if os.path.exists(feature_path):
            with open(feature_path, "r") as f:
                feature_content = f.read()
        
        if step_text not in feature_content:
            if not feature_content.strip():
                feature_content = "Feature: Autonomous Test Automation Execution\n\n  Scenario: Execute Business Flow\n"
            
            # Format and append step
            step_line = f"    {step_text}\n"
            # Try to append to the end of the Scenario
            with open(feature_path, "w") as f:
                f.write(feature_content.rstrip() + "\n" + step_line)

class CompilerAgent:
    """Validates Java file syntax statically to simulate compiler without build tools."""
    def compile_framework(self) -> Tuple[bool, str]:
        # Walk through the directories and find all java files
        java_files = []
        for root, _, files in os.walk(JAVA_FRAMEWORK_SRC):
            for f in files:
                if f.endswith(".java"):
                    java_files.append(os.path.join(root, f))
                    
        logs = []
        success = True
        
        for file_path in java_files:
            try:
                with open(file_path, "r") as f:
                    content = f.read()
                
                # Check for basic compile rules:
                # 1. Matching brackets
                open_brackets = content.count("{")
                close_brackets = content.count("}")
                if open_brackets != close_brackets:
                    success = False
                    logs.append(f"[ERROR] {file_path}: Unbalanced curly brackets. Open: {open_brackets}, Close: {close_brackets}")
                
                # 2. Package matches path
                package_match = re.search(r"package\s+([\w\.]+);", content)
                if package_match:
                    pkg = package_match.group(1)
                    expected_suffix = pkg.replace(".", "/")
                    if expected_suffix not in file_path.replace("\\", "/"):
                        success = False
                        logs.append(f"[ERROR] {file_path}: Package declaration '{pkg}' does not match directories path.")
                
                # 3. Method syntax checks (semicolons inside methods, no double declaration)
                # Find all methods and look for basic structure
                methods = re.findall(r"(public|private|protected)\s+\w+\s+(\w+)\s*\(", content)
                method_names = [m[1] for m in methods]
                duplicates = set([x for x in method_names if method_names.count(x) > 1])
                for dup in duplicates:
                    if dup not in ["setUp", "tearDown", "scenarios", "BasePage", "BaseActions", "SamplePage"]:
                        success = False
                        logs.append(f"[ERROR] {file_path}: Duplicate method declaration found for '{dup}'.")

            except Exception as e:
                success = False
                logs.append(f"[ERROR] {file_path}: Failed reading file: {e}")
                
        if success:
            return True, "Static validation check PASSED. 0 compile errors found in Java sources."
        else:
            return False, "\n".join(logs)

class ExecutionAgent:
    """Executes Cucumber scenarios using python-selenium, capturing reports and logs."""
    def execute_tests(self, transaction_number: str = None) -> Tuple[str, bool, str]:
        lines, feature_label, select_err = self._select_scenario_lines(transaction_number)
        if select_err:
            return select_err, False, ""

        logs = ["[INFO] TestNG Suite: 'Enterprise Automation Suite' - Started",
                "[INFO] Running TestRunner: com.nbc.runners.TestRunner"]
        if transaction_number:
            logs.append(f"[INFO] Filtering to transaction: @screen{transaction_number} — {feature_label}")

        success = True
        step_results = []
        driver = None

        try:
            # Initialize live Edge browser
            logger.info("Initializing Microsoft Edge browser for live execution...")
            edge_options = EdgeOptions()
            edge_options.add_argument("--remote-allow-origins=*")
            # Run headless to avoid opening actual browser windows if GUI is absent
            # but allow GUI by default
            edge_options.add_argument("--headless=new")

            # Use a local msedgedriver.exe if present, so offline/restricted-network
            # machines don't need Selenium Manager to reach the internet.
            # Convention: <project root>/drivers/msedgedriver.exe (auto-detected).
            # Override with EDGE_DRIVER_PATH env var if you keep it somewhere else.
            edge_driver_path = os.getenv("EDGE_DRIVER_PATH") or default_edge_driver_path()
            if edge_driver_path and os.path.exists(edge_driver_path):
                logger.info(f"Using local Edge driver: {edge_driver_path}")
                edge_service = EdgeService(executable_path=edge_driver_path)
                driver = webdriver.Edge(service=edge_service, options=edge_options)
            else:
                # Falls back to Selenium Manager, which auto-downloads the driver
                # (requires internet access).
                driver = webdriver.Edge(options=edge_options)
            driver.maximize_window()
            driver.implicitly_wait(4)
            
            # Step runner
            for line in lines:
                line_str = line.strip()
                if not line_str or line_str.startswith("Feature:") or line_str.startswith("Scenario:"):
                    logs.append(f"[CUCUMBER] {line_str}")
                    continue
                
                # Parse Cucumber prefixes
                prefix_match = re.match(r"^(Given|When|Then|And|But)\s+(.*)$", line_str)
                if not prefix_match:
                    continue
                
                step_type = prefix_match.group(1)
                step_text = prefix_match.group(2)
                logs.append(f"[CUCUMBER] Executing step: {step_type} {step_text}")
                
                # Execute actions in Selenium based on step parsing
                try:
                    # 1. Navigation Given User is on home page "url"
                    nav_match = re.search(r"home page\s+['\"](.*?)['\"]|on\s+['\"](.*?)['\"]", step_text)
                    if nav_match:
                        url = nav_match.group(1) or nav_match.group(2)
                        driver.get(url)
                        logs.append(f"  └─ Navigate to URL: {url}")
                        step_results.append((step_text, "PASSED", None))
                        continue
                    
                    # 2. Enter Text When User searches for query "text"
                    input_match = re.search(r"searches for query\s+['\"](.*?)['\"]|enters\s+['\"](.*?)['\"]", step_text)
                    if input_match:
                        val = input_match.group(1) or input_match.group(2)
                        # Try to find input search box name="q" or class or type=text
                        try:
                            elem = driver.find_element(By.NAME, "q")
                        except:
                            elem = driver.find_element(By.XPATH, "//input[@type='text'] | //input[@placeholder]")
                        elem.clear()
                        elem.sendKeys(val) if hasattr(elem, 'sendKeys') else elem.send_keys(val)
                        elem.submit()
                        logs.append(f"  └─ Entered value: {val} and submitted form.")
                        step_results.append((step_text, "PASSED", None))
                        continue
                    
                    # 3. Assert Title Then Page title should contain "keyword"
                    assert_match = re.search(r"title should contain\s+['\"](.*?)['\"]", step_text)
                    if assert_match:
                        kw = assert_match.group(1)
                        title = driver.title
                        if kw.lower() in title.lower():
                            logs.append(f"  └─ Assertion PASSED: Title '{title}' contains '{kw}'")
                            step_results.append((step_text, "PASSED", None))
                        else:
                            raise AssertionError(f"Title '{title}' does not contain expected keyword '{kw}'")
                        continue
                        
                    # Generic action matching: click, select, etc.
                    if "click" in step_text.lower() or "press" in step_text.lower():
                        # Try finding a button/link matching text
                        words = step_text.split(" ")
                        btn_name = words[-2] if len(words) > 2 else "button"
                        elem = driver.find_element(By.XPATH, f"//button[contains(., '{btn_name}')] | //input[@type='submit']")
                        elem.click()
                        logs.append(f"  └─ Clicked button: {btn_name}")
                        step_results.append((step_text, "PASSED", None))
                        continue
                        
                except Exception as step_err:
                    logs.append(f"  └─ [ERROR] Step failed: {step_err}")
                    success = False
                    # Capture screenshot on failure
                    screenshot_dir = os.path.join(JAVA_FRAMEWORK_TARGET, "screenshots")
                    os.makedirs(screenshot_dir, exist_ok=True)
                    screenshot_path = os.path.join(screenshot_dir, "failure.png")
                    driver.save_screenshot(screenshot_path)
                    
                    step_results.append((step_text, "FAILED", str(step_err)))
                    break
                    
        except Exception as driver_err:
            success = False
            logs.append(f"[ERROR] Driver issue: {driver_err}")
        finally:
            if driver:
                driver.quit()
                
        # Generate Extent/Cucumber Report HTML
        report_dir = JAVA_FRAMEWORK_TARGET
        os.makedirs(report_dir, exist_ok=True)
        report_path = os.path.join(report_dir, "cucumber-reports.html")
        
        report_html = f"""
        <!DOCTYPE html>
        <html>
        <head>
            <title>Extent Reports - Test Execution Report</title>
            <style>
                body {{ font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f8f9fa; margin: 20px; }}
                .card {{ background: #fff; border-radius: 8px; padding: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); margin-bottom: 20px; }}
                .header {{ display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid #eee; padding-bottom: 10px; }}
                .status-pass {{ color: #28a745; font-weight: bold; }}
                .status-fail {{ color: #dc3545; font-weight: bold; }}
                .step {{ margin: 10px 0; padding: 10px; border-left: 4px solid #007bff; background: #f1f3f5; display:flex; justify-content:space-between; }}
                .step.FAILED {{ border-left-color: #dc3545; background-color: #fdf2f2; }}
                .step.PASSED {{ border-left-color: #28a745; background-color: #f4faf6; }}
            </style>
        </head>
        <body>
            <div class="card">
                <div class="header">
                    <h2>Test Execution Summary</h2>
                    <span class="{"status-pass" if success else "status-fail"}">
                        {"PASSED" if success else "FAILED"}
                    </span>
                </div>
                <div style="margin-top: 15px;">
                    <strong>Feature:</strong> Autonomous Test Automation Execution<br>
                    <strong>Timestamp:</strong> {time.strftime('%Y-%m-%d %H:%M:%S')}
                </div>
            </div>
            
            <div class="card">
                <h3>Steps Trace</h3>
                {"".join(f'<div class="step {res[1]}"><span>{res[0]}</span><span class="status-{res[1].lower()}">{res[1]}</span></div>' for res in step_results)}
            </div>
        </body>
        </html>
        """
        with open(report_path, "w") as f:
            f.write(report_html)

        logs.append(f"[INFO] Test Execution finished. Status: {'PASS' if success else 'FAIL'}")
        
        # Save Log to DB
        db = SessionLocal()
        try:
            log_entry = ExecutionLogModel(
                status="PASS" if success else "FAIL",
                output_log="\n".join(logs),
                screenshot_path=os.path.abspath(os.path.join(report_dir, "screenshots/failure.png")) if not success else ""
            )
            db.add(log_entry)
            db.commit()
        finally:
            db.close()
            
        return "\n".join(logs), success, "target/cucumber-reports.html"

    # Matches @txn123456, @txn_123456, @screen123456, @screen_123456 — with or
    # without a trailing descriptive name glued directly on (e.g. @txn021073RemittancePaymentToDeposit).
    TXN_TAG_RE = re.compile(r'^@(?:txn|screen)_?0*(\d+)', re.IGNORECASE)

    def _normalize_txn_digits(self, value: str) -> str:
        """Strips everything but digits, then strips leading zeros (keeping at least one digit)
        so '021073', '21073', and '0021073' all normalize to the same thing for comparison."""
        digits = re.sub(r'\D', '', value or '')
        return digits.lstrip('0') or digits or ''

    def _select_scenario_lines(self, transaction_number: str = None):
        """
        Returns (lines, feature_label, error_message).

        With no transaction_number: preserves the old default — runs Sample.feature
        in full, unchanged behavior for existing callers.

        With a transaction_number: scans every .feature file under
        java-framework/src/test/resources/features/ for a Scenario tagged with that
        transaction/screen number, and returns just that scenario's Given/When/Then/And
        lines — not the whole file, so multi-scenario feature files don't run unrelated
        scenarios. Recognizes both AI-recorded tags (@screen<number>) and real hand-written
        framework tags (@txn<number>..., @txn_<number>..., with or without a name glued on,
        and regardless of leading zeros) — e.g. all of @txn021073, @txn_021073,
        @txn021073RemittancePaymentToDeposit, and @txn_25060IssueOfCash match "21073"/"25060".
        """
        features_dir = os.path.join(JAVA_FRAMEWORK_SRC, "test", "resources", "features")

        if not transaction_number:
            feature_path = os.path.join(features_dir, "Sample.feature")
            if not os.path.exists(feature_path):
                return None, None, "No Sample.feature found to execute."
            with open(feature_path, "r") as f:
                return f.readlines(), "Sample.feature", None

        if not os.path.isdir(features_dir):
            return None, None, f"Features folder not found: {features_dir}"

        query_digits = self._normalize_txn_digits(transaction_number)
        available_tags = set()
        # Fallback candidate if no @txn/@screen-prefixed tag matches: a tag that merely
        # *contains* the number anywhere (covers oddly-formatted tags we didn't anticipate).
        loose_fallback = None

        for fname in sorted(os.listdir(features_dir)):
            if not fname.endswith(".feature"):
                continue
            fpath = os.path.join(features_dir, fname)
            try:
                with open(fpath, "r", encoding="utf-8", errors="ignore") as f:
                    raw_lines = f.readlines()
            except Exception:
                continue

            feature_name = ""
            i = 0
            while i < len(raw_lines):
                stripped = raw_lines[i].strip()
                if stripped.startswith("Feature:"):
                    feature_name = stripped
                if stripped.startswith("@"):
                    matched_this_line = False
                    for tag in stripped.split():
                        available_tags.add(tag)
                        m = self.TXN_TAG_RE.match(tag)
                        if m and query_digits and self._normalize_txn_digits(m.group(1)) == query_digits:
                            matched_this_line = True
                        elif loose_fallback is None and query_digits and query_digits in re.sub(r'\D', '', tag):
                            loose_fallback = (fname, i, feature_name)

                    if matched_this_line:
                        result = self._extract_scenario_block(raw_lines, i, feature_name)
                        if result:
                            return result[0], f"{fname} — {result[1]}", None
                i += 1

        # No strict @txn/@screen match anywhere — try the loose fallback if one was seen.
        if loose_fallback:
            fname, tag_line_idx, feature_name = loose_fallback
            fpath = os.path.join(features_dir, fname)
            with open(fpath, "r", encoding="utf-8", errors="ignore") as f:
                raw_lines = f.readlines()
            result = self._extract_scenario_block(raw_lines, tag_line_idx, feature_name)
            if result:
                return result[0], f"{fname} — {result[1]} (loose match)", None

        if len(available_tags) > 40:
            shown = sorted(available_tags)[:40]
            hint = f" {len(available_tags)} tags exist in total; first 40: {', '.join(shown)} …"
        elif available_tags:
            hint = f" Tags found in existing feature files: {', '.join(sorted(available_tags))}"
        else:
            hint = " No tagged scenarios found at all — record or import a transaction first."
        return None, None, f"No scenario matching transaction '{transaction_number}' was found.{hint}"

    def _extract_scenario_block(self, raw_lines, tag_line_idx, feature_name):
        """Given the index of a tag line, finds the Scenario line right after it and
        collects that scenario's lines up to the next tag/Scenario boundary."""
        j = tag_line_idx + 1
        while j < len(raw_lines) and not raw_lines[j].strip():
            j += 1
        if j >= len(raw_lines) or not raw_lines[j].strip().startswith("Scenario"):
            return None
        scenario_lines = [feature_name + "\n", raw_lines[j]]
        k = j + 1
        while k < len(raw_lines):
            s = raw_lines[k].strip()
            if s.startswith("@") or s.startswith("Scenario"):
                break
            scenario_lines.append(raw_lines[k])
            k += 1
        return scenario_lines, raw_lines[j].strip()

class SelfHealingAgent:
    """Attempts to self-heal XPath or Wait parameters on element interaction failure."""
    def heal_locator(self, page_name: str, element_name: str, error_msg: str, latest_html: str) -> Tuple[bool, str]:
        logger.info(f"Self-healing triggered for element {element_name} in {page_name}...")
        
        new_xpath = None
        # Dynamic selector recovery rules
        if f"id=\"{element_name.lower()}\"" in latest_html:
            new_xpath = f"//*[@id='{element_name.lower()}']"
        elif f"name=\"{element_name.lower()}\"" in latest_html:
            new_xpath = f"//*[@name='{element_name.lower()}']"
        elif element_name in latest_html:
            new_xpath = f"//*[contains(text(), '{element_name}')]"
            
        if not new_xpath:
            new_xpath = f"//button[contains(., '{element_name}')] | //input[@placeholder='{element_name}']"
            
        file_path = os.path.join(JAVA_FRAMEWORK_SRC, "main", "java", "com", "nbc", "pages", f"{page_name}.java")
        if os.path.exists(file_path):
            with open(file_path, "r") as f:
                content = f.read()
                
            locator_var = re.sub(r"[^a-zA-Z0-9]", "", element_name).lower()
            pattern = rf"private By ({locator_var})\s*=\s*By\..*?;"
            replacement = rf"private By \1 = By.xpath(\"{new_xpath}\");"
            
            new_content = re.sub(pattern, replacement, content, flags=re.IGNORECASE)
            with open(file_path, "w") as f:
                f.write(new_content)
                
            db = SessionLocal()
            try:
                page_db = db.query(PageModel).filter(PageModel.name == page_name).first()
                if page_db:
                    loc_db = db.query(LocatorModel).filter(
                        LocatorModel.page_id == page_db.id,
                        LocatorModel.element_name == element_name
                    ).first()
                    if loc_db:
                        loc_db.selector_type = "xpath"
                        loc_db.selector_value = new_xpath
                        db.commit()
            finally:
                db.close()
                
            return True, f"Successfully self-healed {element_name} locator to: {new_xpath}"
        return False, "Java file not found."
