@app.get("/framework/archive/status")
def archive_status():
    """Browse the permanent archive (data/archive/<Txn>/<timestamp>/...) —
    every file version ever replaced by an approved AI commit, never deleted."""
    if not config.ARCHIVE_DIR.exists():
        return {"count": 0, "entries": []}
    entries = []
    for txn_dir in sorted(config.ARCHIVE_DIR.iterdir()):
        if not txn_dir.is_dir():
            continue
        for ts_dir in sorted(txn_dir.iterdir(), reverse=True):
            if not ts_dir.is_dir():
                continue
            files = sorted(f.name for f in ts_dir.iterdir() if f.is_file())
            entries.append({"txn": txn_dir.name, "timestamp": ts_dir.name,
                           "files": files, "file_count": len(files)})
    return {"count": len(entries), "entries": entries}


