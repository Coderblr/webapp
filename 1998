# ─── Live Recorder API (in-frontend, no Chrome extension) ───────────────────────
#
# A single active session is buffered in memory. The dashboard starts a session,
# the bookmarklet script (served below) streams each step here, and Stop & Save
# converts the buffer into a real RecordingSession + runs the RecorderAgent —
# reusing exactly the same pipeline the extension used.

import uuid as _uuid
from datetime import datetime as _dt

# In-memory live session store: { live_id: {meta + steps[]} }
LIVE_SESSIONS: Dict[str, Dict[str, Any]] = {}
ACTIVE_LIVE_ID: Optional[str] = None


@app.post("/api/recorder/live/start")
def live_start(data: LiveStartInput):
    """Open a new live recording session and make it the active one."""
    global ACTIVE_LIVE_ID
    live_id = _uuid.uuid4().hex[:12]
    LIVE_SESSIONS[live_id] = {
        "session_name": data.session_name or f"Live_{_dt.now().strftime('%Y%m%d_%H%M%S')}",
        "transaction_type": data.transaction_type or "generic",
        "started_at": _dt.now(),
        "steps": [],
    }
    ACTIVE_LIVE_ID = live_id
    return {"live_id": live_id, "active": True}


@app.get("/api/recorder/live/active")
def live_active():
    """The bookmarklet polls this to discover the current active session."""
    if ACTIVE_LIVE_ID and ACTIVE_LIVE_ID in LIVE_SESSIONS:
        sess = LIVE_SESSIONS[ACTIVE_LIVE_ID]
        return {"active": True, "live_id": ACTIVE_LIVE_ID, "count": len(sess["steps"])}
    return {"active": False, "live_id": None, "count": 0}


@app.get("/api/recorder/target-url")
def recorder_target_url():
    """
    Reads the real application URL (baseUrl / url) from the framework's
    per-environment common.properties (or the legacy config.properties as a
    fallback) so the dashboard can auto-open the NBC target site when Start
    Recording is clicked — one config value, no need to type/paste the URL a
    second time in the browser.
    """
    config = read_config_properties()
    value = config.get("baseUrl") or config.get("url")
    if value and value.strip() and value.strip().lower() != "https://example.com":
        return {"url": value.strip(), "found": True}
    return {"url": None, "found": False}


@app.post("/api/recorder/live/step")
def live_step(data: LiveStepInput):
    """Receive a single step from the in-page recorder script."""
    sess = LIVE_SESSIONS.get(data.live_id)
    if not sess:
        raise HTTPException(status_code=404, detail="Live session not found or already stopped.")
    # Re-index server-side so counts stay consistent regardless of client
    step = dict(data.step or {})
    step["step_index"] = len(sess["steps"]) + 1
    sess["steps"].append(step)
    return {"count": len(sess["steps"])}


@app.get("/api/recorder/live/status/{live_id}")
def live_status(live_id: str):
    """The dashboard polls this while recording to show the live step feed."""
    sess = LIVE_SESSIONS.get(live_id)
    if not sess:
        return {"found": False, "active": False, "count": 0, "steps": []}
    # Return a light preview (last 50 steps) for the live feed
    preview = []
    for s in sess["steps"][-50:]:
        elem = s.get("element") or {}
        best = (elem.get("best_locator") or {})
        preview.append({
            "step_index": s.get("step_index"),
            "action": s.get("action"),
            "page_title": s.get("page_title", ""),
            "element_name": elem.get("element_name", ""),
            "locator_type": best.get("type"),
            "locator_value": best.get("value"),
            "value": s.get("value") or s.get("selected_text") or "",
        })
    return {
        "found": True,
        "active": ACTIVE_LIVE_ID == live_id,
        "count": len(sess["steps"]),
        "steps": preview,
    }


@app.post("/api/recorder/live/stop")
def live_stop(data: LiveStopInput):
    """Finalize a live session: persist steps and run the RecorderAgent pipeline."""
    global ACTIVE_LIVE_ID
    sess = LIVE_SESSIONS.get(data.live_id)
    if not sess:
        raise HTTPException(status_code=404, detail="Live session not found.")

    if ACTIVE_LIVE_ID == data.live_id:
        ACTIVE_LIVE_ID = None  # stop accepting new steps immediately

    raw_steps = sess["steps"]
    if not raw_steps:
        LIVE_SESSIONS.pop(data.live_id, None)
        raise HTTPException(status_code=400, detail="No steps were captured. Nothing to save.")

    duration = int((_dt.now() - sess["started_at"]).total_seconds())

    db = SessionLocal()
    try:
        session = RecordingSessionModel(
            session_name=sess["session_name"],
            transaction_type=sess["transaction_type"],
            total_steps=len(raw_steps),
            duration_seconds=duration,
            status="captured",
        )
        db.add(session)
        db.flush()

        for idx, step in enumerate(raw_steps, start=1):
            elem = step.get("element") or {}
            best_loc = elem.get("best_locator") or None
            db.add(RecordedStepModel(
                session_id=session.id,
                step_index=step.get("step_index", idx),
                action=step.get("action", "click"),
                url=step.get("url", "") or "",
                page_title=step.get("page_title", "") or "",
                element_tag=elem.get("tag", "") or "",
                element_name=elem.get("element_name", "") or "",
                element_text=elem.get("text", "") or "",
                locator_type=(best_loc or {}).get("type"),
                locator_value=(best_loc or {}).get("value"),
                all_locators=json.dumps(elem.get("locators", {})),
                input_value=step.get("value") or step.get("selected_text") or "",
                timestamp=step.get("timestamp", "") or "",
            ))

        db.commit()
        session_id = session.id
    except Exception as e:
        db.rollback()
        raise HTTPException(status_code=500, detail=str(e))
    finally:
        db.close()

    # Clear the in-memory buffer now that it's persisted
    LIVE_SESSIONS.pop(data.live_id, None)

    # Run the same generation pipeline the extension flow used
    agent = RecorderAgent()
    result = agent.process_session(session_id)

    return {
        "session_id": session_id,
        "steps_saved": len(raw_steps),
        "duration_seconds": duration,
        "locators_stored": result.get("locators_stored", 0),
        "pages_discovered": result.get("pages_discovered", 0),
        "page_objects_generated": result.get("page_objects_generated", []),
        "feature_file": result.get("feature_file", ""),
        "message": result.get("message", "Session saved successfully"),
    }


@app.get("/api/recorder/live/script")
@app.get("/r")  # short alias — fewer characters to type by hand when clipboard/DevTools/bookmarks are all blocked
def live_recorder_script():
    """Serve the in-page recorder JS (loaded by the bookmarklet, or by hand-typed address-bar code)."""
    path = os.path.join(BACKEND_DIR, "static", "live_recorder.js")
    if os.path.exists(path):
        return FileResponse(path, media_type="application/javascript")
    raise HTTPException(status_code=404, detail="live_recorder.js not found")


# Serves static UI frontend files
@app.get("/")
def serve_index():
    index_path = os.path.join(FRONTEND_DIR, "index.html")
    if os.path.exists(index_path):
        return FileResponse(index_path)
    return {"message": f"Frontend index.html not found. Please place static files in {FRONTEND_DIR}"}

@app.get("/{path:path}")
def serve_static(path: str):
    static_file = os.path.join(FRONTEND_DIR, path)
    if os.path.exists(static_file) and os.path.isfile(static_file):
        return FileResponse(static_file)
    # Default fallback to serve index.html for single page routing
    index_path = os.path.join(FRONTEND_DIR, "index.html")
    if os.path.exists(index_path):
        return FileResponse(index_path)
    raise HTTPException(status_code=404, detail="Static resource not found.")
