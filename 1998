keep any incomplete trailing event

      for (const event of events) {
        const line = event.trim();
        if (!line.startsWith("data:")) continue;
        const data = line.slice(5).trim();
        if (data === "[DONE]") continue;

        let payload;
        try {
          payload = JSON.parse(data);
        } catch {
          continue; // skip malformed events
        }
        if (payload.error) {
          const error = new Error(payload.error);
          error.partialText = fullText;
          throw error;
        }
        if (payload.delta) {
          fullText += payload.delta;
          onDelta(payload.delta);
        }
      }
    }

    if (!fullText) {
      throw new Error("The server returned an empty response.");
    }
    return fullText;
  },

  /** Non-streaming request (used as a fallback). */
  async sendMessage(message, history) {
    let response;
    try {
      response = await fetch(`${API_BASE_URL}/chat`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: this.buildBody(message, history),
      });
    } catch {
      throw new Error(
        "Could not reach the backend. Make sure the FastAPI server is running on " +
          `${API_BASE_URL} (see README).`
      );
    }

    let payload = null;
    try {
      payload = await response.json();
    } catch {
      /* non-JSON body — handled below */
    }

    if (!response.ok) {
      const detail =
        payload && typeof payload.detail === "string"
          ? payload.detail
          : `The server returned an error (HTTP ${response.status}).`;
      throw new Error(detail);
    }

    if (!payload || typeof payload.response !== "string") {
      throw new Error("The server returned an unexpected response format.");
    }
    return payload.response;
  },

  /** @returns {Promise<boolean>} whether the backend is reachable. */
  async checkHealth() {
    try {
      const response = await fetch(`${API_BASE_URL}/health`);
      const payload = await response.json();
      return response.ok && payload.status === "running";
    } catch {
      return false;
    }
  },
};

/* ------------------------------------------------------------
   app — orchestration
   ------------------------------------------------------------ */

const app = (() => {
  let state = { conversations: [], activeId: null };
  let isSending = false;

  const getActive = () =>
    state.conversations.find((c) => c.id === state.activeId) || null;

  function persist() {
    store.save(state);
  }

  function refreshSidebar() {
    ui.renderSidebar(state.conversations, state.activeId, {
      onSelect: switchConversation,
      onDelete: deleteConversation,
    });
  }

  function renderActiveConversation() {
    ui.clearMessages();
    const conversation = getActive();
    if (conversation) {
      conversation.messages.forEach((message) => ui.appendMessage(message));
    }
  }

  /** Create a new empty conversation and make it active. */
  function createConversation() {
    const conversation = {
      id: store.newId(),
      title: "New chat",
      messages: [],
      updatedAt: Date.now(),
    };
    state.conversations.push(conversation);
    state.activeId = conversation.id;
    persist();
    return conversation;
  }

  /** Return the active conversation, creating one if none exists. */
  function ensureActiveConversation() {
    return getActive() || createConversation();
  }

  function switchConversation(id) {
    if (isSending || id === state.activeId) {
      ui.setSidebarOpen(false);
      return;
    }
    state.activeId = id;
    persist();
    refreshSidebar();
    renderActiveConversation();
    ui.setSidebarOpen(false);
    ui.input.focus();
  }

  function deleteConversation(id) {
    if (isSending) return;
    const conversation = state.conversations.find((c) => c.id === id);
    if (!conversation) return;
    if (!window.confirm(`Delete "${conversation.title}"? This cannot be undone.`)) return;

    state.conversations = state.conversations.filter((c) => c.id !== id);
    if (state.activeId === id) {
      const mostRecent = [...state.conversations].sort(
        (a, b) => b.updatedAt - a.updatedAt
      )[0];
      state.activeId = mostRecent ? mostRecent.id : null;
      renderActiveConversation();
    }
    persist();
    refreshSidebar();
  }

  function handleNewChat() {
    if (isSending) return;
    const active = getActive();
    // Reuse the current conversation if it's already empty.
    if (active && active.messages.length === 0) {
      ui.setSidebarOpen(false);
      ui.input.focus();
      return;
    }
    createConversation();
    refreshSidebar();
    renderActiveConversation();
    ui.setSidebarOpen(false);
    ui.input.focus();
  }

  function addMessage(conversation, role, content) {
    const message = { role, content, timestamp: Date.now() };
    conversation.messages.push(message);
    conversation.updatedAt = Date.now();
    if (role === "user" && conversation.title === "New chat") {
      conversation.title = store.titleFrom(conversation.messages);
    }
    persist();
    refreshSidebar();
    return message;
  }

  async function handleSend() {
    const text = ui.input.value.trim();
    if (!text || isSending) return;

    isSending = true;

    const conversation = ensureActiveConversation();
    const history = conversation.messages.slice(); // context = turns before this one

    addMessage(conversation, "user", text);
    ui.appendMessage(conversation.messages[conversation.messages.length - 1]);
    ui.input.value = "";
    ui.autoResizeInput();
    ui.setLoading(true);

    // Show typing dots until the first token arrives, then stream.
    let removeTyping = ui.showTypingIndicator();
    let streamer = null;
    let accumulated = "";

    const onDelta = (delta) => {
      if (!streamer) {
        removeTyping();
        removeTyping = null;
        streamer = ui.beginStreamingMessage();
      }
      accumulated += delta;
      streamer.update(accumulated);
    };

    try {
      const fullText = await api.streamMessage(text, history, onDelta);
      if (streamer) {
        streamer.finalize(fullText);
      }
      addMessage(conversation, "assistant", fullText);
    } catch (error) {
      if (removeTyping) removeTyping();
      // Keep any partial reply that streamed before the failure.
      if (streamer && accumulated) {
        streamer.finalize(accumulated);
        addMessage(conversation, "assistant", accumulated);
      } else if (streamer) {
        streamer.remove();
      }
      // Errors are shown in the chat but not persisted to history.
      ui.appendMessage({
        role: "assistant",
        content: `⚠ ${error.message}`,
        timestamp: Date.now(),
        isError: true,
      });
    } finally {
      isSending = false;
      ui.setLoading(false);
    }
  }

  async function pollHealth() {
    ui.setConnectionStatus((await api.checkHealth()) ? "online" : "offline");
  }

  function bindEvents() {
    // Send button
    ui.sendBtn.addEventListener("click", handleSend);

    // Enter to send, Shift+Enter for a new line
    ui.input.addEventListener("keydown", (event) => {
      if (event.key === "Enter" && !event.shiftKey) {
        event.preventDefault();
        handleSend();
      }
    });

    // Enable/disable Send with content; auto-grow the textarea
    ui.input.addEventListener("input", () => {
      ui.sendBtn.disabled = !ui.input.value.trim() || isSending;
      ui.autoResizeInput();
    });

    // New Chat (sidebar)
    document.getElementById("new-chat-btn").addEventListener("click", handleNewChat);

    // Sidebar open/close (mobile drawer)
    document
      .getElementById("sidebar-open-btn")
      .addEventListener("click", () => ui.setSidebarOpen(true));
    document
      .getElementById("sidebar-close-btn")
      .addEventListener("click", () => ui.setSidebarOpen(false));
    document
      .getElementById("sidebar-backdrop")
      .addEventListener("click", () => ui.setSidebarOpen(false));

    // Suggestion chips on the empty state
    document.querySelectorAll(".chip[data-suggestion]").forEach((chip) => {
      chip.addEventListener("click", () => {
        ui.input.value = chip.dataset.suggestion;
        ui.input.dispatchEvent(new Event("input"));
        handleSend();
      });
    });

    // Copy buttons inside rendered code blocks (event delegation)
    document.getElementById("messages").addEventListener("click", (event) => {
      const button = event.target.closest("[data-copy-code]");
      if (!button) return;
      const code = button.closest(".codeblock")?.querySelector("code");
      if (code) ui.copyToClipboard(code.textContent, button);
    });
  }

  function init() {
    state = store.load();
    if (!getActive() && state.conversations.length) {
      state.activeId = [...state.conversations].sort(
        (a, b) => b.updatedAt - a.updatedAt
      )[0].id;
    }
    bindEvents();
    refreshSidebar();
    renderActiveConversation();
    ui.input.focus();
    pollHealth();
    setInterval(pollHealth, 30_000); // re-check the backend every 30s
  }

  return { init };
})();

document.addEventListener("DOMContentLoaded", app.init);
