    let videoStream = null;

    // Backend origin the bookmarklet must call. When the frontend is served
    // by the backend, API_BASE is "" so we derive from location; otherwise
    // default to localhost:8000.
    const RECORDER_BACKEND = (API_BASE && API_BASE.length)
        ? API_BASE
        : (window.location.origin && window.location.origin.startsWith('http')
            ? window.location.origin
            : 'http://localhost:8000');

    // Build the bookmarklet href once the DOM is ready.
    let recorderLoaderScript = '';
    let recorderShortManualCode = '';
    (function buildBookmarklet() {
        const link = document.getElementById('recorder-bookmarklet');
        recorderLoaderScript =
            "(function(){var s=document.createElement('script');" +
            "window.__AI_RECORDER_BACKEND__='" + RECORDER_BACKEND + "';" +
            "s.src='" + RECORDER_BACKEND + "/api/recorder/live/script?t='+Date.now();" +
            "document.body.appendChild(s);})();";
        if (link) link.setAttribute('href', 'javascript:' + encodeURIComponent(recorderLoaderScript));

        // Shortest possible version for hand-typing (no clipboard, no DevTools):
        // live_recorder.js now detects its own backend from the <script src>, so this
        // doesn't need to set window.__AI_RECORDER_BACKEND__ separately — one URL, done.
        recorderShortManualCode = "javascript:(function(){var s=document.createElement('script');" +
            "s.src='" + RECORDER_BACKEND + "/r';document.body.appendChild(s)})()";
        const manualEl = document.getElementById('recorder-manual-code');
        if (manualEl) manualEl.textContent = recorderShortManualCode;
    })();

    // Fallback for browsers/IT policies that block dragging javascript: links onto
    // the bookmarks bar, or that disable DevTools outright. Same loader code either
    // way — paste into DevTools Console, OR into the address bar after typing
    // "javascript:" yourself (browsers strip a pasted javascript: prefix).
    window.copyConsoleScript = function() {
        const btn = document.getElementById('btn-copy-console-script');
        const restore = () => { btn.textContent = '📋 Copy Recorder Code'; };
        navigator.clipboard.writeText(recorderLoaderScript)
            .then(() => {
                btn.textContent = '✅ Copied — paste into Console or address bar';
                setTimeout(restore, 3000);
            })
            .catch(() => {
                // Clipboard API blocked (also common on locked-down/VDI browsers) —
                // fall back to a selectable prompt so it can be copied manually
                // with Ctrl+C, which usually still works even when the page-level
                // clipboard API is disabled by policy.
                window.prompt(
                    'Copy this (Ctrl+C), then either paste into DevTools Console (F12) and press Enter,\n' +
                    'or click the target tab\'s address bar, type "javascript:" first, paste right after it, and press Enter:',
                    recorderLoaderScript
                );
            });
    };

    window.startLiveRecording = function() {
