_CANON = {"feature": "src/test/resources/features/{name}.feature",
          "stepdef": "src/test/java/stepdefinitions/{name}Steps.java",
          "pageobject": "src/test/java/pages/{name}Page.java",
          "runner": "src/test/java/runners/{name}Runner.java",
          "testdata": "src/test/resources/testdata/{name}.json"}


def _safe(name: str) -> str:
    """Keep alphanumerics and PRESERVE capitalization (SBIBranchChannelPage
    must not become Sbibranchchannelpage), uppercasing only the first char
    so the filename always matches the public class name."""
    s = "".join(c for c in name if c.isalnum())
    s = s.lstrip("0123456789")          # class names cannot start with a digit
    return (s[:1].upper() + s[1:]) if s else "Generated"


_PUBLIC_CLASS = re.compile(r"public\s+(?:final\s+|abstract\s+)?class\s+([A-Za-z_$][\w$]*)")


def _declared_class(content: str) -> str | None:
    """The Java filename MUST equal the public class name declared inside the
    file. Trust the code, never a normalized path."""
    m = _PUBLIC_CLASS.search(content or "")
    return m.group(1) if m else None



def _balance_java(content: str) -> tuple[str, list[str]]:
    """Auto-repair the most common LLM Java syntax slip: a statement line whose
    round brackets are unbalanced (missing closing parens before the ';').
    Only touches single-line statements ending in ');' or ';' and never removes
    code — appends the missing ')' just before the semicolon."""
    fixes, out = [], []
    for i, line in enumerate(content.splitlines(), 1):
        stripped = line.rstrip()
        if stripped.endswith(";") and not stripped.lstrip().startswith(("//", "*", "/*")):
            # count parens outside string literals / char literals
            depth, in_str, in_chr, esc = 0, False, False, False
            for ch in stripped:
                if esc:
                    esc = False
                    continue
                if ch == "\\":
                    esc = True
                    continue
                if in_str:
                    if ch == '"':
                        in_str = False
                    continue
                if in_chr:
                    if ch == "'":
                        in_chr = False
                    continue
                if ch == '"':
                    in_str = True
                elif ch == "'":
                    in_chr = True
                elif ch == "(":
                    depth += 1
                elif ch == ")":
                    depth -= 1
            if depth > 0:
                indent_len = len(stripped) - len(stripped.lstrip())
                line = stripped[:-1] + (")" * depth) + ";"
                fixes.append(f"line {i}: added {depth} missing ')'")
        out.append(line)
    return "\n".join(out) + ("\n" if content.endswith("\n") else ""), fixes


def _validate_java(content: str) -> list[str]:
    """Report structural problems that would fail javac, so bad artifacts are
    flagged in the review screen instead of silently breaking the build."""
    problems = []
    depth = {"(": 0, "{": 0}
    in_str = in_chr = esc = False
    in_line_comment = in_block_comment = False
    prev = ""
    for ch in content:
        if in_line_comment:
            if ch == "\n":
                in_line_comment = False
            prev = ch
            continue
        if in_block_comment:
            if prev == "*" and ch == "/":
                in_block_comment = False
            prev = ch
            continue
        if esc:
            esc = False
            prev = ch
            continue
        if ch == "\\" and (in_str or in_chr):
            esc = True
            prev = ch
            continue
        if in_str:
            if ch == '"':
                in_str = False
        elif in_chr:
            if ch == "'":
                in_chr = False
        else:
            if prev == "/" and ch == "/":
                in_line_comment = True
            elif prev == "/" and ch == "*":
                in_block_comment = True
            elif ch == '"':
                in_str = True
            elif ch == "'":
                in_chr = True
            elif ch in "({":
                depth[ch] += 1
            elif ch == ")":
                depth["("] -= 1
            elif ch == "}":
                depth["{"] -= 1
        prev = ch
    if depth["("] != 0:
        problems.append(f"unbalanced round brackets ({depth['(']:+d})")
    if depth["{"] != 0:
        problems.append(f"unbalanced braces ({depth['{']:+d})")
    if "package " not in content:
        problems.append("missing package declaration")
    return problems


def _canonical_path(art: dict, transaction: str) -> str:
    """Force every artifact into one fixed layout so 1000s of recordings
    accumulate in the SAME framework structure instead of scattering.
    Page objects are named by SCREEN (shared across transactions);
    features/stepdefs by transaction."""
    atype = art.get("artifact_type", "feature")
    raw = Path(art.get("target_path", "")).stem
    # For Java artifacts the file name is dictated by the declared public class.
    if atype in ("pageobject", "stepdef", "runner"):
        declared = _declared_class(art.get("content", ""))
        if declared:
            folder = {"pageobject": "src/test/java/pages",
                      "stepdef": "src/test/java/stepdefinitions",
                      "runner": "src/test/java/runners"}[atype]
            return f"{folder}/{declared}.java"
    if atype == "pageobject":
        name = _safe(raw.removesuffix("Page") or transaction)
    else:
        name = _safe(transaction if atype in ("feature", "stepdef") else raw)
    template = _CANON.get(atype)
    return template.format(name=name) if template else art.get("target_path", "")


async def generate_for_transaction(transaction: str) -> list[int]:
    """Generate all artifacts for one transaction; returns artifact ids."""
    db = SessionLocal()
    try:
        pkg = build_knowledge_package(db, transaction)
        fw = framework_update.framework_context(transaction)
        # Feed the CURRENT content of page objects for every screen in this
        # transaction so the AI updates shared files instead of recreating them.
        screens = {a.get("screen") for a in pkg.get("actions", []) if a.get("screen")}
        for s in screens:
            rel = _CANON["pageobject"].format(name=_safe(s))
            existing_po = framework_update.read_existing(rel)
            if existing_po:
                fw["matching_files"][rel] = existing_po[:8000]

        result = await azure_client.chat_json(
            _GEN_SYSTEM,
            "Generate automation for this transaction knowledge package.\n"
            f"KNOWLEDGE PACKAGE:\n{json.dumps(pkg)[:40000]}\n"
            f"EXISTING FRAMEWORK CONTEXT:\n{json.dumps(fw)[:20000]}\n"
            'Return JSON: {"artifacts": [{"artifact_type": '
            '"feature|stepdef|pageobject|runner|testdata", '
            '"target_path": "relative/path/in/framework", "content": "..."}], '
            '"summary": "..."}',
            max_tokens=8000)

        ids, seen = [], set()
        for art in result.get("artifacts", []):
            # Auto-repair common LLM syntax slips, then validate.
            if art.get("artifact_type") in ("pageobject", "stepdef", "runner"):
                content, fixes = _balance_java(art.get("content", ""))
                art["content"] = content
                problems = _validate_java(content)
                if fixes or problems:
                    art["notes"] = ("auto-fixed: " + "; ".join(fixes) if fixes else "") + \
                                   (" | REVIEW: " + "; ".join(problems) if problems else "")
            path = _canonical_path(art, transaction)
            if path in seen:            # one artifact per file per generation
                continue
            seen.add(path)
            existing = framework_update.read_existing(path)
            # Supersede older pending artifacts for the same file so re-recording
            # a screen updates, never forks, the framework.
            db.query(GeneratedArtifact).filter_by(
                target_path=path, status="proposed").update({"status": "superseded"})
            ga = GeneratedArtifact(transaction_number=transaction,
                                   artifact_type=art["artifact_type"],
                                   target_path=path,
                                   content=art["content"],
                                   existing_content=existing)
            db.add(ga)
            db.flush()
            ids.append(ga.id)
        db.add(LearningEvent(kind="recording", reference=transaction,
                             detail={"generated": len(ids),
                                     "summary": result.get("summary")}))
        db.commit()
        return ids
    finally:
        db.close()


def approve_artifact(artifact_id: int, approve: bool, edited: str | None = None) -> dict:
    """Human review gate — approved artifacts are written by the update engine."""
    db = SessionLocal()
    try:
        art = db.query(GeneratedArtifact).get(artifact_id)
        if not art:
            return {"ok": False, "error": "not found"}
        if edited is not None:
            art.content = edited
            db.add(LearningEvent(kind="human_correction", reference=art.target_path,
                                 detail={"artifact_id": artifact_id}))
        if approve:
            framework_update.write_artifact(art.target_path, art.content)
            art.status = "written"
        else:
            art.status = "rejected"
        db.commit()
        return {"ok": True, "status": art.status}
    finally:
        db.close()
