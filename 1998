@app.post("/framework/normalize")
def framework_normalize(body: NormalizeRequest):
    """Rewrite the uploaded feature to match framework conventions (tag
    casing, step wording, scenario naming, Examples headers) BEFORE any Java
    generation. If existing_text is omitted, the best match is auto-found
    (Phase 6). Not yet wired into /execute/upload."""
    try:
        if body.existing_text is not None:
            return feature_normalizer.normalize_feature(body.uploaded_text, body.existing_text)
