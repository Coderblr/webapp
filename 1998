@app.post("/api/recorder/save")
def save_recording_session(data: RecorderSessionInput):
    """Receive a recorded session from the Chrome Extension and store all steps."""
    db = SessionLocal()
    try:
        # Create session record
        session = RecordingSessionModel(
            session_name=data.session_name,
            transaction_type=data.transaction_type,
            total_steps=len(data.steps),
            duration_seconds=data.duration_seconds or 0,
            status="captured"
        )
        db.add(session)
        db.flush()  # Get session.id

        # Store each step
        for step_input in data.steps:
            elem = step_input.element
            best_loc = elem.best_locator if elem else None
            all_locs = json.dumps(elem.locators if elem else {})

            step_model = RecordedStepModel(
                session_id=session.id,
                step_index=step_input.step_index,
                action=step_input.action,
                url=step_input.url or '',
                page_title=step_input.page_title or '',
                element_tag=elem.tag if elem else '',
                element_name=elem.element_name if elem else '',
                element_text=elem.text if elem else '',
                locator_type=best_loc.get('type') if best_loc else None,
                locator_value=best_loc.get('value') if best_loc else None,
                all_locators=all_locs,
                input_value=step_input.value or step_input.selected_text or '',
                timestamp=step_input.timestamp or '',
            )
            db.add(step_model)

        db.commit()

        # Auto-process the session to generate framework artifacts
        agent = RecorderAgent()
        result = agent.process_session(session.id)

        return {
            "session_id": session.id,
            "steps_saved": len(data.steps),
            "locators_stored": result.get("locators_stored", 0),
            "pages_discovered": result.get("pages_discovered", 0),
            "page_objects_generated": result.get("page_objects_generated", []),
            "feature_file": result.get("feature_file", ""),
            "message": result.get("message", "Session saved successfully")
        }
    except Exception as e:
        db.rollback()
        raise HTTPException(status_code=500, detail=str(e))
    finally:
        db.close()


