        <td style="padding:6px"><input type="checkbox" class="reckeep" data-i="${i}" checked></td>
        <td>${esc(e.kind)} &middot; &lt;${esc(e.tag)}&gt; ${esc((e.text || "").slice(0, 30))}</td>
