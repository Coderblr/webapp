        ["Recordings captured", d.recordings],
        ["Self-healed locators", d.self_healed],
        ["UI changes detected", d.ui_changes],
        ["Changes awaiting review", d.pending_artifacts]]
        .map(function (c) {
          return h("div", { class: "card" },
            h("div", { class: "num" }, c[1]), h("div", { class: "lbl" }, c[0]));
        });
      if (d.last_execution) {
        cards.push(h("div", { class: "card" },
          h("div", { class: "num" }, statusBadge(d.last_execution.status)),
          h("div", { class: "lbl" }, "Last run · " + d.last_execution.passed +
            " passed / " + d.last_execution.failed + " failed")));
      }
      append(wrap, [
        h("div", { class: "topbar" }, h("h1", null, "Platform overview")),
        h("div", { class: "cards" }, cards),
        h("h2", null, "Recent activity"),
        h("div", { class: "panel" },
          h("table", null, h("tbody", null, d.recent_activity.map(function (a) {
            return h("tr", null,
              h("td", null, badge("info", a.kind)),
              h("td", { class: "mono" }, a.ref),
              h("td", { class: "muted" }, a.at));
          })))),
