package pages;

import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;

public class UserPasswordExpiredForcedPasswordChangePage extends BasePage {

    private static final String TXN    = "TXN-400";
    private static final String SCREEN = "User Password Expired : Forced Password Change";

    public UserPasswordExpiredForcedPasswordChangePage(WebDriver driver) { super(driver); }

    @Override protected String transaction() { return TXN; }
    @Override protected String screen()      { return SCREEN; }

    public WebElement oldPassword()        { return find("UIPage_009750_oldPassword"); }
    public WebElement newPassword()        { return find("UIPage_009750_newPassword"); }
    public WebElement confirmNewPassword() { return find("UIPage_009750_confirmNewPassword"); }
    public WebElement submit()             { return clickable("UIPage_009750_submit"); }
    public WebElement okButton()           { return clickable("ok-button"); }

    public void changePassword(String oldPwd, String newPwd) {
        type("UIPage_009750_oldPassword", oldPwd);
        type("UIPage_009750_newPassword", newPwd);
        type("UIPage_009750_confirmNewPassword", newPwd);
        click("UIPage_009750_submit");
    }
}
