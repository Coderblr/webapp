                let html = `<div>${escapeHtml(data.message)}</div>`;
                if (data.protected_skipped && data.protected_skipped.length) {
                    html += `<div style="margin-top:8px;color:#48cfad;">Kept: ${data.protected_skipped.map(escapeHtml).join(', ')}</div>`;
                }
                resultEl.innerHTML = html;
                if (typeof loadKnowledgeGraph === 'function') loadKnowledgeGraph();
            })
            .catch(err => {
                btn.disabled = false;
                btn.textContent = '🗑️ Clear Uploaded Framework';
                resultEl.innerHTML = `<span style="color:#ff8a80;">❌ ${escapeHtml(err.message)}</span>`;
            });
    };

});
