    // ── Optional screen-video capture (visual reference alongside locators) ──
    window.toggleScreenVideo = function() {
        if (mediaRecorder && mediaRecorder.state !== 'inactive') {
            stopScreenVideo();
        } else {
            startScreenVideo();
        }
    };

    function startScreenVideo() {
        if (!navigator.mediaDevices || !navigator.mediaDevices.getDisplayMedia) {
            alert('Screen recording is not supported in this browser.');
            return;
        }
        navigator.mediaDevices.getDisplayMedia({ video: true, audio: false })
            .then(stream => {
                videoStream = stream;
                recordedChunks = [];
                mediaRecorder = new MediaRecorder(stream, { mimeType: 'video/webm' });
                mediaRecorder.ondataavailable = e => { if (e.data.size > 0) recordedChunks.push(e.data); };
                mediaRecorder.onstop = () => {
                    const blob = new Blob(recordedChunks, { type: 'video/webm' });
                    const url = URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `recording_${Date.now()}.webm`;
                    a.click();
                    URL.revokeObjectURL(url);
                };
                mediaRecorder.start();
                // User can stop sharing from the browser bar too
                stream.getVideoTracks()[0].addEventListener('ended', stopScreenVideo);

                const preview = document.getElementById('live-video-preview');
                preview.srcObject = stream;
                preview.style.display = 'block';
                preview.play().catch(()=>{});

                const btn = document.getElementById('btn-live-video');
                btn.textContent = '⏹ Stop Video';
                btn.classList.add('btn-primary');
            })
            .catch(() => {/* user cancelled the picker */});
    }

    function stopScreenVideo() {
        if (mediaRecorder && mediaRecorder.state !== 'inactive') mediaRecorder.stop();
        if (videoStream) { videoStream.getTracks().forEach(t => t.stop()); videoStream = null; }
        const preview = document.getElementById('live-video-preview');
        preview.style.display = 'none';
        preview.srcObject = null;
        const btn = document.getElementById('btn-live-video');
        btn.textContent = '🎥 Also Record Video';
        btn.classList.remove('btn-primary');
    }

    function escapeHtml(str) {
        if (!str) return '';
        return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // One-touch import of an existing hand-written java-framework into the
    // AI's knowledge graph (Pages/Locators/Step Definitions).
    function renderImportResult(data) {
        const resultEl = document.getElementById('import-result');
        let html = `<div>${escapeHtml(data.message)}</div>`;
        if (data.files_copied) {
            const fc = data.files_copied;
            const parts = [];
            if (fc.pages && fc.pages.length) parts.push(`Pages: ${fc.pages.map(escapeHtml).join(', ')}`);
            if (fc.steps && fc.steps.length) parts.push(`Steps: ${fc.steps.map(escapeHtml).join(', ')}`);
            if (fc.features && fc.features.length) parts.push(`Features: ${fc.features.map(escapeHtml).join(', ')}`);
            if (parts.length) html += `<div style="margin-top:8px;color:#48cfad;">Copied — ${parts.join(' · ')}</div>`;
        }
        if (data.page_names && data.page_names.length) {
            html += `<div style="margin-top:8px;color:#a78bfa;">Pages in knowledge graph: ${data.page_names.map(escapeHtml).join(', ')}</div>`;
        }
        if (data.files_skipped && data.files_skipped.length) {
            html += `<div style="margin-top:8px;color:#888;">Skipped (couldn't tell if page or step): ${data.files_skipped.map(escapeHtml).join(', ')}</div>`;
        }
        if (data.warnings && data.warnings.length) {
            html += `<div style="margin-top:8px;color:#ffb300;">⚠️ ${data.warnings.map(escapeHtml).join('<br>⚠️ ')}</div>`;
        }
        document.getElementById('import-result').innerHTML = html;
        if (typeof loadKnowledgeGraph === 'function') loadKnowledgeGraph();
    }

