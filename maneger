/**
 * SessionManager.js
 * Add this useEffect in your ROOT layout or main App component (not LoginPage)
 *
 * HOW IT WORKS:
 * - Tab CLOSE  → sendBeacon calls /logout → clears session → next login works
 * - Page RELOAD → performance.navigation detects reload → calls /restore-session → stays logged in
 */

import { useEffect } from "react";

const BASE_URL = process.env.NEXT_PUBLIC_API_URL;

export function useSessionManager() {
    useEffect(() => {
        // ── On mount: check if this is a reload ──────────────────────
        const navEntry = performance.getEntriesByType("navigation")[0];
        const isReload = navEntry?.type === "reload";
        const wasLoggedIn = sessionStorage.getItem("sessionActive") === "true";

        if (isReload && wasLoggedIn) {
            // Page was reloaded while logged in → restore session jti in DB
            fetch(`${BASE_URL}/restore-session`, {
                method: "POST",
                credentials: "include",   // sends cookie automatically
            }).catch(() => {});           // silently ignore errors
        }

        // ── On tab/window close: send beacon to logout ────────────────
        const handleClose = () => {
            const loggedIn = sessionStorage.getItem("sessionActive") === "true";
            if (!loggedIn) return;

            // sendBeacon sends cookies automatically for same-origin
            // For cross-origin, token goes in the body
            navigator.sendBeacon(
                `${BASE_URL}/logout`,
                new Blob([], { type: "application/json" })
            );

            // Note: sessionStorage is cleared automatically by browser on close
            // On reload it persists — that's how we detect reload vs close
        };

        window.addEventListener("pagehide", handleClose);
        return () => window.removeEventListener("pagehide", handleClose);
    }, []);
}

/**
 * Call this after successful login:
 *   setSessionActive()
 *
 * Call this after logout:
 *   clearSessionActive()
 */

export function setSessionActive() {
    sessionStorage.setItem("sessionActive", "true");
}

export function clearSessionActive() {
    sessionStorage.removeItem("sessionActive");
}manager
