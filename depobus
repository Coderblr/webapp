            @media (max-width: 760px) { .dav-form-grid { grid-template-columns: 1fr; } }

            /* ─── FIELD CARD ─── */
            .dav-field-card {
                background: var(--white);
                border: 1px solid var(--line);
                border-radius: var(--r);
                box-shadow: var(--sh);
                padding: 16px 18px;
                display: flex;
                flex-direction: column;
                gap: 10px;
                transition: border-color .15s, box-shadow .15s;
            }
