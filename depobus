"use client";
import { useState } from "react";
import RegionDropdown from "../../utils/RegionDropdown";

const PRODUCTS = [
    { code: "10111101", label: "Savings",  short: "SAV", color: "#059669", bg: "#d1fae5", border: "#6ee7b7" },
    { code: "53112401", label: "DW",        short: "DW",  color: "#2563eb", bg: "#dbeafe", border: "#93c5fd" },
    { code: "50111511", label: "TDR",       short: "TDR", color: "#7c3aed", bg: "#ede9fe", border: "#c4b5fd" },
    { code: "50111101", label: "Current",   short: "CUR", color: "#0891b2", bg: "#cffafe", border: "#67e8f9" },
    { code: "10141101", label: "NRE",       short: "NRE", color: "#b45309", bg: "#fef3c7", border: "#fcd34d" },
];

export default function DepositAccountView() {
    const [region, setRegion]           = useState("");
    const [cif, setCif]                 = useState("");
    const [prod_code, setProd_code]     = useState("");
    const [acc_segment, setAcc_Segment] = useState("");
    const [no_acc, setNo_acc]           = useState(1);
    const [response, setResponse]       = useState([]);
    const [loading, setLoading]         = useState(false);
    const [error, setError]             = useState(null);
    const [formErrors, setFormErrors]   = useState({});
    const BASE_URL = process.env.NEXT_PUBLIC_API_URL;

    const handleSubmit = async (event) => {
        event.preventDefault();
        const errors = {};
        if (!/^\d{11}$/.test(cif))
            errors.cif = "Please enter correct CIF";
        if (!no_acc || Number(no_acc) < 1 || Number(no_acc) > 10)
            errors.no_acc = "Number of accounts must be between 1 and 10";
        if (Object.keys(errors).length > 0) { setFormErrors(errors); return; }
        setFormErrors({});
        setLoading(true);
        setError(null);
        setResponse([]);
        try {
            const res = await fetch(`${BASE_URL}/create_deposit_account`, {
                credentials: "include", method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ region, cif, p_code: prod_code, seg_code: acc_segment, no_acc: parseInt(no_acc, 10) }),
            });
            if (!res.ok) throw new Error(`API error: ${res.status} ${res.statusText}`);
            setResponse(await res.json());
        } catch (err) {
            setError(err.message);
            setResponse([{ res_data: JSON.stringify({ ERROR_DESCRIPTION: err.message }) }]);
        } finally {
            setLoading(false);
        }
    };

    const selProd    = PRODUCTS.find(p => p.code === prod_code);
    const hasResults = response.length > 0;
    const cifDone    = cif.length === 11;

    return (
        <>
        <style>{`
            @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap');

            :root {
                --bg:        #f0f2f7;
                --white:     #ffffff;
                --ink:       #0d1b2e;
                --ink2:      #1c3252;
                --ink3:      #3a567a;
                --muted:     #6b80a0;
                --line:      #dde5f0;
                --line-lt:   #eef3fa;
                --navy:      #0f2a6b;
                --navy-md:   #1a3e8f;
                --navy-lt:   #e8eeff;
                --navy-gl:   rgba(15,42,107,.10);
                --orange:    #ea580c;
                --orange-lt: #fff7ed;
                --orange-gl: rgba(234,88,12,.12);
                --green:     #059669;
                --green-lt:  #d1fae5;
                --red:       #dc2626;
                --red-lt:    #fef2f2;
                --sh:        0 1px 3px rgba(13,27,46,.06), 0 4px 16px rgba(13,27,46,.07);
                --sh-lg:     0 8px 36px rgba(13,27,46,.13);
                --r:         12px;
                --font:      'Inter', sans-serif;
                --mono:      'JetBrains Mono', monospace;
            }

            .dav-root {
                font-family: var(--font);
                -webkit-font-smoothing: antialiased;
                min-height: 100%;
                background: var(--bg);
                padding: 24px 24px 48px;
                display: flex;
                flex-direction: column;
                gap: 20px;
            }

            /* ─── TOPBAR ─── */
            .dav-topbar {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 18px 24px;
                background: linear-gradient(120deg, var(--navy) 0%, var(--navy-md) 100%);
                border-radius: 14px;
                box-shadow: 0 4px 20px rgba(15,42,107,.28);
                position: relative;
                overflow: hidden;
            }
            .dav-topbar::before {
                content: "";
                position: absolute; inset: 0;
                background-image: radial-gradient(circle at 80% 50%, rgba(255,255,255,.06) 0%, transparent 60%);
                pointer-events: none;
            }
            .dav-topbar-l { display: flex; align-items: center; gap: 14px; position: relative; }
            .dav-topbar-icon {
                width: 46px; height: 46px; border-radius: 12px;
                background: rgba(255,255,255,.12);
                border: 1px solid rgba(255,255,255,.18);
                display: flex; align-items: center; justify-content: center;
                flex-shrink: 0;
            }
            .dav-topbar-title {
                font-size: 20px; font-weight: 800;
                color: #fff; letter-spacing: -.03em; line-height: 1;
            }
            .dav-topbar-sub { font-size: 13px; color: rgba(255,255,255,.55); margin-top: 4px; }
            .dav-topbar-badge {
                padding: 5px 14px; border-radius: 20px;
                background: rgba(255,255,255,.12);
                border: 1px solid rgba(255,255,255,.20);
                color: rgba(255,255,255,.85);
                font-size: 11px; font-weight: 700;
                letter-spacing: .07em; text-transform: uppercase;
                position: relative;
            }

            /* ─── STEPPER BAR ─── */
            .dav-stepper {
                display: flex;
                background: var(--white);
                border: 1px solid var(--line);
                border-radius: var(--r);
                box-shadow: var(--sh);
                overflow: hidden;
            }
            .dav-step {
                flex: 1;
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 14px 18px;
                border-right: 1px solid var(--line);
                position: relative;
            }
            .dav-step:last-child { border-right: none; }
            .dav-step-circle {
                width: 28px; height: 28px; border-radius: 50%;
