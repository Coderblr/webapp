            .dav-field-card.has-error { border-color: var(--red); box-shadow: var(--sh), 0 0 0 3px rgba(220,38,38,.08); }

            .dav-fc-label {
                font-size: 11.5px; font-weight: 700; color: var(--muted);
                letter-spacing: .06em; text-transform: uppercase;
                display: flex; align-items: center; justify-content: space-between;
            }
            .dav-fc-req { color: var(--red); font-size: 13px; }

            /* plain input inside card */
            .dav-bare-input {
                width: 100%; border: none; outline: none;
                font-family: var(--font); font-size: 15px; font-weight: 600;
                color: var(--ink); background: transparent;
                padding: 0;
            }
            .dav-bare-input::placeholder { color: var(--line); font-weight: 400; }

            /* mono cif */
            .dav-cif-row { display: flex; align-items: center; justify-content: space-between; }
            .dav-cif-input {
                font-family: var(--mono); font-size: 15px; font-weight: 600;
                color: var(--ink); background: transparent;
                border: none; outline: none; width: 80%;
                letter-spacing: .08em;
            }
            .dav-cif-input::placeholder { letter-spacing: 0; font-family: var(--font); font-weight: 400; color: var(--line); }
            .dav-cif-dots {
                display: flex; gap: 3px; align-items: center;
            }
            .dav-cif-dot {
                width: 8px; height: 8px; border-radius: 50%;
                background: var(--line);
                transition: background .12s;
            }
            .dav-cif-dot.filled { background: var(--navy); }
            .dav-cif-dot.done   { background: var(--green); }

            /* select bare */
            .dav-bare-select {
                width: 100%; border: none; outline: none; appearance: none;
                font-family: var(--font); font-size: 15px; font-weight: 600;
                color: var(--ink); background: transparent; cursor: pointer;
                padding: 0;
            }
            .dav-bare-select option { color: var(--ink); font-weight: 500; }

            /* product chips */
            .dav-prod-chips { display: flex; gap: 7px; flex-wrap: wrap; }
            .dav-prod-chip {
                display: flex; align-items: center; gap: 6px;
                padding: 6px 12px; border-radius: 20px;
                border: 1.5px solid var(--line);
                background: var(--line-lt);
                cursor: pointer; user-select: none;
                font-size: 12px; font-weight: 600; color: var(--ink3);
                transition: all .14s;
            }
            .dav-prod-chip:hover { border-color: var(--navy-md); color: var(--navy); }
            .dav-prod-chip.sel {
                background: var(--navy-lt);
                border-color: var(--navy-md);
                color: var(--navy);
                box-shadow: 0 0 0 3px var(--navy-gl);
            }
            .dav-chip-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }

            /* number stepper */
            .dav-stepper-row { display: flex; align-items: center; gap: 10px; }
            .dav-count-display {
                font-size: 28px; font-weight: 800; color: var(--ink);
                font-family: var(--mono); min-width: 40px; text-align: center;
            }
            .dav-stp-btn {
                width: 34px; height: 34px; border-radius: 9px;
                border: 1.5px solid var(--line); background: var(--line-lt);
                color: var(--ink3); font-size: 20px; font-weight: 500; line-height: 1;
                cursor: pointer; display: flex; align-items: center; justify-content: center;
                transition: background .12s, border-color .12s, color .12s;
                user-select: none;
            }
            .dav-stp-btn:hover { background: var(--navy-lt); border-color: var(--navy-md); color: var(--navy); }

            /* field error */
            .dav-ferr { font-size: 11.5px; font-weight: 500; color: var(--red); display: flex; align-items: center; gap: 4px; }
            .dav-global-err {
                padding: 12px 16px; border-radius: 10px;
                background: var(--red-lt); border: 1px solid rgba(220,38,38,.20);
                color: var(--red); font-size: 13px; font-weight: 500;
            }

            /* ─── SUBMIT ─── */
            .dav-submit-row {
                display: flex;
                align-items: center;
                gap: 14px;
                background: var(--white);
                border: 1px solid var(--line);
                border-radius: var(--r);
                box-shadow: var(--sh);
                padding: 16px 20px;
            }
            .dav-config-chips { display: flex; flex-wrap: wrap; gap: 7px; flex: 1; }
            .dav-cfg-chip {
                display: flex; align-items: center; gap: 5px;
                padding: 4px 11px; border-radius: 20px;
                background: var(--line-lt); border: 1px solid var(--line);
                font-size: 12px; font-weight: 600; color: var(--ink3);
            }
            .dav-cfg-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--navy-md); }

            .dav-submit-btn {
                flex-shrink: 0;
                height: 44px; padding: 0 28px;
                border-radius: 10px; border: none;
                background: linear-gradient(135deg, var(--navy) 0%, var(--navy-md) 100%);
                color: #fff; font-family: var(--font);
                font-size: 13.5px; font-weight: 700;
                cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;
                white-space: nowrap;
                box-shadow: 0 4px 14px rgba(15,42,107,.30);
                transition: opacity .15s, transform .12s, box-shadow .15s;
            }
            .dav-submit-btn:hover:not(:disabled) {
                opacity: .91; transform: translateY(-1px);
                box-shadow: 0 6px 20px rgba(15,42,107,.38);
            }
            .dav-submit-btn:active:not(:disabled) { transform: translateY(0); }
            .dav-submit-btn:disabled { opacity: .58; cursor: not-allowed; }
            .dav-spin {
                width: 15px; height: 15px;
                border: 2.5px solid rgba(255,255,255,.35); border-top-color: #fff;
                border-radius: 50%; animation: daspin .7s linear infinite;
            }
            @keyframes daspin { to { transform: rotate(360deg); } }

            /* ─── RESULTS ─── */
            .dav-results-header {
                display: flex; align-items: center; justify-content: space-between;
                flex-wrap: wrap; gap: 10px;
            }
            .dav-results-title-row { display: flex; align-items: center; gap: 10px; }
            .dav-results-title { font-size: 16px; font-weight: 700; color: var(--ink2); letter-spacing: -.02em; }
            .dav-res-pill {
                padding: 3px 11px; border-radius: 20px;
                background: var(--navy-lt); color: var(--navy);
                border: 1px solid rgba(15,42,107,.18);
                font-size: 12px; font-weight: 700;
            }
            .dav-res-sub { font-size: 12.5px; color: var(--muted); font-weight: 500; }

            /* result card grid */
            .dav-res-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
                gap: 12px;
            }
            .dav-res-item {
                background: var(--white);
                border: 1px solid var(--line);
                border-radius: var(--r);
                box-shadow: var(--sh);
                overflow: hidden;
                animation: resIn .24s ease both;
            }
            @keyframes resIn {
                from { opacity: 0; transform: translateY(10px) scale(.98); }
                to   { opacity: 1; transform: translateY(0) scale(1); }
            }
            .dav-res-item-head {
                padding: 11px 14px;
                display: flex; align-items: center; justify-content: space-between;
                border-bottom: 1px solid var(--line-lt);
            }
            .dav-res-idx {
                font-size: 11px; font-weight: 700; color: var(--muted);
                letter-spacing: .06em; text-transform: uppercase;
            }
            .dav-res-status-ok  { display: flex; align-items: center; gap: 5px; color: var(--green);  font-size: 12px; font-weight: 700; }
