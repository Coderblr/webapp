            .dav-step.active .dav-step-circle { background: var(--navy); color: #fff; }
            .dav-step.idle .dav-step-circle   { background: var(--line-lt); color: var(--muted); border: 1.5px solid var(--line); }
            .dav-step-label { font-size: 12px; font-weight: 600; color: var(--ink3); line-height: 1.2; }
            .dav-step-sublabel { font-size: 11px; color: var(--muted); margin-top: 2px; }
            /* done checkmark */
            .dav-step.done .dav-step-label { color: var(--green); }
            /* active indicator line */
            .dav-step.active::after {
                content: "";
                position: absolute; bottom: 0; left: 0; right: 0;
                height: 3px;
                background: linear-gradient(90deg, var(--navy), var(--navy-md));
                border-radius: 2px 2px 0 0;
            }

            /* ─── FORM GRID ─── */
            .dav-form-grid {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 14px;
