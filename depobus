    .dav-wrap { padding: 28px 16px 60px; }
    .dav-form-body { grid-template-columns: 1fr; }
    .dav-field { border-right: none !important; border-bottom: 1.5px solid #e8e8e8 !important; }
    .dav-field:last-child { border-bottom: none !important; }
    .dav-step-label { display: none; }
    .dav-results-cols, .dav-result-row { grid-template-columns: 36px 1fr 1fr; }
    .dav-submit-row { flex-direction: column; align-items: stretch; }
    .dav-submit { justify-content: center; }
  }
`;

const productLabels = {
  "10111101": "Savings",
  "53112401": "DW",
  "50111511": "TDR",
  "50111101": "Current",
  "10141101": "NRE",
};

export default function DepositAccountView() {
  const [region, setRegion] = useState("");
  const [cif, setCif] = useState("");
  const [prod_code, setProd_code] = useState("");
  const [acc_segment, setAcc_Segment] = useState("");
  const [no_acc, setNo_acc] = useState(1);
  const [response, setResponse] = useState([]);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState(null);
  const [formErrors, setFormErrors] = useState({});
  const BASE_URL = process.env.NEXT_PUBLIC_API_URL;

  const handleSubmit = async (event) => {
    event.preventDefault();
    const errors = {};
    if (!/^\d{11}$/.test(cif)) errors.cif = "Must be exactly 11 digits";
    if (!no_acc || Number(no_acc) < 1 || Number(no_acc) > 10)
      errors.no_acc = "Must be between 1 and 10";
    if (Object.keys(errors).length > 0) { setFormErrors(errors); return; }

    setFormErrors({});
    setLoading(true);
    setError(null);
    setResponse([]);

    try {
      const res = await fetch(`${BASE_URL}/create_deposit_account`, {
        credentials: "include",
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          region, cif, p_code: prod_code, seg_code: acc_segment,
          no_acc: parseInt(no_acc, 10),
        }),
      });
      if (!res.ok) throw new Error(`API error: ${res.status} ${res.statusText}`);
      const data = await res.json();
      setResponse(data);
    } catch (err) {
      setError(err.message);
      setResponse([{ res_data: JSON.stringify({ ERROR_DESCRIPTION: err.message }) }]);
    } finally {
      setLoading(false);
    }
  };

  return (
    <>
      <style>{css}</style>
      <div className="dav-wrap">

        <header className="dav-header">
          <div className="dav-header-left">
            <p className="dav-eyebrow">Deposit Operations</p>
            <h1 className="dav-title">
              Create <em>Deposit</em><br />Account
            </h1>
            <div className="dav-badge">
              <span className="dav-badge-dot" />
              System Active
            </div>
          </div>
          <div className="dav-step-label">01</div>
        </header>

        <form onSubmit={handleSubmit}>
          <div className="dav-form-body">

            {/* Region */}
            <div className="dav-field">
              <div className="dav-label">Region <span className="dav-label-num">01</span></div>
              <RegionDropdown value={region} onChange={setRegion} error={formErrors.region} />
              {formErrors.region && <span className="dav-field-error">{formErrors.region}</span>}
            </div>

            {/* CIF */}
            <div className="dav-field">
              <div className="dav-label">CIF Number <span className="dav-label-num">02</span></div>
              <input
                type="text"
                className="dav-input"
                value={cif}
                placeholder="00000000000"
                required
                onChange={(e) => {
                  const v = e.target.value;
                  if (!/^\d*$/.test(v) || v.length > 11) {
                    setFormErrors({ ...formErrors, cif: "Digits only, max 11" });
                    return;
                  }
                  setCif(v);
                  setFormErrors({ ...formErrors, cif: "" });
                }}
              />
              {formErrors.cif && <span className="dav-field-error">{formErrors.cif}</span>}
            </div>

            {/* Product Code */}
            <div className="dav-field">
              <div className="dav-label">Product Code <span className="dav-label-num">03</span></div>
              <div className="dav-select-wrap">
                <select className="dav-select" value={prod_code} onChange={(e) => setProd_code(e.target.value)} required>
                  <option value="">Select</option>
                  <option value="10111101">Savings — 10111101</option>
                  <option value="53112401">DW — 53112401</option>
                  <option value="50111511">TDR — 50111511</option>
                  <option value="50111101">Current — 50111101</option>
                  <option value="10141101">NRE — 10141101</option>
                </select>
              </div>
            </div>

            {/* Account Segment */}
            <div className="dav-field">
              <div className="dav-label">Account Segment <span className="dav-label-num">04</span></div>
              <div className="dav-select-wrap">
                <select className="dav-select" value={acc_segment} onChange={(e) => setAcc_Segment(e.target.value)} required>
                  <option value="">Select</option>
                  <option value="0706">0706</option>
                </select>
              </div>
            </div>

            {/* No. of Accounts */}
            <div className="dav-field full">
              <div className="dav-label">Number of Accounts <span className="dav-label-num">05</span></div>
              <div className="dav-counter-row">
                <span className="dav-counter-display">{no_acc}</span>
                <span className="dav-counter-hint">account{no_acc !== 1 ? "s" : ""} will be generated</span>
                <div className="dav-counter-controls">
                  <button type="button" className="dav-counter-btn" disabled={no_acc <= 1} onClick={() => setNo_acc(n => Math.max(1, n - 1))}>−</button>
                  <button type="button" className="dav-counter-btn" disabled={no_acc >= 10} onClick={() => setNo_acc(n => Math.min(10, n + 1))}>+</button>
                </div>
              </div>
              {formErrors.no_acc && <span className="dav-field-error">{formErrors.no_acc}</span>}
            </div>

          </div>

          <div className="dav-submit-row">
            <p className="dav-submit-hint">
              Submitting <strong>{no_acc}</strong> account{no_acc !== 1 ? "s" : ""}
              {prod_code ? ` · ${productLabels[prod_code] || prod_code}` : ""}
            </p>
            <button type="submit" className={`dav-submit${loading ? " dav-submit-loading" : ""}`} disabled={loading}>
              {loading ? "Processing" : "Generate"}
              <span className="dav-submit-arrow">{loading ? "…" : "→"}</span>
            </button>
          </div>
        </form>

        {(error || response.length > 0) && (
          <div className="dav-results">
            <div className="dav-results-header">
              <h2 className="dav-results-title">Output</h2>
              {response.length > 0 && <span className="dav-results-count">{response.length} record{response.length !== 1 ? "s" : ""}</span>}
            </div>

            {error && <div className="dav-error-banner"><span>⚠</span> {error}</div>}

            {response.length > 0 && (
              <>
                <div className="dav-results-cols">
                  <div className="dav-col-header">#</div>
                  <div className="dav-col-header">RRN</div>
                  <div className="dav-col-header">Status</div>
                  <div className="dav-col-header">Account No.</div>
                </div>
                <div className="dav-results-grid">
                  {response.map((item, index) => {
                    const parsed = JSON.parse(item.res_data);
                    const hasError = !!parsed.ERROR_DESCRIPTION;
                    return (
                      <div key={index} className={`dav-result-row${hasError ? " error-row" : ""}`}>
                        <span className="dav-row-index">{String(index + 1).padStart(2, "0")}</span>
                        <div><span className="dav-cell-val">{item.RRN || "—"}</span></div>
                        <div>
                          <span className={`dav-cell-val ${hasError ? "error-text" : "success"}`}>
                            {hasError ? parsed.ERROR_DESCRIPTION : (parsed.STATUS || "—")}
                          </span>
                        </div>
                        <div><span className="dav-cell-val acc">{parsed.ACCOUNT_NUMBER || "—"}</span></div>
                      </div>
                    );
                  })}
                </div>
              </>
            )}
          </div>
        )}

      </div>
    </>
  );
}
