            .dav-res-sdot { width: 6px; height: 6px; border-radius: 50%; }
            .dav-res-status-ok  .dav-res-sdot { background: var(--green); }
            .dav-res-status-err .dav-res-sdot { background: var(--red);   }

            .dav-res-item-body { padding: 14px; display: flex; flex-direction: column; gap: 10px; }
            .dav-res-acc {
                font-family: var(--mono); font-size: 17px; font-weight: 600;
                color: var(--ink); letter-spacing: .04em;
            }
            .dav-res-err-txt { font-size: 12.5px; color: var(--red); font-weight: 500; line-height: 1.4; }

            .dav-res-meta { display: flex; flex-direction: column; gap: 5px; }
            .dav-res-row {
                display: flex; align-items: center; justify-content: space-between;
                font-size: 12px;
            }
            .dav-res-key { color: var(--muted); font-weight: 500; }
            .dav-res-val { color: var(--ink2); font-weight: 600; font-family: var(--mono); font-size: 11.5px; }

            .dav-prod-badge {
                display: inline-block; padding: 3px 10px; border-radius: 20px;
                font-size: 11px; font-weight: 700; letter-spacing: .04em;
            }
        `}</style>

        <div className="dav-root">

            {/* ─── TOPBAR ─── */}
            <div className="dav-topbar">
                <div className="dav-topbar-l">
                    <div className="dav-topbar-icon">
                        <svg width="22" height="22" fill="none" stroke="#fff" strokeWidth="2.2" viewBox="0 0 24 24">
                            <path strokeLinecap="round" strokeLinejoin="round"
                                d="M3 10h18M3 10V7a2 2 0 012-2h14a2 2 0 012 2v3M3 10l2 9h14l2-9"/>
                        </svg>
                    </div>
                    <div>
                        <div className="dav-topbar-title">Create Deposit Account</div>
                        <div className="dav-topbar-sub">Generate deposit accounts linked to a customer CIF</div>
                    </div>
                </div>
                <div className="dav-topbar-badge">Account Services</div>
            </div>

            {/* ─── PROGRESS STEPPER ─── */}
            <div className="dav-stepper">
                {[
                    { label: "Region & CIF",   sub: region && cifDone ? `${region} · ${cif}` : "Select region & enter CIF", done: !!(region && cifDone) },
                    { label: "Product",         sub: selProd ? selProd.label : "Choose product code",                          done: !!prod_code },
                    { label: "Configuration",   sub: acc_segment ? `Seg ${acc_segment} · Qty ${no_acc}` : "Segment & quantity", done: !!acc_segment },
                    { label: "Generate",        sub: hasResults ? `${response.length} record(s) created` : "Submit form",       done: hasResults },
                ].map((s, i) => (
                    <div key={i} className={`dav-step ${s.done ? "done" : i === ([!!(region && cifDone), !!prod_code, !!acc_segment, hasResults].findIndex(v => !v)) ? "active" : "idle"}`}>
                        <div className="dav-step-circle">
                            {s.done ? (
                                <svg width="13" height="13" fill="none" stroke="currentColor" strokeWidth="2.5" viewBox="0 0 24 24">
                                    <path strokeLinecap="round" strokeLinejoin="round" d="M5 13l4 4L19 7"/>
                                </svg>
                            ) : i + 1}
                        </div>
                        <div>
                            <div className="dav-step-label">{s.label}</div>
                            <div className="dav-step-sublabel">{s.sub}</div>
                        </div>
                    </div>
                ))}
            </div>

            {/* ─── FORM GRID ─── */}
            <div className="dav-form-grid">

                {/* Region */}
                <div className={`dav-field-card${formErrors.region ? " has-error" : ""}`}>
                    <div className="dav-fc-label">
                        Region <span className="dav-fc-req">*</span>
                    </div>
                    <RegionDropdown value={region} onChange={setRegion} error={formErrors.region} />
                    {formErrors.region && <div className="dav-ferr">⚠ {formErrors.region}</div>}
                </div>

                {/* CIF */}
                <div className={`dav-field-card${formErrors.cif ? " has-error" : ""}`}>
                    <div className="dav-fc-label">
                        CIF Number <span className="dav-fc-req">*</span>
                        <span style={{ fontWeight: 500, textTransform: "none", letterSpacing: 0, fontSize: 11, color: cifDone ? "var(--green)" : "var(--muted)" }}>
                            {cifDone ? "✓ Valid" : `${cif.length}/11 digits`}
                        </span>
                    </div>
                    <div className="dav-cif-row">
                        <input
                            type="text"
                            value={cif}
                            placeholder="00000000000"
                            className="dav-cif-input"
                            onChange={(e) => {
                                const v = e.target.value;
                                if (!/^\d*$/.test(v) || v.length > 11) {
                                    setFormErrors({ ...formErrors, cif: "Only digits, max 11 characters" });
                                    return;
                                }
                                setCif(v);
                                setFormErrors({ ...formErrors, cif: "" });
                            }}
                        />
                        <div className="dav-cif-dots">
                            {Array.from({ length: 11 }).map((_, i) => (
                                <div key={i} className={`dav-cif-dot${cif.length > i ? (cifDone ? " done" : " filled") : ""}`} />
                            ))}
                        </div>
                    </div>
                    {formErrors.cif && <div className="dav-ferr">⚠ {formErrors.cif}</div>}
                </div>

                {/* Product Code — spans 2 cols */}
                <div className="dav-field-card" style={{ gridColumn: "1 / -1" }}>
                    <div className="dav-fc-label">Product Code <span className="dav-fc-req">*</span></div>
                    <div className="dav-prod-chips">
                        {PRODUCTS.map(p => (
                            <div
                                key={p.code}
                                className={`dav-prod-chip${prod_code === p.code ? " sel" : ""}`}
                                onClick={() => setProd_code(p.code)}
                            >
                                <div className="dav-chip-dot" style={{ background: p.color }} />
                                <span style={{ color: prod_code === p.code ? "var(--navy)" : p.color, fontWeight: 700 }}>{p.short}</span>
                                <span>{p.label}</span>
                                <span style={{ fontFamily: "var(--mono)", fontSize: 10, opacity: .7 }}>{p.code}</span>
                            </div>
                        ))}
                    </div>
                </div>

                {/* Account Segment */}
                <div className="dav-field-card">
                    <div className="dav-fc-label">Account Segment <span className="dav-fc-req">*</span></div>
                    <div style={{ position: "relative" }}>
                        <select
                            value={acc_segment}
                            onChange={(e) => setAcc_Segment(e.target.value)}
                            className="dav-bare-select"
                            required
                        >
                            <option value="">Select segment…</option>
                            <option value="0706">0706</option>
                        </select>
                    </div>
                </div>

                {/* No. of Accounts */}
                <div className={`dav-field-card${formErrors.no_acc ? " has-error" : ""}`}>
                    <div className="dav-fc-label">No. of Accounts <span className="dav-fc-req">*</span>
                        <span style={{ fontWeight: 400, textTransform: "none", letterSpacing: 0, fontSize: 11, color: "var(--muted)" }}>max 10</span>
                    </div>
                    <div className="dav-stepper-row">
                        <button className="dav-stp-btn" type="button" onClick={() => setNo_acc(v => Math.max(1, Number(v) - 1))}>−</button>
                        <div className="dav-count-display">{no_acc}</div>
                        <button className="dav-stp-btn" type="button" onClick={() => setNo_acc(v => Math.min(10, Number(v) + 1))}>+</button>
                    </div>
                    {formErrors.no_acc && <div className="dav-ferr">⚠ {formErrors.no_acc}</div>}
                </div>
            </div>

            {/* ─── SUBMIT ROW ─── */}
            <div className="dav-submit-row">
                <div className="dav-config-chips">
                    {region      && <div className="dav-cfg-chip"><div className="dav-cfg-dot"/>Region: <b>{region}</b></div>}
                    {cifDone     && <div className="dav-cfg-chip"><div className="dav-cfg-dot"/>CIF: <b style={{ fontFamily: "var(--mono)" }}>{cif}</b></div>}
                    {selProd     && <div className="dav-cfg-chip"><div className="dav-cfg-dot" style={{ background: selProd.color }}/>Product: <b>{selProd.label}</b></div>}
                    {acc_segment && <div className="dav-cfg-chip"><div className="dav-cfg-dot"/>Seg: <b>{acc_segment}</b></div>}
                    {no_acc      && <div className="dav-cfg-chip"><div className="dav-cfg-dot"/>Qty: <b>{no_acc}</b></div>}
                    {!region && !cif && !prod_code && !acc_segment && (
                        <span style={{ fontSize: 13, color: "var(--muted)" }}>Fill in the form to see a configuration summary</span>
                    )}
                </div>
                <button className="dav-submit-btn" type="button" onClick={handleSubmit} disabled={loading}>
                    {loading
                        ? <><div className="dav-spin"/>Creating…</>
                        : <>
                            <svg width="15" height="15" fill="none" stroke="currentColor" strokeWidth="2.3" viewBox="0 0 24 24">
                                <path strokeLinecap="round" d="M12 4v16m8-8H4"/>
                            </svg>
                            Create Account
                          </>
                    }
                </button>
            </div>

            {error && <div className="dav-global-err">{error}</div>}

            {/* ─── RESULTS ─── */}
            {hasResults && (
                <div style={{ display: "flex", flexDirection: "column", gap: 14 }}>
                    <div className="dav-results-header">
                        <div className="dav-results-title-row">
                            <div className="dav-results-title">Generated Records</div>
                            <div className="dav-res-pill">{response.length}</div>
                        </div>
                        <div className="dav-res-sub">CIF · {cif} &nbsp;·&nbsp; {selProd?.label || prod_code} &nbsp;·&nbsp; Seg {acc_segment}</div>
                    </div>

                    <div className="dav-res-grid">
                        {response.map((item, i) => {
                            const parsed = JSON.parse(item.res_data);
                            const isErr = !!parsed.ERROR_DESCRIPTION;
                            return (
                                <div key={i} className="dav-res-item" style={{ animationDelay: `${i * 50}ms` }}>
                                    <div className="dav-res-item-head">
                                        <div className="dav-res-idx">Record #{i + 1}</div>
                                        {isErr
                                            ? <span className="dav-res-status-err"><div className="dav-res-sdot"/>Failed</span>
                                            : <span className="dav-res-status-ok"><div className="dav-res-sdot"/>{parsed.STATUS || "Success"}</span>
                                        }
                                    </div>
                                    <div className="dav-res-item-body">
                                        {isErr ? (
                                            <div className="dav-res-err-txt">{parsed.ERROR_DESCRIPTION}</div>
                                        ) : (
                                            <>
                                                {parsed.ACCOUNT_NUMBER && (
                                                    <div className="dav-res-acc">{parsed.ACCOUNT_NUMBER}</div>
                                                )}
                                                <div className="dav-res-meta">
                                                    {item.RRN && (
                                                        <div className="dav-res-row">
                                                            <span className="dav-res-key">RRN</span>
                                                            <span className="dav-res-val">{item.RRN}</span>
                                                        </div>
                                                    )}
                                                    <div className="dav-res-row">
                                                        <span className="dav-res-key">Product</span>
                                                        {selProd
                                                            ? <span className="dav-prod-badge" style={{ background: selProd.bg, color: selProd.color }}>{selProd.label}</span>
                                                            : <span className="dav-res-val">{prod_code}</span>
                                                        }
                                                    </div>
                                                    <div className="dav-res-row">
                                                        <span className="dav-res-key">Segment</span>
                                                        <span className="dav-res-val">{acc_segment}</span>
                                                    </div>
                                                </div>
                                            </>
                                        )}
                                    </div>
                                </div>
                            );
                        })}
                    </div>
                </div>
            )}
        </div>
        </>
    );
}
