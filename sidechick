"use client";
import { useState } from "react";
import { styles } from "../../styles/AppStyles";

export default function ChequeBook() {
    const [server, setServer] = useState("");
    const [account, setAccount] = useState("");
    const [numBooks, setNumBooks] = useState("");
    const [leaves, setLeaves] = useState("");
    const [instrument, setInstrument] = useState("");
    const [response, setResponse] = useState(null);
    const [error, setError] = useState("");
    const [loading, setLoading] = useState(false);
    const [formErrors, setFormErrors] = useState({});

    const BASE_URL = process.env.NEXT_PUBLIC_API_URL;

    const validateAccount = (v) => /^\d{11}$/.test(v);
    const validateBooks = (v) => /^[1-9]$/.test(v);
    const validateLeaves = (v) => /^\d{1,4}$/.test(v);
    const validateInstrument = (v) => /^\d{2}$/.test(v);

    const validateForm = () => {
        let errors = {};

        if (!validateAccount(account)) {
            errors.account = "Account must be exactly 11 digits";
        }

        if (!validateBooks(numBooks)) {
            errors.numBooks = "Enter 1 digit (1-9)";
        }

        if (!validateLeaves(leaves)) {
            errors.leaves = "Enter up to 4 digits";
        }

        if (!validateInstrument(instrument)) {
            errors.instrument = "Enter exactly 2 digits";
        }

        if (!server) {
            errors.server = "Please select a region";
        }

        setFormErrors(errors);
        return Object.keys(errors).length === 0;
    };

    async function handleSubmit(e) {
        e.preventDefault();

        setError("");
        setResponse(null);

        if (!validateForm()) return;

        setLoading(true);

        try {
            const res = await fetch(`${BASE_URL}/chequebook`, {
                credentials: "include",
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                },
                body: JSON.stringify({
                    server,
                    acct: account,
                    no_of_chequebook: numBooks,
                    leaves_per_book: leaves.padStart(4, "0"),
                    instrument_type: instrument,
                }),
            });

            if (!res.ok) {
                if (res.status === 401 || res.status === 403) {
                    setError("Session expired. Please login again.");
                    window.location.reload();
                    return;
                }
                throw new Error(`${res.status} ${res.statusText}`);
            }

            const data = await res.json();
            setResponse(data);
        } catch (err) {
            setError(err.message);
        } finally {
            setLoading(false);
        }
    }

    return (
        <div>
            <div style={styles.pageHeader}>
                <h1 style={styles.pageTitle}>Cheque Book Request</h1>
                <p style={styles.pageSubtitle}>Create Cheque Book</p>
            </div>

            <div style={styles.formCard}>
                <form onSubmit={handleSubmit}>
                    <div style={styles.formGrid}>

                        {/* Account */}
                        <div style={styles.formGroup}>
                            <label style={styles.label}>Account Number</label>
                            <input
                                type="text"
                                maxLength={11}
                                value={account}
                                onChange={(e) => {
                                    const value = e.target.value.replace(/\D/g, "");
                                    setAccount(value);
                                }}
                            />
                            {formErrors.account && <div style={styles.fieldError}>{formErrors.account}</div>}
                        </div>

                        {/* Books */}
                        <div style={styles.formGroup}>
                            <label style={styles.label}>No. of Cheque Books</label>
                            <input
                                type="text"
                                maxLength={1}
                                value={numBooks}
                                onChange={(e) => {
                                    const value = e.target.value.replace(/\D/g, "");
                                    setNumBooks(value);
                                }}
                            />
                            {formErrors.numBooks && <div style={styles.fieldError}>{formErrors.numBooks}</div>}
                        </div>

                        {/* Leaves */}
                        <div style={styles.formGroup}>
                            <label style={styles.label}>Leaves per Book</label>
                            <input
                                type="text"
                                maxLength={4}
                                value={leaves}
                                onChange={(e) => {
                                    const value = e.target.value.replace(/\D/g, "");
                                    setLeaves(value);
                                }}
                            />
                            {formErrors.leaves && <div style={styles.fieldError}>{formErrors.leaves}</div>}
                        </div>

                        {/* Instrument */}
                        <div style={styles.formGroup}>
                            <label style={styles.label}>Instrument Type (2 digits)</label>
                            <input
                                type="text"
                                maxLength={2}
                                value={instrument}
                                onChange={(e) => {
                                    const value = e.target.value.replace(/\D/g, "");
                                    setInstrument(value);
                                }}
                            />
                            {formErrors.instrument && <div style={styles.fieldError}>{formErrors.instrument}</div>}
                        </div>

                        {/* Region */}
                        <div style={styles.formGroup}>
                            <label style={styles.label}>Region</label>
                            <select value={server} onChange={(e) => setServer(e.target.value)} style={styles.select}>
                                <option value="">Select Region</option>
                                <option value="O">O - UAT</option>
                                <option value="Y">Y - UAT</option>
                                <option value="Z">Z - UAT</option>
                                <option value="K">K - Pre-Prod</option>
                                <option value="R1">R1 - Pre-Prod</option>
                                <option value="Y2">Y2 - Pre-Prod</option>
                                <option value="L">L - Pre-Prod</option>
                            </select>
                            {formErrors.server && <div style={styles.fieldError}>{formErrors.server}</div>}
                        </div>
                    </div>

                    {error && <div style={styles.errorMsg}>{error}</div>}

                    <button type="submit" style={styles.primaryButton} disabled={loading}>
                        {loading ? "Generating..." : "Generate"}
                    </button>
                </form>
            </div>

            {/* Response stays same */}
        </div>
    );
}