python@router.post("/logout", tags=["Auth"])
async def logout(
    request:  Request,
    response: Response,
    session:  DBS.SessionDep,
):
    # ── Get token from cookie, header, or beacon body ──
    token = request.cookies.get("access_token")

    if not token:
        auth = request.headers.get("Authorization", "")
        if auth.startswith("Bearer "):
            token = auth[7:]

    if not token:
        # sendBeacon sends token in body
        try:
            body  = await request.json()
            token = body.get("token")
        except Exception:
            pass

    if not token:
        return {"message": "Logged out."}

    # ── Get username from token ──
    try:
        payload  = Security.decode_token(token)
        username = payload.get("sub")
    except Exception:
        Security.clear_auth_cookies(response)
        return {"message": "Logged out."}

    if not username:
        return {"message": "Logged out."}

    # ── Blacklist token ──
    Security.blacklist_token(token, username, session)

    # ── Clear active_session_jti ──
    session.execute(
        sql_update(User.DBUser)
        .where(User.DBUser.username == username)
        .values(active_session_jti=None)
    )
    session.commit()

    Security.clear_auth_cookies(response)

    # ── Audit log (skip for beacon — no departmentCode easily available) ──
    try:
        db_user = session.get(User.DBUser, username)
        if db_user:
            garage.capture_log(username, "/token(logout)", db_user.departmentCode, session)
    except Exception:
        pass

    return {"message": "Logged out successfully."}
