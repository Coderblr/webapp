import re
from pathlib import Path
from typing import Optional

# Array form: features = { "path/one.feature", "path/two.feature" }
FEATURES_ARRAY_RE = re.compile(r'(features\s*=\s*\{)(.*?)(\})', re.DOTALL)
# Single quoted-string form: features = "path/one.feature"
FEATURES_STRING_RE = re.compile(r'(features\s*=\s*")([^"]*)(")')


class TestRunnerPatchError(Exception):
    pass


class TestRunnerPatcher:
    """Temporarily narrows TestRunner.java's @CucumberOptions(features=...) to a
    single feature file, and restores the original content afterwards."""

    def __init__(self, testrunner_path: Path):
        self.testrunner_path = testrunner_path
        self._original_content: Optional[str] = None

    def point_to_single_feature(self, feature_relative_path: str) -> None:
        self._original_content = self.testrunner_path.read_text(encoding="utf-8")
        normalized = feature_relative_path.replace("\\", "/")

        patched, count = FEATURES_ARRAY_RE.subn(
            rf'\g<1>\n        "{normalized}"\n    \g<3>',
            self._original_content,
            count=1,
        )
        if count == 0:
            patched, count = FEATURES_STRING_RE.subn(
                rf'\g<1>{normalized}\g<3>', self._original_content, count=1
            )
        if count == 0:
            raise TestRunnerPatchError(
                "Could not locate 'features' attribute in TestRunner.java"
            )
        self.testrunner_path.write_text(patched, encoding="utf-8")

    def restore(self) -> None:
        if self._original_content is not None:
            self.testrunner_path.write_text(self._original_content, encoding="utf-8")
