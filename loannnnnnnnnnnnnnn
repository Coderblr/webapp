"""
FastAPI orchestrator for the Java Cucumber framework.

Flow 1 (manager's primary flow):
    POST /execute/txn/{txn_no}      -> looks up the feature in the index, runs it on Edge

Flow 2 (alternate flow):
    POST /execute/upload            -> user uploads a .feature file; we detect its module,
                                       dry-run to verify glue code exists, then execute it

Common:
    GET  /jobs/{job_id}             -> status + pass/fail summary
    GET  /jobs/{job_id}/logs        -> live console log (poll with ?offset=)
    GET  /txns?q=0104               -> search the index (for an autocomplete box in Next.js)
    POST /index/rebuild             -> rescan the framework after new features are added

Run with:  uvicorn app.main:app --reload --port 8000
"""
import re

from fastapi import FastAPI, File, Form, HTTPException, UploadFile
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel

from . import config, executor, indexer


class RunParams(BaseModel):
    """Target environment + credentials for one execution.
    All optional — omit any value to keep whatever the properties file already has."""
    url: str | None = None
    maker_id: str | None = None
    maker_password: str | None = None
    checker_id: str | None = None
    checker_password: str | None = None

app = FastAPI(title="Java Framework Orchestrator")

app.add_middleware(
    CORSMiddleware,
    allow_origins=["http://localhost:3000"],  # your Next.js dev server
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)


@app.on_event("startup")
def _startup():
    if config.FRAMEWORK_ROOT.exists():
        indexer.build_index()


# ─────────────────────────── index endpoints ────────────────────────────────
@app.post("/index/rebuild")
def rebuild_index():
    idx = indexer.build_index()
    return {"indexed_txns": len(idx)}


@app.get("/txns")
def search_txns(q: str = "", all: bool = False):
    """Returns [{txn, module, file}] — the full list when all=1 so the UI can
    offer a scrollable, searchable dropdown of every feature."""
    idx = indexer.get_index()
    q = q.lower()
    items = []
    for k, v in sorted(idx.items()):
        if q and q not in k.lower() and q not in (v.get("feature") or "").lower():
            continue
        from pathlib import Path as _P
        items.append({"txn": k, "module": v.get("module") or "",
                      "file": _P(v["feature"]).name if v.get("feature") else ""})
    if not all:
        items = items[:50]
    return {"count": len(items), "txns": items}


# ───────────────────────── flow 1: run by txn number ────────────────────────
@app.post("/execute/txn/{txn_no}")
def execute_txn(txn_no: str, params: RunParams | None = None):
    """txn_no arrives as e.g. 'Txn36048' or 'txn69069' (prefix chosen in the UI).
    We locate the feature via the index, VERIFY the matching @tag exists inside
    the feature file, then run with cucumber.filter.tags=<that exact tag> —
    same effect as replacing the number in TestRunner's tags, but with no
    Java edit and no recompile."""
    hit = indexer.lookup(txn_no)
    if not hit:
        raise HTTPException(404, f"Txn '{txn_no}' not found in index. Try POST /index/rebuild.")
    if not hit.get("feature"):
        raise HTTPException(409, f"{hit['txn']} exists but has no .feature file indexed.")

    # find the matching tag inside the feature file. Frameworks tag in several
    # styles, so we accept (in priority order):
    #   1. @Txn012000                              (exact, any casing)
    #   2. @Txn012000_LoansCreateLoanDetails       (starts with the txn id)
    #   3. @12000                                  (bare number, zero-padding ignored)
    from pathlib import Path as _P
    text = _P(hit["feature"]).read_text(encoding="utf-8", errors="ignore")
    tags_in_file = re.findall(r"@[\w]+", text)
    digits = re.sub(r"\D", "", txn_no)

    def _match_rank(t: str) -> int:
        low = t.lower().lstrip("@")
        if low == f"txn{digits}".lower():
            return 1
        if low.startswith(f"txn{digits}".lower()) and not low[len(f"txn{digits}"):][:1].isdigit():
            return 2
        if low.isdigit() and low.lstrip("0") == digits.lstrip("0"):
            return 3
        return 99

    tag = min(tags_in_file, key=_match_rank, default=None)
    if tag is not None and _match_rank(tag) == 99:
        tag = None
    if not tag:
        raise HTTPException(409,
            f"Feature found ({_P(hit['feature']).name}) but it has no @{txn_no} tag. "
            f"Tags present in the file: {sorted(set(tags_in_file)) or 'none'}. "
            f"Add the tag above the Scenario/Feature line, or run without tag matching.")

    job = executor.start_job(hit["feature"],
                             run_params=params.model_dump() if params else None,
                             tag_filter=tag)
    return {"txn": hit["txn"], "module": hit["module"], "tag": tag, **job.public()}


# ───────────────────── flow 2: run an uploaded feature ──────────────────────
@app.post("/execute/upload")
async def execute_upload(
    file: UploadFile = File(...),
    dry_run: bool = False,
    url: str | None = Form(None),
    maker_id: str | None = Form(None),
    maker_password: str | None = Form(None),
    checker_id: str | None = Form(None),
    checker_password: str | None = Form(None),
):
    if not file.filename.endswith(".feature"):
        raise HTTPException(400, "Please upload a .feature file.")
    text = (await file.read()).decode("utf-8", errors="ignore")
    if "Scenario" not in text and "Scenario Outline" not in text:
        raise HTTPException(400, "File does not look like a valid Gherkin feature.")

    module = indexer.detect_module(text)
    dest = config.UPLOADS_DIR / file.filename
    dest.write_text(text, encoding="utf-8")

    run_params = {
        "url": url,
        "maker_id": maker_id,
        "maker_password": maker_password,
        "checker_id": checker_id,
        "checker_password": checker_password,
    }
    # NOTE: we execute the feature straight from our uploads folder via the
    # cucumber features override. The framework's source is never modified;
    # only the properties file is patched for the run and restored afterwards.
    job = executor.start_job(str(dest), dry_run=dry_run, run_params=run_params)
    closest = indexer.closest_feature(text, module)
    return {
        "module_detected": module,
        "closest_existing_feature": closest,
        "hint": "If the run reports undefined_steps, the framework has no Java glue "
                "for those lines — reuse the closest_existing_feature's wording, "
                "or generate new step definitions (phase 2).",
        **job.public(),
    }


# ─────────────────────────── job status / logs ──────────────────────────────
@app.post("/jobs/{job_id}/stop")
def stop_job(job_id: str):
    ok = executor.stop_job(job_id)
    if not ok:
        raise HTTPException(409, "Job is not running (or unknown id).")
    return {"job_id": job_id, "status": "stopping"}


@app.get("/jobs/{job_id}")
def job_status(job_id: str):
    job = executor.JOBS.get(job_id)
    if not job:
        raise HTTPException(404, "Unknown job id.")
    return job.public()


@app.get("/jobs/{job_id}/logs")
def job_logs(job_id: str, offset: int = 0):
    chunk, new_offset = executor.read_log(job_id, offset)
    job = executor.JOBS.get(job_id)
    return {
        "log": chunk,
        "next_offset": new_offset,
        "status": job.status if job else "unknown",
    }


# ───────────────────────── serve the frontend ───────────────────────────────
# Must be mounted LAST so it doesn't shadow the API routes above.
# Open http://localhost:8000 in a browser after starting uvicorn.
from pathlib import Path as _Path
from fastapi.staticfiles import StaticFiles

_FRONTEND_DIR = _Path(__file__).resolve().parent.parent / "frontend"
if _FRONTEND_DIR.exists():
    app.mount("/", StaticFiles(directory=str(_FRONTEND_DIR), html=True), name="frontend")



















