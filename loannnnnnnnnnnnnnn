import json
from pathlib import Path
from typing import Dict, Optional

from app import config


def find_latest_html_report(framework_root: Path) -> Optional[Path]:
    reports_dir = framework_root / config.HTML_REPORT_RELATIVE_DIR
    if not reports_dir.exists():
        return None
    html_files = list(reports_dir.rglob("*.html"))
    if not html_files:
        return None
    return max(html_files, key=lambda p: p.stat().st_mtime)


def summarize_json_report(framework_root: Path) -> Dict:
    json_path = framework_root / config.JSON_REPORT_RELATIVE_PATH
    summary = {"total_scenarios": 0, "passed_scenarios": 0, "failed_scenarios": 0}
    if not json_path.exists():
        return summary

    try:
        data = json.loads(json_path.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError):
        return summary

    for feature in data:
        for element in feature.get("elements", []):
            if element.get("type") != "scenario":
                continue
            summary["total_scenarios"] += 1
            steps = element.get("steps", [])
            failed = any(
                step.get("result", {}).get("status") != "passed" for step in steps
            )
            if failed:
                summary["failed_scenarios"] += 1
            else:
                summary["passed_scenarios"] += 1

    return summary
