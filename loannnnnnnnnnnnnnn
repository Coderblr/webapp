import re
from pathlib import Path
from typing import Optional

from app import config

FEATURE_LINE_RE = re.compile(r"^\s*Feature:\s*(.+)$", re.MULTILINE)
TXN_RE = re.compile(r"(Txn\d+)", re.IGNORECASE)


class FeatureValidationError(Exception):
    pass


def validate_feature_content(filename: str, content: str) -> None:
    if not filename.lower().endswith(".feature"):
        raise FeatureValidationError("Uploaded file must have a .feature extension.")
    if not content.strip():
        raise FeatureValidationError("Uploaded feature file is empty.")
    if not FEATURE_LINE_RE.search(content):
        raise FeatureValidationError(
            "Uploaded file does not contain a valid 'Feature:' definition."
        )


def extract_feature_name(content: str) -> str:
    match = FEATURE_LINE_RE.search(content)
    return match.group(1).strip() if match else "Unknown Feature"


def extract_transaction_number(filename: str, content: str) -> Optional[str]:
    match = TXN_RE.search(Path(filename).stem)
    if match:
        return match.group(1)
    match = TXN_RE.search(content)
    if match:
        return match.group(1)
    return None


def find_existing_feature(
    framework_root: Path, filename: str, txn_number: Optional[str]
) -> Optional[Path]:
    features_dir = framework_root / config.FEATURES_RELATIVE_DIR
    if not features_dir.exists():
        return None

    candidates = list(features_dir.rglob("*.feature"))

    for path in candidates:
        if path.name.lower() == filename.lower():
            return path

    if txn_number:
        for path in candidates:
            if txn_number.lower() in path.name.lower():
                return path

    return None
